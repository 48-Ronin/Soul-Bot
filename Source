  /**
   * Execute a trade with Jupiter
   * @param {string} fromMint Input token mint
   * @param {string} toMint Output token mint
   * @param {number} amount Amount to swap
   * @param {string} strategy Strategy name
   * @returns {Promise<boolean>} Success or failure 
   */
  async executeTrade(fromMint, toMint, amount, strategy) {
    if (this.#isTradeInProgress && strategy !== 'STOP_LOSS') {
      this.log('Another trade is in progress, skipping', 'warn');
      return false;
    }
    
    this.#isTradeInProgress = true;
    
    try {
      const fromSymbol = this.#mintToSymbol(fromMint);
      const toSymbol = this.#mintToSymbol(toMint);
      const tradeType = strategy === 'ARBITRAGE' ? 'SWAP' : (fromMint === this.#tokenRegistry.USDC ? 'BUY' : 'SELL');

      this.notify(`Preparing to trade ${amount.toFixed(6)} ${fromSymbol} to ${toSymbol}`);

      // Validate minimum viable amount
      const fromPrice = await this.getTokenPrice(fromMint);
      const fromValueUsd = amount * fromPrice;
      const minViableUsd = 0.1; // $0.10 minimum value
      
      if (fromValueUsd < minViableUsd) {
        this.notify(`Trade value too small: $${fromValueUsd.toFixed(4)} < $${minViableUsd}`, 'warn');
        return false;
      }

      // Check balance
      const balance = await this.getTokenBalance(fromMint);
      if (balance < amount) {
        this.notify(`Insufficient balance: ${balance.toFixed(6)} ${fromSymbol} < ${amount.toFixed(6)} ${fromSymbol}`, 'warn');
        return false;
      }

      // Get token decimals
      const fromDecimals = await this.getTokenDecimals(fromMint);
      const toDecimals = await this.getTokenDecimals(toMint);

      // Adjust amount to account for fees
      const adjustedAmount = amount * 0.99; // Leave 1% for fees
      
      // In demo mode, simulate the trade
      if (this.#demoMode) {
        // Get quote to determine expected output
        const quote = await this.getJupiterQuote(fromMint, toMint, adjustedAmount);
        if (!quote) {
          this.notify(`Failed to get Jupiter quote for ${fromSymbol} → ${toSymbol}`, 'error');
          return false;
        }
        
        // Calculate expected output
        const expectedOutput = parseFloat(quote.outAmount) / Math.pow(10, toDecimals);
        
        this.notify(`[DEMO] Trading ${adjustedAmount.toFixed(6)} ${fromSymbol} → ${expectedOutput.toFixed(6)} ${toSymbol}`);
        
        // Update demo balances
        const trade = await this.updateDemoBalancesForTrade(
          fromMint, 
          toMint, 
          adjustedAmount, 
          expectedOutput, 
          strategy
        );
        
        // Send notification
        await this.sendDiscordTradeNotification({
          strategy,
          tradeType,
          inputAmount: adjustedAmount,
          inputSymbol: fromSymbol,
          outputAmount: expectedOutput,
          outputSymbol: toSymbol,
          profit: trade.profitUsd,
          profitPercent: (trade.profitUsd / fromValueUsd) * 100
        });
        
        return true;
      }
      
      // In simulation mode, just log the trade
      if (this.#simulationMode) {
        this.notify(`[SIMULATION] Would trade ${adjustedAmount.toFixed(6)} ${fromSymbol} to ${toSymbol}`);
        
        // Get quote to determine expected output
        const quote = await this.getJupiterQuote(fromMint, toMint, adjustedAmount);
        if (!quote) {
          this.notify(`Failed to get Jupiter quote for ${fromSymbol} → ${toSymbol}`, 'error');
          return false;
        }
        
        // Calculate expected output
        const expectedOutput = parseFloat(quote.outAmount) / Math.pow(10, toDecimals);
        const toPrice = await this.getTokenPrice(toMint);
        const profit = (expectedOutput * toPrice) - fromValueUsd;
        
        // Record successful trade
        this.#successfulTrades++;
        this.#totalProfitLoss += profit;
        
        // Send notification
        await this.sendDiscordTradeNotification({
          strategy,
          tradeType,
          inputAmount: adjustedAmount,
          inputSymbol: fromSymbol,
          outputAmount: expectedOutput,
          outputSymbol: toSymbol,
          profit,
          profitPercent: (profit / fromValueUsd) * 100
        });
        
        // Add to trade history
        this.#addTradeToHistory({
          timestamp: new Date().toISOString(),
          strategy,
          tradeType,
          input: {
            mint: fromMint,
            symbol: fromSymbol,
            amount: adjustedAmount
          },
          output: {
            mint: toMint,
            symbol: toSymbol,
            amount: expectedOutput
          },
          status: 'simulated',
          profit,
          profitPercent: (profit / fromValueUsd) * 100
        });
        
        return true;
      }
      
      // Live trading mode - check if wallet is read-only
      if (this.#walletType === 'readOnly') {
        this.notify('Cannot execute trade in read-only mode', 'error');
        return false;
      }
      
      // Ensure token accounts exist
      const fromAccountExists = await this.ensureTokenAccount(fromMint);
      const toAccountExists = await this.ensureTokenAccount(toMint);
      
      if (!fromAccountExists || !toAccountExists) {
        this.notify('Failed to ensure token accounts exist', 'error');
        return false;
      }
      
      // Get Jupiter quote
      const quote = await this.getJupiterQuote(fromMint, toMint, adjustedAmount);
      if (!quote) {
        this.notify(`Failed to get Jupiter quote for ${fromSymbol} → ${toSymbol}`, 'error');
        this.#failedTrades++;
        return false;
      }
      
      // Calculate expected output
      const expectedOutput = parseFloat(quote.outAmount) / Math.pow(10, toDecimals);
      
      this.notify(`Quote received: ${adjustedAmount.toFixed(6)} ${fromSymbol} → ${expectedOutput.toFixed(6)} ${toSymbol}`);
      
      // Calculate adaptive slippage based on token properties
      const priceImpact = quote.priceImpactPct || 0;
      
      // Get token-specific slippage settings
      const inputTokenSlippage = this.#tokenSlippage[fromMint] || this.#tokenSlippage[fromSymbol] || 0.5;
      const outputTokenSlippage = this.#tokenSlippage[toMint] || this.#tokenSlippage[toSymbol] || 0.5;
      
      // Use the higher of the two token slippages as base
      let slippage = Math.max(inputTokenSlippage, outputTokenSlippage);
      
      // Adjust slippage based on price impact
      if (priceImpact > 1) {
        slippage += priceImpact * 0.5; // Add 0.5% for each 1% of price impact
      }
      
      // Additional adjustment for higher impacts
      if (priceImpact > 3) {
        slippage += priceImpact * 0.3;
      }
      
      // Cap maximum slippage at 8% for most cases, higher for stop loss
      const maxSlippage = strategy === 'STOP_LOSS' ? 15 : 8;
      slippage = Math.min(slippage, maxSlippage);
      
      // Convert to basis points
      const slippageBps = Math.floor(slippage * 100);
      
      // Create swap transaction
      const transaction = await this.createSwapTransaction(quote, slippageBps);
      if (!transaction) {
        this.notify(`Failed to create swap transaction`, 'error');
        this.#failedTrades++;
        return false;
      }
      
      // Calculate estimated fee before sending
      const estimatedFeeInLamports = await this.#estimateTransactionFee();
      const solPrice = await this.getTokenPrice(this.#tokenRegistry.SOL);
      const estimatedFeeUsd = (estimatedFeeInLamports / 1e9) * solPrice;
      
      this.notify('Sending transaction to network...');
      
      // Send and confirm transaction
      const txid = await this.#sendAndConfirmTransaction(transaction);
      if (!txid) {
        this.notify(`Transaction failed to confirm`, 'error');
        this.#failedTrades++;
        return false;
      }
      
      this.notify(`Transaction confirmed! Signature: ${txid}`);
      
      // Calculate profit/loss
      const toPrice = await this.getTokenPrice(toMint);
      const toValueUsd = expectedOutput * toPrice;
      const profit = toValueUsd - fromValueUsd;
      const profitWithFees = profit - estimatedFeeUsd;
      
      // Add to successful trades count
      this.#successfulTrades++;
      this.#totalProfitLoss += profitWithFees;
      
      // Record in trade history
      const trade = {
        timestamp: new Date().toISOString(),
        strategy,
        tradeType,
        fromMint,
        fromSymbol,
        toMint,
        toSymbol,
        fromAmount: adjustedAmount,
        toAmount: expectedOutput,
        fromValueUsd,
        toValueUsd,
        profit: profitWithFees,
        profitPercent: (profitWithFees / fromValueUsd) * 100,
        txid,
        fee: estimatedFeeUsd,
        status: 'success'
      };
      
      this.#addTradeToHistory(trade);
      
      // Send detailed notification
      await this.sendDiscordTradeNotification({
        strategy,
        tradeType,
        inputAmount: adjustedAmount,
        inputSymbol: fromSymbol,
        outputAmount: expectedOutput,
        outputSymbol: toSymbol,
        profit: profitWithFees,
        profitPercent: (profitWithFees / fromValueUsd) * 100,
        txid
      });
      
      return true;
    } catch (error) {
      this.notify(`Trade execution failed: ${error.message}`, 'error');
      this.#failedTrades++;
      return false;
    } finally {
      this.#isTradeInProgress = false;
    }
  }
  
  /**
   * Check for arbitrage opportunities and execute trades
   * @returns {Promise<void>} 
   */
  async findArbitrageOpportunities() {
    if (this.#arbitrageActive) {
      this.log('Arbitrage strategy already running', 'debug');
      return;
    }
    
    this.#arbitrageActive = true;
    
    try {
      this.log('Checking arbitrage opportunities...');
      
      // Skip if daily loss limit hit
      if (this.#hasHitDailyLossLimit()) {
        this.log('Daily loss limit reached, skipping arbitrage', 'warn');
        return;
      }
      
      // Calculate available capital
      const portfolioValue = this.#demoMode ? 
        await this.calculateDemoPortfolioValue() : 
        await this.calculatePortfolioValue();
      const arbitrageCapital = portfolioValue * (this.#arbitrageAllocation / 100);
      const tradeRiskAmount = arbitrageCapital * (this.#maxRiskPercentage / 100);
      
      this.log(`Arbitrage capital: $${arbitrageCapital.toFixed(2)}, Trade risk: $${tradeRiskAmount.toFixed(2)}`);
      
      // Check SOL balance for fees
      const solBalance = await this.getTokenBalance(this.#tokenRegistry.SOL);
      if (solBalance < 0.01 && !this.#demoMode && !this.#simulationMode) {
        this.log(`Insufficient SOL for transaction fees: ${solBalance.toFixed(6)} SOL`, 'warn');
        return;
      }
      
      // Get market volatility to adjust profit threshold
      const marketVolatility = parseFloat(this.#getStoredValue('marketVolatility') || '0');
      let adjustedProfitThreshold = this.#minProfitThreshold;
      if (marketVolatility > 10) {
        adjustedProfitThreshold = this.#minProfitThreshold * 1.5;
      }
      
      // Track potential opportunities
      let bestOpportunity = {
        profit: 0,
        pair: null,
        fromMint: null,
        toMint: null,
        tradeSize: 0,
        quote: null
      };
      
      // Create trading pairs from token registry - fully matrix
      const tokens = Object.entries(this.#tokenRegistry);
      const tradingPairs = [];
      
      // Add all possible combinations
      for (let i = 0; i < tokens.length; i++) {
        for (let j = 0; j < tokens.length; j++) {
          if (i !== j) {
            tradingPairs.push(`${tokens[i][0]}-${tokens[j][0]}`);
          }
        }
      }
      
      // Check for arbitrage across all trading pairs
      for (const pair of tradingPairs) {
        try {
          const [fromSymbol, toSymbol] = pair.split('-');
          const fromMint = this.#tokenRegistry[fromSymbol];
          const toMint = this.#tokenRegistry[toSymbol];
          
          if (!fromMint || !toMint) continue;
          
          // Skip pairs with recent failed attempts
          const pairKey = `${fromMint}-${toMint}`;
          const lastFailTime = parseInt(this.#getStoredValue(`lastFail_${pairKey}`) || '0');
          const backoffPeriod = parseInt(this.#getStoredValue(`backoff_${pairKey}`) || '60000');
          
          if (Date.now() - lastFailTime < backoffPeriod) continue;
          
          // Check token balances
          const fromBalance = await this.getTokenBalance(fromMint);
          if (fromBalance <= 0) continue;
          
          // Check if token has hit stop loss
          const fromPrice = await this.getTokenPrice(fromMint);
          const fromValueUsd = fromBalance * fromPrice;
          
          const stopLossCheck = await this.checkStopLoss(fromMint, fromValueUsd);
          if (stopLossCheck.triggered) {
            await this.executeStopLossExit(fromMint);
            continue;
          }
          
          // Calculate trade size
          const minViableAmount = this.#minimumViableAmounts[fromMint] || 0.001;
          const tradeSize = Math.max(
            Math.min(tradeRiskAmount / fromPrice, fromBalance * 0.98),
            minViableAmount
          );
          
          if (tradeSize * fromPrice < 0.1) continue;
          
          // Get quote
          const quote = await this.getJupiterQuote(fromMint, toMint, tradeSize);
          if (!quote) {
            // Record failure with exponential backoff
            const currentBackoff = parseInt(this.#getStoredValue(`backoff_${pairKey}`) || '60000');
            const newBackoff = Math.min(currentBackoff * 2, 3600000); // Max 1 hour
            this.#setStoredValue(`lastFail_${pairKey}`, Date.now().toString());
            this.#setStoredValue(`backoff_${pairKey}`, newBackoff.toString());
            continue;
          }
          
          // Reset backoff on successful quote
          this.#setStoredValue(`backoff_${pairKey}`, '60000');
          
          // Calculate profit
          const outAmount = parseFloat(quote.outAmount) / Math.pow(10, await this.getTokenDecimals(toMint));
          const toPrice = await this.getTokenPrice(toMint);
          
          const inputValue = tradeSize * fromPrice;
          const outputValue = outAmount * toPrice;
          
          // Estimate transaction fee
          const estimatedFeeInLamports = await this.#estimateTransactionFee();
          const solPrice = await this.getTokenPrice(this.#tokenRegistry.SOL);
          const transactionFeeUsd = (estimatedFeeInLamports / 1e9) * solPrice;
          
          // Calculate net profit after fees
          const netProfitUsd = outputValue - inputValue - transactionFeeUsd;
          const netProfitPercentage = (netProfitUsd / inputValue) * 100;
          
          // Track best opportunity
          if (netProfitPercentage > adjustedProfitThreshold && netProfitPercentage > bestOpportunity.profit) {
            bestOpportunity = {
              profit: netProfitPercentage,
              pair,
              fromMint,
              toMint,
              tradeSize,
              quote,
              netProfitUsd
            };
          }
        } catch (e) {
          this.log(`Error checking arbitrage for ${pair}: ${e.message}`, 'error');
        }
      }
      
      // Execute the best opportunity found
      if (bestOpportunity.profit > 0) {
        this.log(`Executing best arbitrage: ${bestOpportunity.pair} with ${bestOpportunity.profit.toFixed(2)}% profit`);
        await this.executeTrade(
          bestOpportunity.fromMint, 
          bestOpportunity.toMint, 
          bestOpportunity.tradeSize, 
          'ARBITRAGE'
        );
      } else {
        this.log('No profitable arbitrage opportunities found');
      }
    } catch (error) {
      this.log(`Error in arbitrage strategy: ${error.message}`, 'error');
    } finally {
      this.#arbitrageActive = false;
    }
  }
  
  /**
   * Get token price movements
   * @returns {Promise<Map<string, Object>>} Map of token price movements
   */
  async getTokenPriceMovements() {
    try {
      // Create set of unique tokens
      const uniqueTokens = new Set(Object.values(this.#tokenRegistry));
      
      // Create comma-separated list of mints
      const mints = Array.from(uniqueTokens).join(',');
      
      // Use circuit breaker for Jupiter Price API
      return await this.#jupiterQuoteCircuitBreaker.execute(
        async () => {
          const controller = new AbortController();
          const timeoutId = setTimeout(() => controller.abort(), 15000);
          
          try {
            const response = await fetch(`https://price.jup.ag/v4/price?ids=${mints}`, {
              signal: controller.signal
            });
            clearTimeout(timeoutId);
    
            if (!response.ok) throw new Error(`Price API error: ${response.status}`);
            const data = await response.json();
    
            // Process results
            const movements = new Map();
            let marketVolatilitySum = 0;
            let volatileTokenCount = 0;
            
            for (const mint of uniqueTokens) {
              const tokenData = data.data[mint] || {};
              const priceChange = (tokenData.priceChange24h || 0) * 100;
              
              // Track market volatility (excluding stablecoins)
              if (!this.#isStablecoin(mint) && tokenData.price > 0) {
                marketVolatilitySum += Math.abs(priceChange);
                volatileTokenCount++;
              }
              
              movements.set(mint, {
                priceChange24h: priceChange,
                volume24h: tokenData.volume24h || 0,
                price: tokenData.price || 0
              });
            }
            
            // Calculate average market volatility
            const avgMarketVolatility = volatileTokenCount > 0 ? 
              marketVolatilitySum / volatileTokenCount : 0;
            
            // Store market volatility for reference
            this.#setStoredValue('marketVolatility', avgMarketVolatility.toString());
            
            return movements;
          } catch (error) {
            clearTimeout(timeoutId);
            throw error;
          }
        },
        async () => {
          // Fallback when circuit is open
          return this.#tokenMovements || new Map();
        }
      );
    } catch (e) {
      this.log(`Error fetching price movements: ${e.message}`, 'error');
      return this.#tokenMovements || new Map();
    }
  }
  
  /**
   * Find daily movers opportunities and execute trades
   * @returns {Promise<void>} 
   */
  async findDailyMoversOpportunities() {
    if (this.#isTradeInProgress) {
      this.log('Trade already in progress, skipping daily movers scan', 'debug');
      return;
    }
    
    this.#isTradeInProgress = true;
    
    try {
      this.log('Scanning for daily movers...');
      
      // Skip if daily loss limit hit
      if (this.#hasHitDailyLossLimit()) {
        this.log('Daily loss limit reached, skipping daily movers', 'warn');
        return;
      }
      
      // Calculate available capital
      const portfolioValue = this.#demoMode ? 
        await this.calculateDemoPortfolioValue() : 
        await this.calculatePortfolioValue();
      const dailyMoverCapital = portfolioValue * (this.#dailyMoversAllocation / 100);
      const tradeRiskAmount = dailyMoverCapital * (this.#maxRiskPercentage / 100);
      
      this.log(`Daily movers capital: $${dailyMoverCapital.toFixed(2)}, Trade risk: $${tradeRiskAmount.toFixed(2)}`);
      
      // Check SOL balance for fees
      const solBalance = await this.getTokenBalance(this.#tokenRegistry.SOL);
      if (solBalance < 0.01 && !this.#demoMode && !this.#simulationMode) {
        this.log(`Insufficient SOL for transaction fees: ${solBalance.toFixed(6)} SOL`, 'warn');
        return;
      }
      
      // Get token price movements
      const tokenMovements = await this.getTokenPriceMovements();
      if (!tokenMovements || tokenMovements.size === 0) {
        this.log('No price movement data available', 'warn');
        return;
      }
      
      // Store for reference
      this.#tokenMovements = tokenMovements;
      
      // Check market volatility and adjust threshold
      const marketVolatility = parseFloat(this.#getStoredValue('marketVolatility') || '0');
      let adjustedThreshold = this.#dailyMoverThreshold;
      
      if (marketVolatility > 12) {
        adjustedThreshold = this.#dailyMoverThreshold * 1.5;
        this.log(`Increased daily mover threshold to ${adjustedThreshold}% due to high market volatility`);
      }
      
      // Filter for significant movers
      const significantMovers = [...tokenMovements.entries()]
        .filter(([mint, data]) => {
          // Skip stablecoins
          if (this.#isStablecoin(mint)) return false;
          
          // Skip tokens with insufficient price data
          if (!data.price || data.price === 0) return false;
          
          // Check for significant movement and volume
          const significantMove = Math.abs(data.priceChange24h) >= adjustedThreshold;
          const sufficientVolume = data.volume24h > 50000; // $50k minimum volume
          
          return significantMove && sufficientVolume;
        })
        .sort((a, b) => Math.abs(b[1].priceChange24h) - Math.abs(a[1].priceChange24h));
      
      if (significantMovers.length === 0) {
        this.log('No significant daily movers found');
        return;
      }
      
      this.log(`Found ${significantMovers.length} significant daily movers`);
      
      // Send Discord notification with found movers
      if (significantMovers.length > 0) {
        let moversMessage = `📊 **DAILY MOVERS DETECTED**\n`;
        significantMovers.slice(0, 5).forEach(([mint, data], index) => {
          const symbol = this.#mintToSymbol(mint);
          const change = data.priceChange24h.toFixed(2);
          const direction = data.priceChange24h > 0 ? '📈' : '📉';
          moversMessage += `${index+1}. ${direction} **${symbol}**: ${change}% ($${(data.volume24h/1000).toFixed(0)}k vol)\n`;
        });
        
        if (significantMovers.length > 5) {
          moversMessage += `...and ${significantMovers.length - 5} more`;
        }
        
        await this.sendDiscordNotification(moversMessage, 'info');
      }
      
      // Process each significant mover
      for (const [mint, data] of significantMovers) {
        const symbol = this.#mintToSymbol(mint);
        this.log(`${symbol}: ${data.priceChange24h.toFixed(2)}% price change, $${data.volume24h.toFixed(0)} volume`);
        
        // Determine trade direction:
        // - Negative price change: BUY (price dropped, expect recovery)
        // - Positive price change: SELL (price jumped, take profit)
        const direction = data.priceChange24h <= -adjustedThreshold ? 'BUY' : 'SELL';
        
        await this.tradeDailyMover(
          direction === 'BUY' ? this.#tokenRegistry.USDC : mint,
          direction === 'BUY' ? mint : this.#tokenRegistry.USDC,
          data.priceChange24h,
          direction,
          tradeRiskAmount
        );
        
        // Wait a bit between trades
        await new Promise(resolve => setTimeout(resolve, 3000));
      }
    } catch (error) {
      this.log(`Error in daily movers strategy: ${error.message}`, 'error');
    } finally {
      this.#isTradeInProgress = false;
    }
  }
  
  /**
   * Execute trade for daily mover strategy
   * @param {string} fromMint From token mint
   * @param {string} toMint To token mint
   * @param {number} priceChange Price change percentage
   * @param {string} direction Trade direction (BUY/SELL)
   * @param {number} maxTradeSize Maximum trade size in USD
   * @returns {Promise<boolean>} Success or failure 
   */
  async tradeDailyMover(fromMint, toMint, priceChange, direction, maxTradeSize) {
    try {
      const fromSymbol = this.#mintToSymbol(fromMint);
      const toSymbol = this.#mintToSymbol(toMint);
      
      this.log(`Evaluating ${direction} opportunity for ${fromSymbol} → ${toSymbol} (${priceChange.toFixed(2)}% move)`);
      
      // Check balance
      const fromBalance = await this.getTokenBalance(fromMint);
      if (fromBalance <= 0) {
        this.log(`No balance for ${fromSymbol}, skipping trade`, 'warn');
        return false;
      }
      
      // Check for stop loss
      const fromPrice = await this.getTokenPrice(fromMint);
      const fromValueUsd = fromBalance * fromPrice;
      
      const stopLossCheck = await this.checkStopLoss(fromMint, fromValueUsd);
      if (stopLossCheck.triggered) {
        await this.executeStopLossExit(fromMint);
        return false;
      }
      
      // Calculate trade size
      const minViableAmount = this.#minimumViableAmounts[fromMint] || 0.001;
      const maxSafeAmount = fromBalance * 0.98;
      
      // Determine optimal trade size
      let tradeSize;
      if (direction === 'BUY') {
        // For buys, use a percentage of the max trade size to diversify risk
        const buyPercentage = Math.min(30 + Math.abs(priceChange), 70) / 100; // 30-70% based on price drop
        tradeSize = Math.min(maxTradeSize * buyPercentage / fromPrice, maxSafeAmount);
      } else {
        // For sells, use a higher percentage of available balance to lock in profits
        const sellPercentage = Math.min(50 + Math.abs(priceChange) / 2, 90) / 100; // 50-90% based on price jump
        tradeSize = Math.min(maxSafeAmount * sellPercentage, maxTradeSize / fromPrice);
      }
      
      // Ensure minimum viable amount
      tradeSize = Math.max(tradeSize, minViableAmount);
      
      if (tradeSize * fromPrice < 0.1) {
        this.log(`Trade value too small for ${fromSymbol}, skipping`, 'warn');
        return false;
      }
      
      // Get quote
      const quote = await this.getJupiterQuote(fromMint, toMint, tradeSize);
      if (!quote) {
        this.log(`Failed to get quote for ${fromSymbol} → ${toSymbol}`, 'warn');
        return false;
      }
      
      // Calculate output
      const toDecimals = await this.getTokenDecimals(toMint);
      const outAmount = parseFloat(quote.outAmount) / Math.pow(10, toDecimals);
      const toPrice = await this.getTokenPrice(toMint);
      
      // Determine if trade is favorable
      let shouldTrade = false;
      
      if (direction === 'BUY') {
        // For buys, check execution price vs expected
        const executionPriceChange = ((tradeSize * fromPrice / outAmount) - toPrice) / toPrice * 100;
        
        // Trade is favorable if execution price is within 3% of market price
        shouldTrade = Math.abs(executionPriceChange) < 3.0;
        
        // Additional check for severe price drops (>15%)
        if (priceChange < -15 && !this.#getStoredValue(`confirmed_drop_${toMint}`)) {
          // Only buy after confirming the drop in a second scan
          this.#setStoredValue(`confirmed_drop_${toMint}`, 'true');
          this.log(`Large price drop for ${toSymbol} (${priceChange.toFixed(2)}%), waiting for confirmation`, 'warn');
          shouldTrade = false;
        }
      } else {
        // For sells, always execute to lock in profits, unless execution price is terrible
        const executionPriceChange = (toPrice - (outAmount / tradeSize)) / toPrice * 100;
        shouldTrade = executionPriceChange < 5.0; // Allow up to 5% slippage for sells
      }
      
      if (shouldTrade) {
        this.log(`Executing ${direction} for ${fromSymbol} → ${toSymbol} (${priceChange.toFixed(2)}% move)`);
        return await this.executeTrade(fromMint, toMint, tradeSize, 'DAILY_MOVER');
      } else {
        this.log(`Skipping ${direction} for ${fromSymbol} → ${toSymbol} - unfavorable execution`, 'warn');
        return false;
      }
    } catch (error) {
      this.log(`Error in daily mover trade: ${error.message}`, 'error');
      return false;
    }
  }
  
  /**
   * Check if a token has hit its stop loss
   * @param {string} mint Token mint address
   * @param {number} currentValueUsd Current value in USD
   * @returns {Promise<{triggered: boolean, mint?: string, symbol?: string, dropPercentage?: number, highWaterMarkUsd?: number, currentValueUsd?: number}>} Stop loss status 
   */
  async checkStopLoss(mint, currentValueUsd) {
    try {
      const symbol = this.#mintToSymbol(mint);
      const stopLossKey = `stopLoss_${mint}`;

      // Get token-specific stop loss threshold
      const stopLossThreshold = this.#getTokenStopLossThreshold(mint);

      // Get the high-water mark for this token (if it exists)
      const highWaterMarkStr = this.#getStoredValue(stopLossKey);
      let highWaterMarkUsd = highWaterMarkStr ? parseFloat(highWaterMarkStr) : 0;

      // If current value is higher than high-water mark, update it
      if (currentValueUsd > highWaterMarkUsd) {
        highWaterMarkUsd = currentValueUsd;
        this.#setStoredValue(stopLossKey, highWaterMarkUsd.toString());
        return { triggered: false };
      }

      // Check if we're below stop loss threshold
      if (highWaterMarkUsd > 0) {
        const dropPercentage = (1 - (currentValueUsd / highWaterMarkUsd)) * 100;
        if (dropPercentage >= stopLossThreshold) {
          this.notify(`⚠️ STOP LOSS TRIGGERED for ${symbol}:`, 'alert');
          
          return { 
            triggered: true, 
            mint, 
            symbol,
            dropPercentage,
            highWaterMarkUsd,
            currentValueUsd,
            threshold: stopLossThreshold
          };
        }
      }

      return { triggered: false };
    } catch (error) {
      this.log(`Error in stop loss check for ${this.#mintToSymbol(mint)}: ${error.message}`, 'error');
      return { triggered: false };
    }
  }
  
  /**
   * Get token-specific stop loss threshold
   * @param {string} mint Token mint address
   * @returns {number} Stop loss percentage
   * @private
   */
  #getTokenStopLossThreshold(mint) {
    const baseStopLoss = this.#stopLossPercentage;
    const symbol = this.#mintToSymbol(mint);
    // Check both by mint and symbol
    const volatilityFactor = this.#tokenVolatility[mint] || this.#tokenVolatility[symbol] || 1.0;
    return baseStopLoss * volatilityFactor;
  }
  
  /**
   * Execute exit trade for stop loss
   * @param {string} mint Token mint address to exit
   * @returns {Promise<boolean>} Success or failure 
   */
  async executeStopLossExit(mint) {
    try {
      const symbol = this.#mintToSymbol(mint);
      this.log(`Executing stop loss exit for ${symbol}`);
      
      // Set stop loss mode flag for price impact override
      this.#inStopLossMode = true;

      // Get token balance
      const balance = await this.getTokenBalance(mint);
      const minViableAmount = this.#minimumViableAmounts[mint] || 0.001;
      
      if (balance <= minViableAmount) {
        this.log(`No significant balance for ${symbol}, skipping stop loss exit`, 'warn');
        this.#inStopLossMode = false;
        return false;
      }

      // Choose appropriate stable coin as destination
      const stableMint = this.#tokenRegistry.USDC;

      // Get exit quote - sell 98% of the balance (leave a bit for dust)
      const exitAmount = balance * 0.98;

      // Log the exit attempt
      this.log(`Stop loss exit: selling ${exitAmount.toFixed(6)} ${symbol} for USDC`);

      // Get quote for the exit trade
      const quote = await this.getJupiterQuote(mint, stableMint, exitAmount);
      if (!quote) {
        this.log(`Failed to get quote for stop loss exit of ${symbol}`, 'error');
        this.#inStopLossMode = false;
        return false;
      }

      // Ignore profit threshold for stop loss - execute at market price
      const result = await this.executeTrade(
        mint,
        stableMint,
        exitAmount,
        'STOP_LOSS'
      );

      if (result) {
        // Reset stop loss high-water mark after successful exit
        this.#setStoredValue(`stopLoss_${mint}`, "0");
        this.notify(`✅ Stop loss exit completed for ${symbol}`);
      } else {
        this.log(`Stop loss exit failed for ${symbol}`, 'error');
      }
      
      this.#inStopLossMode = false;
      return result;
    } catch (error) {
      this.log(`Error executing stop loss exit for ${this.#mintToSymbol(mint)}: ${error.message}`, 'error');
      this.#inStopLossMode = false;
      return false;
    }
  }
  
  /**
   * Scan the Solana chain for trading opportunities
   * @param {number} durationMs Minimum scan duration in milliseconds
   * @returns {Promise<Object>} Scan results
   */
  async scanChainForOpportunities(durationMs = 60000) {
    if (this.#tokenDiscoveryActive) {
      this.notify('Chain scan already in progress');
      return this.#scanResults;
    }
    
    this.#tokenDiscoveryActive = true;
    const startTime = Date.now();
    this.notify(`Starting Solana chain scan (minimum ${durationMs/1000} seconds)...`);
    
    try {
      // Discover tokens across Solana
      const tokens = await this.discoverSolanaTokens();
      this.notify(`Discovered ${tokens.length} tokens with sufficient liquidity`);
      
      // Get current price data for all tokens
      const pricedTokens = await this.getPriceDataForTokens(tokens);
      this.notify(`Retrieved price data for ${pricedTokens.length} tokens`);
      
      // Analyze tokens for trading signals
      let opportunities = await this.analyzeTokensForSignals(pricedTokens);
      
      // Ensure we scan for at least the minimum duration
      const elapsedMs = Date.now() - startTime;
      if (elapsedMs < durationMs) {
        this.notify(`Continuing scan for ${((durationMs - elapsedMs)/1000).toFixed(1)} more seconds...`);
        await new Promise(resolve => setTimeout(resolve, durationMs - elapsedMs));
        
        // Refresh data for potential opportunities to get latest prices
        if (opportunities.length > 0) {
          const topMints = opportunities.slice(0, 25).map(t => t.mint);
          const refreshedData = await this.getPriceDataForTokens(topMints);
          opportunities = await this.analyzeTokensForSignals(refreshedData);
        }
      }
      
      // Sort by score and categorize opportunities
      opportunities.sort((a, b) => b.score - a.score);
      
      // Group by strategy
      const buyOpportunities = opportunities.filter(o => o.signal === 'BUY').slice(0, 10);
      const sellOpportunities = opportunities.filter(o => o.signal === 'SELL').slice(0, 10);
      const arbitrageOpportunities = opportunities.filter(o => o.signal === 'ARBITRAGE').slice(0, 10);
      
      // Store scan results
      this.#scanResults = {
        scanTime: new Date(),
        duration: Date.now() - startTime,
        tokensScanned: pricedTokens.length,
        buyOpportunities,
        sellOpportunities,
        arbitrageOpportunities,
        allOpportunities: opportunities
      };
      
      this.notify(`Chain scan complete. Found ${buyOpportunities.length} buy signals, ${sellOpportunities.length} sell signals, and ${arbitrageOpportunities.length} arbitrage opportunities`);
      return this.#scanResults;
    } catch (error) {
      this.notify(`Error scanning chain: ${error.message}`, 'error');
      return null;
    } finally {
      this.#tokenDiscoveryActive = false;
    }
  }
  
  /**
   * Discover tokens across the Solana blockchain
   * @returns {Promise<Array>} List of discovered tokens
   */
  async discoverSolanaTokens() {
    try {
      this.notify('Discovering tokens across Solana...');
      
      // Use Helius API to get top tokens by market cap/volume
      const url = `https://api.helius.xyz/v0/tokens?api-key=${this.#heliusApiKey}`;
      
      const response = await fetch(url);
      if (!response.ok) throw new Error(`Helius API error: ${response.status}`);
      
      const data = await response.json();
      if (!Array.isArray(data)) throw new Error('Invalid response format');
      
      // Filter for tokens with sufficient liquidity and volume
      const viableTokens = data.filter(token => {
        const hasLiquidity = token.marketCap && token.marketCap > this.#minLiquidity;
        const hasVolume = token.volume24h && token.volume24h > this.#minVolume;
        return hasLiquidity && hasVolume;
      });
      
      // Get additional tokens from DEXs
      let dexTokens = [];
      try {
        // Get tokens from Jupiter to supplement the list
        const jupiterTokensUrl = 'https://token.jup.ag/all';
        const jupResponse = await fetch(jupiterTokensUrl);
        if (jupResponse.ok) {
          const jupTokens = await jupResponse.json();
          dexTokens = jupTokens.slice(0, 500); // Take top 500 tokens
        }
      } catch (error) {
        this.log(`Error fetching Jupiter tokens: ${error.message}`, 'warn');
      }
      
      // Combine and deduplicate tokens
      const allTokens = [...viableTokens];
      
      // Add tokens from DEXs that aren't already in the list
      for (const token of dexTokens) {
        if (!allTokens.some(t => t.address === token.address) && 
            token.address && token.symbol) {
          allTokens.push({
            address: token.address,
            symbol: token.symbol,
            name: token.name || token.symbol,
            decimals: token.decimals || 9
          });
        }
      }
      
      // Limit to maximum tokens to avoid overloading
      const limitedTokens = allTokens.slice(0, this.#maxScanTokens);
      
      // Cache these tokens for future reference
      limitedTokens.forEach(token => {
        this.#discoveredTokens.set(token.address, token);
      });
      
      return limitedTokens;
    } catch (error) {
      this.log(`Token discovery error: ${error.message}`, 'error');
      
      // Fallback to Jupiter tokens if Helius fails
      try {
        const jupiterTokensUrl = 'https://token.jup.ag/all';
        const response = await fetch(jupiterTokensUrl);
        if (!response.ok) throw new Error(`Jupiter API error: ${response.status}`);
        
        const tokens = await response.json();
        return tokens.slice(0, this.#maxScanTokens);
      } catch (fallbackError) {
        this.log(`Fallback token discovery failed: ${fallbackError.message}`, 'error');
        return [];
      }
    }
  }
  
  /**
   * Get price data for tokens
   * @param {Array} tokens List of tokens to fetch data for
   * @returns {Promise<Array>} Tokens with price data
   */
  async getPriceDataForTokens(tokens) {
    const batchSize = 75; // Process in batches to avoid API limits
    const results = [];
    
    // Process in batches
    for (let i = 0; i < tokens.length; i += batchSize) {
      const batch = tokens.slice(i, i + batchSize);
      this.log(`Fetching price data for tokens ${i+1}-${i+batch.length} of ${tokens.length}`, 'debug');
      
      try {
        // Convert tokens to mints array
        const mints = batch.map(t => typeof t === 'string' ? t : t.address);
        
        // Fetch price data for the batch
        const priceData = await this.#fetchBatchPriceData(mints);
        
        // Process results
        for (let j = 0; j < batch.length; j++) {
          const token = batch[j];
          const mint = typeof token === 'string' ? token : token.address;
          const data = priceData.get(mint);
          
          if (data) {
            results.push({
              mint,
              symbol: typeof token === 'string' ? this.#mintToSymbol(mint) : token.symbol,
              name: typeof token === 'string' ? this.#mintToSymbol(mint) : token.name || token.symbol,
              price: data.price || 0,
              priceChange24h: data.priceChange24h || 0,
              volume24h: data.volume24h || 0
            });
          }
        }
        
        // Add slight delay between batches
        if (i + batchSize < tokens.length) {
          await new Promise(resolve => setTimeout(resolve, 200));
        }
      } catch (error) {
        this.log(`Error fetching batch ${i}-${i+batchSize}: ${error.message}`, 'warn');
      }
    }
    
    return results;
  }
  
  /**
   * Fetch price data for a batch of token mints
   * @param {Array<string>} mints Array of token mint addresses
   * @returns {Promise<Map>} Map of mint address to price data
   * @private
   */
  async #fetchBatchPriceData(mints) {
    const results = new Map();
    
    try {
      // Convert mints array to comma-separated string
      const mintsStr = mints.join(',');
      
      // Fetch price data from Jupiter
      const response = await fetch(`https://price.jup.ag/v4/price?ids=${mintsStr}`);
      if (!response.ok) throw new Error(`Price API error: ${response.status}`);
      
      const data = await response.json();
      if (!data || !data.data) throw new Error('Invalid price data response');
      
      // Process each token
      for (const mint of mints) {
        if (data.data[mint]) {
          results.set(mint, {
            price: data.data[mint].price || 0,
            priceChange24h: (data.data[mint].priceChange24h || 0) * 100, // Convert to percentage
            volume24h: data.data[mint].volume24h || 0
          });
        }
      }
      
      return results;
    } catch (error) {
      this.log(`Batch price fetch error: ${error.message}`, 'error');
      return results; // Return whatever we managed to get
    }
  }
  
  /**
   * Analyze tokens for trading signals
   * @param {Array} tokens List of tokens with price data
   * @returns {Promise<Array>} Tokens with trading signals
   */
  async analyzeTokensForSignals(tokens) {
    this.notify(`Analyzing ${tokens.length} tokens for trading signals...`);
    const signals = [];
    
    // Check cross-DEX prices for some tokens to find arbitrage
    const arbitrageTokens = tokens.slice(0, 50); // Check top 50 tokens for arbitrage
    const arbitrageOpportunities = await this.checkForArbitrageOpportunities(arbitrageTokens);
    
    // Add arbitrage opportunities to signals
    arbitrageOpportunities.forEach(opp => signals.push(opp));
    
    // Analyze each token for buy/sell signals
    for (const token of tokens) {
      if (!token.price || token.price === 0) continue;
      
      // Skip stablecoins
      if (this.#isStablecoin(token.mint)) continue;
      
      let signal = null;
      let score = 0;
      let reason = '';
      
      // Analyze price movement
      const priceChange = token.priceChange24h;
      
      // BUY signals
      if (priceChange < -8 && priceChange > -30) {
        // Strong oversold condition - potential buy
        signal = 'BUY';
        
        // Score based on price drop and volume
        score = Math.min(100, Math.abs(priceChange) * 2); // Higher score for larger drops
        
        if (token.volume24h > 100000) score += 10; // Bonus for high volume
        if (token.volume24h > 1000000) score += 20;
        
        reason = `${priceChange.toFixed(2)}% price drop in 24h with $${Math.round(token.volume24h).toLocaleString()} volume`;
      }
      // SELL signals
      else if (priceChange > 15) {
        // Strong price increase - potential sell
        signal = 'SELL';
        
        // Score based on price increase
        score = Math.min(100, priceChange);
        
        // Adjust score based on volume
        if (token.volume24h > 50000) score += 10;
        
        reason = `${priceChange.toFixed(2)}% price increase in 24h with $${Math.round(token.volume24h).toLocaleString()} volume`;
      }
      
      // Add to signals if we found a signal
      if (signal) {
        signals.push({
          mint: token.mint,
          symbol: token.symbol,
          name: token.name,
          signal,
          score,
          price: token.price,
          priceChange24h: token.priceChange24h,
          volume24h: token.volume24h,
          reason
        });
      }
    }
    
    return signals;
  }
  
  /**
   * Check for arbitrage opportunities across DEXs
   * @param {Array} tokens List of tokens to check
   * @returns {Promise<Array>} Arbitrage opportunities
   * @private
   */
  async checkForArbitrageOpportunities(tokens) {
    const opportunities = [];
    
    if (this.#dexConnectors.size < 2) {
      await this.initializeDexConnectors();
    }
    
    for (const token of tokens) {
      try {
        const prices = [];
        
        // Get prices from all connected DEXs
        for (const [dexName, connector] of this.#dexConnectors.entries()) {
          try {
            const price = await connector.getPrice(token.mint);
            prices.push({ dex: dexName, price });
          } catch (error) {
            this.log(`Error getting ${token.symbol} price from ${dexName}: ${error.message}`, 'debug');
          }
        }
        
        if (prices.length < 2) continue;
        
        // Find best buy and sell prices
        prices.sort((a, b) => a.price - b.price);
        const cheapest = prices[0];
        const mostExpensive = prices[prices.length - 1];
        
        // Calculate profit potential
        const profitPercent = ((mostExpensive.price - cheapest.price) / cheapest.price) * 100;
        
        if (profitPercent > this.#minArbitrageProfit) {
          opportunities.push({
            mint: token.mint,
            symbol: token.symbol,
            name: token.name,
            signal: 'ARBITRAGE',
            score: profitPercent * 5, // Weight arbitrage opportunities higher
            price: token.price,
            buyDex: cheapest.dex,
            buyPrice: cheapest.price,
            sellDex: mostExpensive.dex,
            sellPrice: mostExpensive.price,
            profitPercent,
            reason: `${profitPercent.toFixed(2)}% arbitrage between ${cheapest.dex} and ${mostExpensive.dex}`
          });
        }
      } catch (error) {
        this.log(`Arbitrage check error for ${token.symbol}: ${error.message}`, 'debug');
      }
    }
    
    return opportunities;
  }
  
  /**
   * Save demo funds to storage
   */
  saveDemoFunds() {
    try {
      const demoData = {
        funds: this.#demoFunds,
        history: this.#demoTradeHistory,
        profitLoss: this.#demoProfitLoss,
        initialValue: this.#demoInitialValue,
        lastUpdated: new Date().toISOString()
      };
      
      this.#queueFileOperation(async () => {
        try {
          const demoStoragePath = path.join(this.#dataDir, 'demo_funds.json');
          const tempPath = `${demoStoragePath}.tmp`;
          await writeFileAsync(tempPath, JSON.stringify(demoData, null, 2));
          await renameAsync(tempPath, demoStoragePath);
        } catch (error) {
          this.log(`Error saving demo funds: ${error.message}`, 'error');
        }
      });
    } catch (error) {
      this.log(`Error saving demo funds: ${error.message}`, 'error');
    }
  }
  
  /**
   * Load demo funds from storage
   */
  loadDemoFunds() {
    try {
      const demoStoragePath = path.join(this.#dataDir, 'demo_funds.json');
      if (fs.existsSync(demoStoragePath)) {
        const data = JSON.parse(fs.readFileSync(demoStoragePath, 'utf8'));
        
        this.#demoFunds = data.funds || this.#demoFunds;
        this.#demoTradeHistory = data.history || [];
        this.#demoProfitLoss = data.profitLoss || 0;
        this.#demoInitialValue = data.initialValue || 0;
        
        this.log('Demo funds loaded from storage', 'debug');
      } else {
        this.log('No saved demo funds found, using defaults', 'debug');
      }
    } catch (error) {
      this.log(`Error loading demo funds: ${error.message}`, 'error');
    }
  }
  
  /**
   * Reset demo funds to default values
   */
  resetDemoFunds() {
    this.#demoFunds = {
      [this.#tokenRegistry.USDC]: 1000,
      [this.#tokenRegistry.SOL]: 3,
      [this.#tokenRegistry.BONK]: 50000000,
      [this.#tokenRegistry.MSOL]: 1,
      [this.#tokenRegistry.SAMO]: 1000,
      [this.#tokenRegistry.JUP]: 100
    };
    
    this.#demoTradeHistory = [];
    this.#demoProfitLoss = 0;
    this.#demoInitialValue = 0;
    
    this.calculateDemoPortfolioValue().then(value => {
      this.#demoInitialValue = value;
      this.notify(`Demo funds reset. New portfolio value: $${value.toFixed(2)}`);
      this.saveDemoFunds();
    });
  }
  
  /**
   * Enable or disable demo mode
   * @param {boolean} enabled Whether to enable demo mode
   */
  enableDemoMode(enabled = true) {
    this.#demoMode = enabled;
    
    if (enabled) {
      this.notify('Demo mode enabled - using virtual funds');
      this.loadDemoFunds();
      
      // Calculate initial portfolio value for P&L tracking
      if (this.#demoInitialValue === 0) {
        this.calculateDemoPortfolioValue().then(value => {
          this.#demoInitialValue = value;
          this.notify(`Initial demo portfolio value: $${this.#demoInitialValue.toFixed(2)}`);
        });
      }
    } else {
      this.notify('Demo mode disabled - using real balances');
    }
    
    return this.#demoMode;
  }
  
  /**
   * Load saved wallet configs
   * @returns {Object} Saved wallet configurations
   */
  loadSavedWallets() {
    try {
      const walletsFile = path.join(this.#dataDir, 'saved_wallets.json');
      if (fs.existsSync(walletsFile)) {
        this.#savedWallets = JSON.parse(fs.readFileSync(walletsFile, 'utf8'));
        this.log(`Loaded ${Object.keys(this.#savedWallets).length} saved wallet configurations`);
      }
      return this.#savedWallets;
    } catch (error) {
      this.log(`Error loading saved wallets: ${error.message}`, 'error');
      return {};
    }
  }
  
  /**
   * Get bot status
   * @returns {Object} Bot status info
   */
  getStatus() {
    return {
      isRunning: this.#isRunning,
      simulationMode: this.#simulationMode,
      demoMode: this.#demoMode,
      walletConnected: !!this.#wallet,
      walletAddress: this.#walletAddress,
      walletType: this.#walletType,
      currentBalanceUsd: this.#currentPortfolioValue,
      successfulTrades: this.#successfulTrades,
      failedTrades: this.#failedTrades,
      totalTrades: this.#successfulTrades + this.#failedTrades,
      profitLoss: this.#demoMode ? this.#demoProfitLoss : this.#totalProfitLoss
    };
  }
}

module.exports = RoninTradingBot;
