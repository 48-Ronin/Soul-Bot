      if (this.#rpcEndpoints.length > 1) {
        this.notify('Trying alternative RPC endpoint...', 'warn');
        const switched = await this.switchRpcEndpoint();
        if (!switched) {
          this.notify('Could not find a working RPC endpoint', 'error');
          return false;
        }
      } else {
        return false;
      }
    }
    
