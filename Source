  /**
   * Send a notification to Discord
   * @param {string} message Notification message
   * @param {string} level Notification level (info, warn, error, success)
   */
  async sendDiscordNotification(message, level = 'info') {
    try {
      if (this.#discordWebhooks.length === 0) return;
      
      // Determine color based on level
      let color;
      switch (level) {
        case 'error':
        case 'alert':
          color = 0xFF0000; // Red
          break;
        case 'warn':
          color = 0xFFAA00; // Orange
          break;
        case 'success':
          color = 0x00FF00; // Green
          break;
        default:
          color = 0x0099FF; // Blue
      }
      
      // Prepare embed
      const embed = {
        color: color,
        description: message,
        timestamp: new Date().toISOString()
      };
      
      // Add footer with bot info
      const mode = this.#simulationMode ? 'Simulation' : (this.#demoMode ? 'Demo' : 'Live');
      embed.footer = {
        text: `Ronin Bot (${mode}) | ${new Date().toLocaleString()}`
      };
      
      // Send to all webhooks
      for (const webhookUrl of this.#discordWebhooks) {
        try {
          const response = await fetch(webhookUrl, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              username: 'Ronin Trading Bot',
              avatar_url: 'https://i.imgur.com/8wPdoUe.png',
              embeds: [embed]
            })
          });
          
          if (!response.ok) {
            throw new Error(`Discord webhook error: ${response.status} ${response.statusText}`);
          }
        } catch (error) {
          console.error(`Discord webhook error: ${error.message}`);
        }
      }
    } catch (error) {
      console.error(`Error sending Discord notification: ${error.message}`);
    }
  }
  
