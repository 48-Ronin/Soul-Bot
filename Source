  /**
   * Load wallet from configuration
   * @param {Object} config Configuration object
   * @private
   */
  loadWallet(config) {
    try {
      let privateKeyData;
      if (config.privateKeyPath) {
        privateKeyData = fs.readFileSync(config.privateKeyPath, 'utf8').trim();
        // Handle different formats (hex, base58, JSON, etc.)
        if (privateKeyData.startsWith('[') && privateKeyData.endsWith(']')) {
          // Array format
          privateKeyData = JSON.parse(privateKeyData);
        } else if (privateKeyData.includes(',')) {
          // CSV format
          privateKeyData = privateKeyData.split(',').map(num => parseInt(num.trim()));
        }
      } else {
        privateKeyData = config.privateKey;
      }
      
      // Convert private key based on format
      if (typeof privateKeyData === 'string') {
        // Check if it's base58 format (Solana CLI default)
        if (privateKeyData.match(/^[A-HJ-NP-Za-km-z1-9]*$/)) {
          privateKeyData = bs58.decode(privateKeyData);
        } else {
          // Assume hex format
          privateKeyData = Buffer.from(privateKeyData, 'hex');
        }
      }

      this.#wallet = Keypair.fromSecretKey(
        Array.isArray(privateKeyData) ? Uint8Array.from(privateKeyData) : privateKeyData
      );
      
      this.#walletAddress = this.#wallet.publicKey.toString();
      this.log(`Wallet loaded: ${this.#walletAddress}`);
    } catch (error) {
      this.log(`Error loading wallet: ${error.message}`, 'error');
    }
  }
  
