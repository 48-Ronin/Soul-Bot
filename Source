  /**
   * Update demo balances after a trade
   * @param {string} fromMint From token mint
   * @param {string} toMint To token mint
   * @param {number} fromAmount Amount of from token
   * @param {number} toAmount Amount of to token
   * @param {string} strategy Trading strategy
   * @returns {Object} Trade details
   */
  async updateDemoBalancesForTrade(fromMint, toMint, fromAmount, toAmount, strategy) {
    // Get token symbols
    const fromSymbol = this.#mintToSymbol(fromMint);
    const toSymbol = this.#mintToSymbol(toMint);
    
    // Calculate USD values
    const fromPrice = await this.getTokenPrice(fromMint);
    const toPrice = await this.getTokenPrice(toMint);
    
    const fromValueUsd = fromAmount * fromPrice;
    const toValueUsd = toAmount * toPrice;
    
    // Calculate profit/loss
    const tradeProfitUsd = toValueUsd - fromValueUsd;
    
    // Update demo balances
    this.#demoFunds[fromMint] = (this.#demoFunds[fromMint] || 0) - fromAmount;
    if (this.#demoFunds[fromMint] < 0) this.#demoFunds[fromMint] = 0; // Prevent negative balances
    
    this.#demoFunds[toMint] = (this.#demoFunds[toMint] || 0) + toAmount;
    
    // Update P&L
    this.#demoProfitLoss += tradeProfitUsd;
    
    // Create trade record
    const trade = {
      timestamp: new Date().toISOString(),
      strategy,
      fromMint,
      fromSymbol,
      toMint,
      toSymbol,
      fromAmount,
      toAmount,
      fromValueUsd,
      toValueUsd,
      profitUsd: tradeProfitUsd,
      success: true
    };
    
    // Add to history
    this.#demoTradeHistory.push(trade);
    if (this.#demoTradeHistory.length > this.#maxTradeHistoryLength) {
      this.#demoTradeHistory = this.#demoTradeHistory.slice(-this.#maxTradeHistoryLength);
    }
    
    // Save updated demo funds
    this.saveDemoFunds();
    
    return trade;
  }
  
  /**
   * Get token prices for multiple tokens
   * @param {Array<string>} mints Array of token mint addresses
   * @returns {Promise<Map<string, number>>} Map of mint to price
   */
  async getTokenPrices(mints) {
    try {
      // Create a map to hold results
      const results = new Map();
      
      // First check cache for all tokens
      const now = Date.now();
      const uncachedMints = [];
      
      for (const mint of mints) {
        const cached = this.#tokenPriceCache.get(mint);
        if (cached && (now - cached.timestamp) < this.#priceCacheTTL) {
          results.set(mint, cached.price);
        } else if (this.#isStablecoin(mint)) {
          this.#tokenPriceCache.set(mint, { price: 1.0, timestamp: now });
          results.set(mint, 1.0);
        } else {
          uncachedMints.push(mint);
        }
      }
      
      // If all mints were cached, return early
      if (uncachedMints.length === 0) {
        return results;
      }
      
      // Create comma-separated list of mints
      const mintsList = uncachedMints.join(',');
      
      return await this.#jupiterQuoteCircuitBreaker.execute(
        async () => {
          const controller = new AbortController();
          const timeoutId = setTimeout(() => controller.abort(), 15000);
          
          try {
            const response = await fetch(`https://price.jup.ag/v4/price?ids=${mintsList}`, {
              signal: controller.signal
            });
            clearTimeout(timeoutId);
    
            if (!response.ok) throw new Error(`Price API error: ${response.status}`);
            const responseData = await response.json();
    
            // Process results
            for (const mint of uncachedMints) {
              const tokenData = responseData.data?.[mint] || {};
              const price = tokenData.price || 0;
              
              // Cache the response
              this.#tokenPriceCache.set(mint, {
                price,
                timestamp: now
              });
              
              // Add to results
              results.set(mint, price);
            }
            
            return results;
          } catch (error) {
            clearTimeout(timeoutId);
            throw error;
          }
        },
        async () => {
          // Fallback: provide fallback prices for known tokens, zeros for others
          for (const mint of uncachedMints) {
            const fallbackPrice = await this.#getTokenPriceFallback(mint);
            results.set(mint, fallbackPrice);
          }
          return results;
        }
      );
    } catch (e) {
      this.log(`Error fetching token prices: ${e.message}`, 'error');
      
      // Return whatever we have, falling back to individual price lookups
      for (const mint of mints) {
        if (!results.has(mint)) {
          try {
            const price = await this.getTokenPrice(mint);
            results.set(mint, price);
          } catch (err) {
            results.set(mint, 0);
          }
        }
      }
      
      return results;
    }
  }
  
  /**
   * Add trade to history
   * @param {Object} trade Trade details
   * @private 
   */
  #addTradeToHistory(trade) {
    // Add to in-memory history
    this.#tradeHistory.push(trade);

    // Limit history size
    if (this.#tradeHistory.length > this.#maxTradeHistoryLength) {
      this.#tradeHistory = this.#tradeHistory.slice(-this.#maxTradeHistoryLength);
    }

    // Queue trade storage to disk
    this.#queueFileOperation(async () => {
      try {
        const tradesFile = path.join(this.#dataDir, 'trades.json');
        await appendFileAsync(tradesFile, JSON.stringify(trade) + '\n');
      } catch (error) {
        this.log(`Error saving trade to history: ${error.message}`, 'error');
      }
    });

    // Update trade stats in storage
    this.#setStoredValue('totalTrades', (this.#successfulTrades + this.#failedTrades).toString());
    this.#setStoredValue('successfulTrades', this.#successfulTrades.toString());
    this.#setStoredValue('failedTrades', this.#failedTrades.toString());
    this.#setStoredValue('profitLoss', this.#totalProfitLoss.toString());
  }
  
  /**
   * Get trade history
   * @param {number} limit Maximum number of trades to return
   * @returns {Array} Trade history
