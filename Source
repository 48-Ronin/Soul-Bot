  /**
   * Generate a performance report
   * @returns {Promise<string>} Performance report
   */
  async generatePerformanceReport() {
    try {
      // Calculate current portfolio value
      const currentValue = this.#demoMode ? 
        await this.calculateDemoPortfolioValue() : 
        await this.calculatePortfolioValue();
      
      // Get initial investment
      const startingValue = this.#initialInvestment || currentValue;
      
      // Calculate overall performance
      const totalProfitLoss = this.#demoMode ? this.#demoProfitLoss : this.#totalProfitLoss;
      const totalProfitPercent = startingValue > 0 ? (totalProfitLoss / startingValue) * 100 : 0;
      
      // Calculate daily performance
      const dailyProfitPercent = this.#dailyStartBalance > 0 ? (this.#dailyPnL / this.#dailyStartBalance) * 100 : 0;
      
      // Get recent trades
      const recentTrades = this.getTradeHistory(5);
      
      // Build the report
      let report = `📊 **RONIN PERFORMANCE REPORT**\n\n`;
      
      // Summary section
      report += `**Summary**\n`;
      report += `+ Mode: ${this.#simulationMode ? 'Simulation' : (this.#demoMode ? 'Demo' : 'Live Trading')}\n`;
      report += `+ Current Portfolio: $${currentValue.toFixed(2)}\n`;
      report += `+ Total P&L: ${totalProfitLoss >= 0 ? '+' : ''}$${totalProfitLoss.toFixed(2)} (${totalProfitPercent >= 0 ? '+' : ''}${totalProfitPercent.toFixed(2)}%)\n`;
      report += `+ Daily P&L: ${this.#dailyPnL >= 0 ? '+' : ''}$${this.#dailyPnL.toFixed(2)} (${dailyProfitPercent >= 0 ? '+' : ''}${dailyProfitPercent.toFixed(2)}%)\n\n`;
      
      // Statistics section
      report += `**Trading Statistics**\n`;
      report += `+ Total Trades: ${this.#successfulTrades + this.#failedTrades}\n`;
      report += `+ Successful: ${this.#successfulTrades}\n`;
      report += `+ Failed: ${this.#failedTrades}\n`;
      report += `+ Success Rate: ${(this.#successfulTrades + this.#failedTrades) > 0 ? (this.#successfulTrades / (this.#successfulTrades + this.#failedTrades) * 100).toFixed(1) : 0}%\n\n`;
      
      // Recent trades section
      if (recentTrades.length > 0) {
        report += `**Recent Trades**\n`;
        recentTrades.forEach((trade, i) => {
          const date = new Date(trade.timestamp).toLocaleString();
          
          report += `${i+1}. ${date.split(',')[0]} - `;
          
          if (trade.fromSymbol && trade.toSymbol) {
            report += `${trade.fromAmount?.toFixed(4) || '?'} ${trade.fromSymbol} → ${trade.toAmount?.toFixed(4) || '?'} ${trade.toSymbol}`;
          } else {
            report += `${trade.amount?.toFixed(4) || '?'} ${trade.fromSymbol || '?'} → ${trade.toSymbol || '?'}`;
          }
          
          if (trade.profitUsd !== undefined) {
            report += ` (${trade.profitUsd >= 0 ? '+' : ''}$${trade.profitUsd.toFixed(2)})`;
          }
          
          report += ` [${trade.strategy || 'Unknown'}]\n`;
        });
      }
      
      return report;
    } catch (error) {
      console.error(`Error generating performance report: ${error.message}`);
      return `Error generating report: ${error.message}`;
    }
  }
  
  /**
   * Log a message with timestamp
   * @param {string} message The message to log
   * @param {string} level Log level (info, warn, error, debug)
   */
  log(message, level = 'info') {
    const timestamp = new Date().toISOString();
    const formattedMessage = `[${timestamp}] [${level.toUpperCase()}] ${message}`;
    console.log(formattedMessage);
    
    // Queue log write to avoid blocking
    this.#queueFileOperation(async () => {
      try {
        const logFile = path.join(this.#logsDir, `bot-${new Date().toISOString().split('T')[0]}.log`);
        await appendFileAsync(logFile, formattedMessage + '\n');
      } catch (e) {
        console.error('Failed to write to log file:', e);
      }
    });
  }
  
  /**
   * Notify all registered handlers
   * @param {string} message Message to send
   * @param {string} level Notification level
   */
  notify(message, level = 'info') {
    this.log(message, level);
    if (this.#notificationHandlers.length > 0) {
      this.#notificationHandlers.forEach(handler => {
        try {
          if (typeof handler === 'function') {
            handler(message, level);
          }
        } catch (error) {
          console.error('Error in notification handler:', error);
        }
      });
    }
  }
  
  /**
   * Queue a file operation to avoid concurrent writes
   * @param {Function} operation Async operation to queue
   * @private
   */
  #queueFileOperation(operation) {
    this.#writeQueue.push(operation);
    
    // Start processing the queue if not already processing
    if (!this.#isProcessingQueue) {
      this.#processWriteQueue();
    }
  }
  
  /**
   * Process the file operation queue
   * @private
   */
  async #processWriteQueue() {
    if (this.#isProcessingQueue || this.#writeQueue.length === 0) {
      return;
    }
    
    this.#isProcessingQueue = true;
    
    try {
      while (this.#writeQueue.length > 0) {
        const operation = this.#writeQueue.shift();
        await operation();
      }
    } catch (error) {
      console.error('Error processing write queue:', error.message);
    } finally {
      this.#isProcessingQueue = false;
    }
  }
  
  /**
   * Get stored value from persistent storage
   * @param {string} key Storage key
   * @returns {string|null} Stored value or null
   * @private 
   */
  #getStoredValue(key) {
    try {
      const storageFile = path.join(this.#dataDir, 'storage.json');
      if (!fs.existsSync(storageFile)) {
        return null;
      }
      const data = JSON.parse(fs.readFileSync(storageFile, 'utf8'));
      return data[key] || null;
    } catch (error) {
      this.log(`Error reading from storage: ${error.message}`, 'error');
      return null;
    }
  }
  
  /**
   * Store value in persistent storage
   * @param {string} key Storage key
   * @param {string} value Value to store
   * @private 
   */
  #setStoredValue(key, value) {
    this.#queueFileOperation(async () => {
      try {
        const storageFile = path.join(this.#dataDir, 'storage.json');
        let data = {};
        
        if (fs.existsSync(storageFile)) {
          try {
            data = JSON.parse(fs.readFileSync(storageFile, 'utf8'));
          } catch (e) {
            this.log(`Error parsing storage file, creating new one: ${e.message}`, 'warn');
            data = {};
          }
        }
        
        data[key] = value;
        
        // Write atomically using temporary file
        const tempFile = `${storageFile}.tmp`;
        await writeFileAsync(tempFile, JSON.stringify(data, null, 2));
        await renameAsync(tempFile, storageFile);
      } catch (error) {
        this.log(`Error writing to storage: ${error.message}`, 'error');
      }
    });
  }
  
  /**
   * Store transaction details
   * @param {string} signature Transaction signature
   * @param {Object} details Transaction details
   * @private
   */
  #storeTransactionDetails(signature, details) {
    this.#queueFileOperation(async () => {
      try {
        const filePath = path.join(this.#transactionsDir, `${signature}.json`);
        const tempFilePath = `${filePath}.tmp`;
        await writeFileAsync(tempFilePath, JSON.stringify(details, null, 2));
        await renameAsync(tempFilePath, filePath);
      } catch (error) {
        this.log(`Error storing transaction details: ${error.message}`, 'error');
      }
    });
  }
  
  /**
   * Start the trading bot
   */
  async start() {
    if (this.#isRunning) {
      this.log('Bot is already running', 'warn');
      return false;
    }
    
    try {
      this.#isRunning = true;
      this.notify('Starting Ronin trading bot...');
      
      // Check if wallet is connected
      if (!this.#wallet && !this.#demoMode) {
        this.notify('No wallet connected. Please connect a wallet or enable demo mode.', 'warn');
        this.#isRunning = false;
        return false;
      }
      
      // Perform diagnostics to ensure everything is working
      if (!await this.runDiagnostics()) {
        this.#isRunning = false;
        return false;
      }
      
      // Get initial balance for drawdown protection
      this.#initialInvestment = this.#demoMode ? 
        await this.calculateDemoPortfolioValue() : 
        await this.calculatePortfolioValue();
      
      // Track daily balance
      await this.trackDailyBalance();
      
      this.notify(`Initial portfolio value: $${this.#initialInvestment.toFixed(2)}`);
      
      // Send initial status message to Discord
      await this.sendStatusMessage();
      
      // Set up daily report scheduler
      this.setupDailyReport();
      
      // Run the trading loop
      this.runTradingLoop();
      
      return true;
    } catch (error) {
      this.#isRunning = false;
      this.notify(`Error starting bot: ${error.message}`, 'error');
      return false;
    }
  }
  
  /**
   * Stop the trading bot
   */
  stop() {
    if (!this.#isRunning) {
      this.log('Bot is not running', 'warn');
      return false;
    }
    
    this.#isRunning = false;
    this.notify('Stopping bot...');
    
    // Save final stats
    const saveStats = async () => {
      try {
        const currentValue = this.#demoMode ? 
          await this.calculateDemoPortfolioValue() : 
          await this.calculatePortfolioValue();
        
        this.#setStoredValue('lastKnownBalance', currentValue.toString());
        
        // Calculate uptime
        const startTimeStr = this.#getStoredValue('startTime');
        const startTime = startTimeStr ? parseInt(startTimeStr) : Date.now();
        const uptime = (Date.now() - startTime) / 1000;
        const hours = Math.floor(uptime / 3600);
        const minutes = Math.floor((uptime % 3600) / 60);
        
        // Send final status
        await this.sendDiscordNotification(
          `🛑 **BOT STOPPED**\n` +
          `+ Final Balance: $${currentValue.toFixed(2)}\n` +
          `+ Uptime: ${hours}h ${minutes}m\n` +
          `+ Trades: ${this.#successfulTrades + this.#failedTrades} (${this.#successfulTrades} successful)\n` +
          `+ P&L: ${this.#demoMode ? this.#demoProfitLoss : this.#totalProfitLoss >= 0 ? '+' : ''}$${(this.#demoMode ? this.#demoProfitLoss : this.#totalProfitLoss).toFixed(2)}`,
          'info'
        );
      } catch (error) {
        this.log(`Error saving final stats: ${error.message}`, 'error');
      }
    };
    
    saveStats();
    
    return true;
  }
  
  /**
   * Run diagnostics to ensure everything is working properly
   */
  async runDiagnostics() {
    this.notify('Running diagnostics...');
    
    // Test RPC connection
    try {
      const version = await this.#connection.getVersion();
      this.notify(`RPC connection successful. Solana version: ${version['solana-core']}`);
