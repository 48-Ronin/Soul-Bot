  /**
   * Execute a trade from one token to another
   * @param {string} fromMint Source token mint address
   * @param {string} toMint Target token mint address
   * @param {number} amount Amount to trade
   * @param {string} strategy Trading strategy
   * @returns {boolean} Success or failure
   */
  async executeTrade(fromMint, toMint, amount, strategy) {
    try {
      const fromSymbol = Object.keys(this.tokenRegistry).find(key => this.tokenRegistry[key] === fromMint) || 'Unknown';
      const toSymbol = Object.keys(this.tokenRegistry).find(key => this.tokenRegistry[key] === toMint) || 'Unknown';
      
      this.notify(`Preparing to trade ${amount.toFixed(6)} ${fromSymbol} to ${toSymbol}`);
      
      // Validate minimum viable amount
      const fromPrice = await this.getTokenPrice(fromMint);
      const valueUsd = amount * fromPrice;
      
      if (valueUsd < 0.1) {
        this.notify(`Trade value too small: $${valueUsd.toFixed(4)} < $0.10`, 'warn');
        return false;
      }
      
      // Check if we have sufficient balance
      const balance = await this.getTokenBalance(fromMint);
      if (balance < amount) {
        this.notify(`Insufficient balance: ${balance.toFixed(6)} ${fromSymbol} < ${amount.toFixed(6)} ${fromSymbol}`, 'warn');
        return false;
      }
      
      // Adjust amount to account for fees
      const adjustedAmount = amount * 0.99; // Leave 1% for fees
      
      // In demo mode, simulate the trade
      if (this.demoMode) {
        // Get quote to determine expected output
        const quote = await this.getJupiterQuote(fromMint, toMint, adjustedAmount);
        if (!quote) {
          this.notify(`Failed to get Jupiter quote for ${fromSymbol} → ${toSymbol}`, 'error');
          return false;
        }
        
        // Calculate expected output
        const outputDecimals = await this.getTokenDecimals(toMint);
        const expectedOutput = parseFloat(quote.outAmount) / Math.pow(10, outputDecimals);
        
        this.notify(`[DEMO] Trading ${adjustedAmount.toFixed(6)} ${fromSymbol} → ${expectedOutput.toFixed(6)} ${toSymbol}`);
        
        // Update demo balances
        const trade = await this.updateDemoBalancesForTrade(
          fromMint, 
          toMint, 
          adjustedAmount, 
          expectedOutput, 
          strategy
        );
        
        this.notify(`[DEMO] Trade executed: ${adjustedAmount.toFixed(6)} ${fromSymbol} → ${expectedOutput.toFixed(6)} ${toSymbol} (${trade.profitUsd >= 0 ? '+' : ''}$${trade.profitUsd.toFixed(2)})`);
        
        return true;
      }
      
      // In simulation mode, just log the trade
      if (this.simulationMode) {
        this.notify(`[SIMULATION] Would trade ${adjustedAmount.toFixed(6)} ${fromSymbol} to ${toSymbol}`);
        this.successfulTrades++;
        return true;
      }
      
      // Check if wallet is read-only
      if (this.walletType === 'readOnly') {
        this.notify('Cannot execute trade in read-only mode', 'error');
        return false;
      }
      
      // Ensure token accounts exist
      await this.ensureTokenAccount(fromMint);
      await this.ensureTokenAccount(toMint);
      
      // Get Jupiter quote with retries
      const quote = await this.retryWithBackoff(async () => {
        return await this.getJupiterQuote(fromMint, toMint, adjustedAmount);
      }, 3);
      
      if (!quote) {
        this.notify(`Failed to get Jupiter quote for ${fromSymbol} → ${toSymbol}`, 'error');
        this.failedTrades++;
        return false;
      }
      
      // Calculate expected output
      const outputDecimals = await this.getTokenDecimals(toMint);
      const expectedOutput = parseFloat(quote.outAmount) / Math.pow(10, outputDecimals);
      
      this.notify(`Quote received: ${adjustedAmount.toFixed(6)} ${fromSymbol} → ${expectedOutput.toFixed(6)} ${toSymbol}`);
      
      // Calculate adaptive slippage based on token volatility
      let slippageBps = 50; // Default 0.5%
      const tokenSpecificSlippage = this.tokenSlippage[fromSymbol] || this.tokenSlippage[toSymbol];
      if (tokenSpecificSlippage) {
        slippageBps = tokenSpecificSlippage * 100; // Convert percentage to basis points
      }
      
      // Create and sign transaction
      const transaction = await this.createSwapTransaction(quote, slippageBps);
      if (!transaction) {
        this.notify(`Failed to create swap transaction`, 'error');
        this.failedTrades++;
        return false;
      }
      
      // Send and confirm transaction with retries
      this.notify('Sending transaction to network...');
      const signature = await this.retryWithBackoff(async () => {
        return await this.sendAndConfirmTransaction(transaction);
      }, 3);
      
      if (!signature) {
        this.notify(`Transaction failed to confirm`, 'error');
        this.failedTrades++;
        return false;
      }
      
      this.notify(`Transaction confirmed! Signature: ${signature}`);
      this.notify(`Successfully traded ${adjustedAmount.toFixed(6)} ${fromSymbol} for approximately ${expectedOutput.toFixed(6)} ${toSymbol}`);
      
      // Add to successful trades count
      this.successfulTrades++;
      
      // Record in trade history
      this.tradeHistory.push({
        timestamp: new Date().toISOString(),
        strategy,
        fromMint,
        fromSymbol,
        toMint,
        toSymbol,
        amount: adjustedAmount,
        expectedOutput,
        signature,
        success: true
      });
      
      return true;
    } catch (error) {
      this.notify(`Trade execution failed: ${error.message}`, 'error');
      this.failedTrades++;
      
      // Record failed trade
      this.tradeHistory.push({
        timestamp: new Date().toISOString(),
        strategy,
        fromMint,
        toMint,
        amount,
        success: false,
        error: error.message
      });
      
      return false;
    }
  }
  
  /**
   * Get token balance
   * @param {string} mint Token mint address
   * @returns {Promise<number>} Token balance
   */
  async getTokenBalance(mint) {
    // If in demo mode, return demo balance
    if (this.demoMode) {
      return this.demoFunds[mint] || 0;
    }
    
    try {
      if (mint === this.tokenRegistry.SOL) {
        const balance = await this.connection.getBalance(this.wallet.publicKey);
        return balance / 1e9; // Convert lamports to SOL
      }
      
      const tokenAccount = await getAssociatedTokenAddressSync(
        new PublicKey(mint),
        this.wallet.publicKey,
        false,
        TOKEN_PROGRAM_ID
      );
      
      try {
        const info = await this.connection.getTokenAccountBalance(tokenAccount);
        return parseFloat(info.value.amount) / Math.pow(10, info.value.decimals);
      } catch (e) {
        if (e.message.includes('Account not found') || e.message.includes('could not find account')) {
          return 0; // Handle non-existent ATA
        }
        throw e;
      }
    } catch (error) {
      this.log(`Error getting balance for ${mint}: ${error.message}`, 'error');
      return 0;
    }
  }
  
  /**
   * Get token decimals
   * @param {string} mint Token mint address
   * @returns {Promise<number>} Token decimals
   */
  async getTokenDecimals(mint) {
    // Check cache first
    if (this.tokenDecimalCache.has(mint)) {
      return this.tokenDecimalCache.get(mint);
    }
    
    // Special case for SOL
    if (mint === this.tokenRegistry.SOL) {
      this.tokenDecimalCache.set(mint, 9);
      return 9;
    }
    
    try {
      // Get token metadata from Solana
      const info = await this.connection.getParsedAccountInfo(new PublicKey(mint));
      
      if (info && info.value && info.value.data && 'parsed' in info.value.data) {
        const parsedData = info.value.data.parsed;
        if (parsedData && parsedData.info && parsedData.info.decimals) {
          const decimals = parsedData.info.decimals;
          this.tokenDecimalCache.set(mint, decimals);
          return decimals;
        }
      }
      
      // Fallbacks for common tokens
      const commonDecimals = {
        [this.tokenRegistry.USDC]: 6,
        [this.tokenRegistry.USDT]: 6,
        [this.tokenRegistry.BONK]: 5,
        [this.tokenRegistry.MSOL]: 9,
        [this.tokenRegistry.SAMO]: 9,
        [this.tokenRegistry.JUP]: 6,
      };
      
      if (commonDecimals[mint]) {
        this.tokenDecimalCache.set(mint, commonDecimals[mint]);
        return commonDecimals[mint];
      }
      
      // Default to 9 decimals if we can't determine
      this.log(`Could not determine decimals for ${mint}, using default of 9`, 'warn');
      this.tokenDecimalCache.set(mint, 9);
      return 9;
    } catch (error) {
      this.log(`Error getting token decimals for ${mint}: ${error.message}`, 'error');
      this.tokenDecimalCache.set(mint, 9);
      return 9;
    }
  }
  
