      this.tokenRegistry.USDT,
      // Add other stablecoins
      'EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v', // USDC
      'Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB', // USDT
      'DUKGuU2eXG4GqRGHk6unZYnNtZNn6d5x5HJU7NMYxLWj'  // USDD
    ];
    
    return stablecoins.includes(mint);
  }
  
  /**
   * Get symbol for a token mint address
   * @param {string} mint Token mint address
   * @returns {string} Symbol for the token
   */
  mintToSymbol(mint) {
    const cachedToken = this.discoveredTokens.get(mint);
    if (cachedToken) return cachedToken.symbol;
    
    // Check registry
    for (const [symbol, address] of Object.entries(this.tokenRegistry)) {
      if (address === mint) return symbol;
    }
    
    // Return shortened address if not found
    return mint.slice(0, 4) + '...' + mint.slice(-4);
  }
  
