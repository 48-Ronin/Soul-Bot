  /**
   * Save demo funds to storage
   */
  saveDemoFunds() {
    try {
      const demoData = {
        funds: this.demoFunds,
        history: this.demoTradeHistory,
        profitLoss: this.demoProfitLoss,
        initialValue: this.demoInitialValue,
        lastUpdated: new Date().toISOString()
      };
      
      const demoStoragePath = path.join(this.dataDir, 'demo_funds.json');
      fs.writeFileSync(demoStoragePath, JSON.stringify(demoData, null, 2));
      this.log('Demo funds saved', 'debug');
    } catch (error) {
      this.log(`Error saving demo funds: ${error.message}`, 'error');
    }
  }
  
  /**
   * Load demo funds from storage
   */
  loadDemoFunds() {
    try {
      const demoStoragePath = path.join(this.dataDir, 'demo_funds.json');
      if (fs.existsSync(demoStoragePath)) {
        const data = JSON.parse(fs.readFileSync(demoStoragePath, 'utf8'));
        
        this.demoFunds = data.funds || this.demoFunds;
        this.demoTradeHistory = data.history || [];
        this.demoProfitLoss = data.profitLoss || 0;
        this.demoInitialValue = data.initialValue || 0;
        
        this.log('Demo funds loaded from storage', 'debug');
      } else {
        this.log('No saved demo funds found, using defaults', 'debug');
      }
    } catch (error) {
      this.log(`Error loading demo funds: ${error.message}`, 'error');
    }
  }
  
  /**
   * Reset demo funds to default values
   */
  resetDemoFunds() {
    this.demoFunds = {
      [this.tokenRegistry.USDC]: 1000,
      [this.tokenRegistry.SOL]: 3,
      [this.tokenRegistry.BONK]: 50000000,
      [this.tokenRegistry.MSOL]: 1,
      [this.tokenRegistry.SAMO]: 1000,
      [this.tokenRegistry.JUP]: 100
    };
    
    this.demoTradeHistory = [];
    this.demoProfitLoss = 0;
    this.demoInitialValue = 0;
    
    this.calculateDemoPortfolioValue().then(value => {
      this.demoInitialValue = value;
      this.notify(`Demo funds reset. New portfolio value: $${value.toFixed(2)}`);
      this.saveDemoFunds();
    });
  }
  
  /**
   * Enable or disable demo mode
   * @param {boolean} enabled Whether to enable demo mode
   */
  enableDemoMode(enabled = true) {
    this.demoMode = enabled;
    
    if (enabled) {
      this.notify('Demo mode enabled - using virtual funds');
      this.loadDemoFunds();
      
      // Calculate initial portfolio value for P&L tracking
      if (this.demoInitialValue === 0) {
        this.calculateDemoPortfolioValue().then(value => {
          this.demoInitialValue = value;
          this.notify(`Initial demo portfolio value: $${this.demoInitialValue.toFixed(2)}`);
        });
      }
    } else {
      this.notify('Demo mode disabled - using real balances');
    }
    
    return this.demoMode;
  }
  
  /**
   * Check if demo mode is enabled
   * @returns {boolean} Whether demo mode is enabled
   */
  isDemoMode() {
    return this.demoMode;
  }
  
  /**
   * Set custom demo fund balance for a token
   * @param {string} token Token symbol or mint
   * @param {number} amount Amount to set
   */
  setDemoBalance(token, amount) {
    // Handle symbol or mint address
    let mint = token;
    if (this.tokenRegistry[token.toUpperCase()]) {
      mint = this.tokenRegistry[token.toUpperCase()];
    }
    
    if (!mint) {
      throw new Error(`Unknown token: ${token}`);
    }
    
    this.demoFunds[mint] = amount;
    this.notify(`Set demo balance for ${token}: ${amount}`);
    this.saveDemoFunds();
  }
  
  /**
   * Connect using a private key file
   * @param {string} keyPath Path to private key file
   * @returns {boolean} Success status
   */
  connectWithKeyFile(keyPath) {
    try {
      if (!fs.existsSync(keyPath)) {
        throw new Error(`Key file not found: ${keyPath}`);
      }
      
      const privateKeyData = fs.readFileSync(keyPath, 'utf8').trim();
      return this.connectWithPrivateKey(privateKeyData);
    } catch (error) {
      this.notify(`Error connecting with key file: ${error.message}`, 'error');
      return false;
    }
  }
  
  /**
   * Connect with raw private key
   * @param {string|array} privateKeyData Private key data
   * @returns {boolean} Success status
   */
  connectWithPrivateKey(privateKeyData) {
    try {
      // Handle different formats (hex, base58, JSON, etc.)
      if (typeof privateKeyData === 'string') {
        if (privateKeyData.startsWith('[') && privateKeyData.endsWith(']')) {
          // Array format
          privateKeyData = JSON.parse(privateKeyData);
        } else if (privateKeyData.includes(',')) {
          // CSV format
          privateKeyData = privateKeyData.split(',').map(num => parseInt(num.trim()));
        }
        
        // Convert string to proper format
        if (privateKeyData.match(/^[A-HJ-NP-Za-km-z1-9]*$/)) {
          // Base58 format (Solana CLI default)
          privateKeyData = bs58.decode(privateKeyData);
        } else if (privateKeyData.length === 64 || privateKeyData.length === 128) {
          // Hex format
          privateKeyData = Buffer.from(privateKeyData, 'hex');
        }
      }
      
      // Create keypair
      const keypair = Array.isArray(privateKeyData) || Buffer.isBuffer(privateKeyData)
        ? Keypair.fromSecretKey(
            Array.isArray(privateKeyData) ? Uint8Array.from(privateKeyData) : privateKeyData
          )
        : null;
      
      if (!keypair) {
        throw new Error('Invalid private key format');
      }
      
      this.wallet = keypair;
      this.walletType = 'privateKey';
      this.walletAddress = keypair.publicKey.toString();
      
      this.notify(`Connected with wallet: ${this.walletAddress}`);
      return true;
    } catch (error) {
      this.notify(`Error connecting with private key: ${error.message}`, 'error');
      return false;
    }
  }
  
  /**
   * Connect in read-only mode (view-only, no trading)
   * @param {string} publicKey Wallet public key
   * @returns {boolean} Success status
   */
  connectReadOnly(publicKey) {
    try {
      // Validate public key
      const pubKey = new PublicKey(publicKey);
      
      this.walletAddress = pubKey.toString();
      this.walletType = 'readOnly';
      
      // Create a dummy wallet with only public key access
      this.wallet = {
        publicKey: pubKey,
        // Override signing methods to prevent trades
        signTransaction: () => {
          throw new Error('Cannot sign transactions in read-only mode');
        },
        signAllTransactions: () => {
          throw new Error('Cannot sign transactions in read-only mode');
        }
      };
      
      this.notify(`Connected in read-only mode with address: ${this.walletAddress}`);
      this.notify('WARNING: Trading functions are disabled in read-only mode', 'warn');
      
      return true;
    } catch (error) {
      this.notify(`Error connecting in read-only mode: ${error.message}`, 'error');
      return false;
    }
  }
  
  /**
   * Save wallet config for future use
   * @param {string} name Wallet name/label
   */
  saveWalletConfig(name) {
    if (!this.walletAddress) {
      this.notify('No wallet connected', 'error');
      return false;
    }
    
    try {
      const walletData = {
        address: this.walletAddress,
        type: this.walletType,
        lastUsed: new Date().toISOString()
      };
      
      // Store wallet config (but never private keys)
      this.savedWallets[name] = walletData;
      
      // Save to file
      const walletsFile = path.join(this.dataDir, 'saved_wallets.json');
      fs.writeFileSync(walletsFile, JSON.stringify(this.savedWallets, null, 2));
      
      this.notify(`Wallet configuration saved as "${name}"`);
      return true;
    } catch (error) {
      this.notify(`Error saving wallet config: ${error.message}`, 'error');
      return false;
    }
  }
  
  /**
   * Load saved wallet configs
   * @returns {Object} Saved wallet configurations
   */
  loadSavedWallets() {
    try {
      const walletsFile = path.join(this.dataDir, 'saved_wallets.json');
      if (fs.existsSync(walletsFile)) {
        this.savedWallets = JSON.parse(fs.readFileSync(walletsFile, 'utf8'));
        this.log(`Loaded ${Object.keys(this.savedWallets).length} saved wallet configurations`);
      }
      return this.savedWallets;
    } catch (error) {
      this.log(`Error loading saved wallets: ${error.message}`, 'error');
      return {};
    }
  }
  
  /**
   * Get current wallet info
   * @returns {Object} Wallet information
   */
  getWalletInfo() {
    if (!this.walletAddress) {
      return { connected: false };
    }
    
    return {
      connected: true,
      address: this.walletAddress,
      type: this.walletType,
      readOnly: this.walletType === 'readOnly'
    };
  }
  
  /**
   * Disconnect current wallet
   */
  disconnectWallet() {
    this.wallet = null;
    this.walletAddress = null;
    this.walletType = null;
    this.notify('Wallet disconnected');
    return true;
  }
  
  /**
   * Get bot status
   * @returns {Object} Bot status info
   */
  getStatus() {
    return {
      isRunning: this.isRunning,
      simulationMode: this.simulationMode,
      demoMode: this.demoMode,
      walletConnected: !!this.wallet,
      walletAddress: this.walletAddress,
      walletType: this.walletType,
      currentBalanceUsd: this.currentPortfolioValue,
      successfulTrades: this.successfulTrades,
      failedTrades: this.failedTrades,
      totalTrades: this.successfulTrades + this.failedTrades,
      profitLoss: this.demoMode ? this.demoProfitLoss : this.totalProfitLoss
    };
  }
  
  /**
   * Get trade history
   * @param {number} limit Maximum number of trades to return
   * @returns {Array} Trade history
   */
  getTradeHistory(limit = 20) {
    if (this.demoMode) {
      return this.demoTradeHistory.slice(-limit);
    }
    return this.tradeHistory.slice(-limit);
  }
  
  /**
   * Get token registry
   * @returns {Object} Token registry
   */
  getTokenRegistry() {
    return this.tokenRegistry;
  }
  
  /**
   * Check if simulation mode is enabled
   * @returns {boolean} Is simulation mode
   */
  isSimulationMode() {
    return this.simulationMode;
  }
  
  /**
   * Toggle simulation mode
   * @returns {boolean} New simulation mode state
   */
  toggleSimulationMode() {
    this.simulationMode = !this.simulationMode;
    this.notify(`Simulation mode ${this.simulationMode ? 'enabled' : 'disabled'}`);
    return this.simulationMode;
  }
  
  /**
   * Check if bot is running
   * @returns {boolean} Is running
   */
  isRunning() {
    return this.isRunning;
  }
}

module.exports = RoninTradingBot;
