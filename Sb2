  /**
   * Find and execute swing trading opportunities
   */
  async findAndExecuteSwingOpportunities() {
    if (this.isTradeInProgress) {
      this.log('Trade already in progress, skipping opportunity search', 'debug');
      return;
    }
    
    this.isTradeInProgress = true;
    
    try {
      this.notify('Searching for swing trading opportunities...');
      
      // Get token price movements
      const priceData = await this.getTokenPriceMovements();
      if (!priceData || priceData.size === 0) {
        this.notify('No price data available', 'warn');
        return;
      }
      
      // Find opportunities based on price data
      const opportunities = this.identifySwingOpportunities(priceData);
      
      if (opportunities.length === 0) {
        this.notify('No swing trading opportunities found');
        return;
      }
      
      // Get total portfolio value
      const portfolioValue = this.demoMode ? 
        await this.calculateDemoPortfolioValue() : 
        await this.calculatePortfolioValue();
      
      // Calculate maximum risk amount (15% of portfolio)
      const maxRiskAmount = portfolioValue * (this.maxRiskPercentage / 100);
      
      // Take the best opportunity
      const bestOpportunity = opportunities[0];
      this.notify(`Best opportunity: ${bestOpportunity.type} ${bestOpportunity.symbol} (${bestOpportunity.score.toFixed(2)} score)`);
      
      // Execute the trade
      if (bestOpportunity.type === 'BUY') {
        // Calculate position size
        const targetToken = bestOpportunity.symbol;
        const targetMint = this.tokenRegistry[targetToken];
        const fromMint = this.tokenRegistry.USDC;
        
        // Calculate trade size (in USDC)
        const tradeSize = Math.min(maxRiskAmount, bestOpportunity.maxSize || maxRiskAmount);
        
        this.notify(`Executing ${bestOpportunity.type} for ${targetToken} with size $${tradeSize.toFixed(2)}`);
        await this.executeTrade(fromMint, targetMint, tradeSize, 'SWING');
      } else if (bestOpportunity.type === 'SELL') {
        // For sell, we need to calculate how much of the token to sell
        const sourceToken = bestOpportunity.symbol;
        const fromMint = this.tokenRegistry[sourceToken];
        const toMint = this.tokenRegistry.USDC;
        
        // Get token balance
        const tokenBalance = await this.getTokenBalance(fromMint);
        const tokenPrice = await this.getTokenPrice(fromMint);
        const tokenValue = tokenBalance * tokenPrice;
        
        // Check if we have enough to sell
        if (tokenBalance > 0 && tokenValue > 1.0) {
          // Sell 70% of the position
          const sellAmount = tokenBalance * 0.7;
          
          this.notify(`Executing ${bestOpportunity.type} for ${sourceToken} with size ${sellAmount.toFixed(6)} tokens`);
          await this.executeTrade(fromMint, toMint, sellAmount, 'SWING');
        } else {
          this.notify(`Not enough ${sourceToken} to sell`, 'warn');
        }
      }
    } catch (error) {
      this.notify(`Error finding swing opportunities: ${error.message}`, 'error');
    } finally {
      this.isTradeInProgress = false;
    }
  }
  
  /**
   * Identify swing trading opportunities from price data
   * @param {Map} priceData Map of token price data
   * @returns {Array} Sorted list of opportunities
   */
  identifySwingOpportunities(priceData) {
    const opportunities = [];
    
    // Process each token
    for (const [mint, data] of priceData.entries()) {
      // Find symbol for the mint
      const symbol = Object.keys(this.tokenRegistry).find(key => this.tokenRegistry[key] === mint);
      if (!symbol) continue;
      
      // Skip stablecoins for buying
      if (symbol === 'USDC' || symbol === 'USDT') continue;
      
      const priceChange24h = data.priceChange24h || 0;
      const volume24h = data.volume24h || 0;
      
      // Minimum requirements
      if (volume24h < 10000) continue; // Skip low volume tokens
      
      // Calculate opportunity score
      let score = 0;
      let type = '';
      let maxSize = 0;
      
      // BUY signals - price dropped but fundamentals remain strong
      if (priceChange24h < -5 && priceChange24h > -20) {
        // Higher score for optimal price drops (-8% to -15%)
        score = Math.abs(priceChange24h);
        
        // Bonus for higher volume
        if (volume24h > 100000) score += 5;
        if (volume24h > 1000000) score += 10;
        
        type = 'BUY';
        // Limit position size based on price drop severity
        maxSize = 100 * (1 - Math.abs(priceChange24h) / 100);
      }
      
      // SELL signals - price pumped significantly
      if (priceChange24h > 10) {
        // Score based on price increase
        score = priceChange24h / 2;
        
        // Higher score for substantial but not excessive pumps
        if (priceChange24h > 20) score += 5;
        if (priceChange24h > 30) score += 5;
        
        // Lower score for extreme pumps (likely to correct)
        if (priceChange24h > 50) score -= 10;
        
        type = 'SELL';
      }
      
      // Add valid opportunities to the list
      if (score > 0 && type) {
        opportunities.push({
          mint,
          symbol,
          type,
          score,
          priceChange24h,
          volume24h,
          maxSize
        });
      }
    }
    
    // Sort by score (highest first)
    return opportunities.sort((a, b) => b.score - a.score);
  }
  
  /**
   * Market Making Strategy
   * Continuously place and update buy/sell orders to profit from spread
   */
  async runMarketMakingStrategy() {
    if (this.marketMakingActive) {
      this.log('Market making already running', 'debug');
      return;
    }
    
    this.marketMakingActive = true;
    this.notify('Starting market making strategy');
    
    try {
      // Select tokens to market make
      const tokens = ['SOL', 'BONK', 'JUP'];
      
      // Get current balances and prices
      const balances = {};
      const prices = {};
      
      for (const token of tokens) {
        const mint = this.tokenRegistry[token];
        balances[token] = await this.getTokenBalance(mint);
        prices[token] = await this.getTokenPrice(mint);
      }
      
      // Get USDC balance (for buys)
      const usdcBalance = await this.getTokenBalance(this.tokenRegistry.USDC);
      
      this.notify(`Market making for: ${tokens.join(', ')}`);
      
      // For each token, place buy and sell orders
      for (const token of tokens) {
        const mint = this.tokenRegistry[token];
        const currentPrice = prices[token];
        const tokenBalance = balances[token];
        
        // Calculate buy and sell prices based on spread
        const buyPrice = currentPrice * (1 - this.spreadPercentage / 100);
        const sellPrice = currentPrice * (1 + this.spreadPercentage / 100);
        
        this.log(`${token} - Current: $${currentPrice}, Buy: $${buyPrice}, Sell: $${sellPrice}`, 'debug');
        
        // Allocate funds for market making (15% of available balance)
        const maxUsdcForBuy = usdcBalance * 0.15;
        const buySize = maxUsdcForBuy / buyPrice;
        
        // For sell, use 15% of token balance
        const sellSize = tokenBalance * 0.15;
        
        if (this.demoMode || this.simulationMode) {
          this.notify(`[SIMULATION] Market making ${token} - Buy: ${buySize.toFixed(6)} @ $${buyPrice.toFixed(6)}, Sell: ${sellSize.toFixed(6)} @ $${sellPrice.toFixed(6)}`);
        } else {
          // Place limit buy order (would need exchange-specific implementation)
          this.log(`Would place buy order: ${buySize.toFixed(6)} ${token} @ $${buyPrice.toFixed(6)}`, 'debug');
          
          // Place limit sell order
          this.log(`Would place sell order: ${sellSize.toFixed(6)} ${token} @ $${sellPrice.toFixed(6)}`, 'debug');
        }
      }
    } catch (error) {
      this.notify(`Market making error: ${error.message}`, 'error');
