      const token1Balance = await this.getTokenBalance(token1Mint);
      const token2Balance = await this.getTokenBalance(token2Mint);
      
      // Calculate amounts to add (15% of balance)
      const token1Amount = token1Balance * 0.15;
      const token2Amount = token2Balance * 0.15;
      
      this.notify(`[DEMO] Adding ${token1Amount.toFixed(6)} ${token1Symbol} and ${token2Amount.toFixed(6)} ${token2Symbol} to ${opportunity.dex} liquidity pool`);
      
      // Track the position
      this.liquidityPositions.push({
        pair: opportunity.name,
        dex: opportunity.dex,
        token1: token1Symbol, 
        token2: token2Symbol,
        token1Amount,
        token2Amount,
        apy: opportunity.apy,
        startTime: new Date(),
        id: `lp-${Date.now()}`
      });
      
