    if (this.liquidityPositions.length === 0) {
      this.log('No active liquidity positions', 'debug');
      return;
    }
    
    this.notify(`Checking rewards for ${this.liquidityPositions.length} liquidity positions`);
    
    for (const position of this.liquidityPositions) {
      try {
        // Calculate time in pool
        const now = new Date();
        const durationMs = now - new Date(position.startTime);
        const durationDays = durationMs / (1000 * 60 * 60 * 24);
        
        // Simulate fees earned based on APY
        const annualRate = position.apy / 100;
        const dailyRate = annualRate / 365;
        
        // Calculate token values
        const token1Mint = this.tokenRegistry[position.token1];
        const token2Mint = this.tokenRegistry[position.token2];
        const token1Price = await this.getTokenPrice(token1Mint);
        const token2Price = await this.getTokenPrice(token2Mint);
        
        const initialValueUsd = (position.token1Amount * token1Price) + (position.token2Amount * token2Price);
        const feesEarnedUsd = initialValueUsd * dailyRate * durationDays;
        
        this.notify(`Liquidity position ${position.pair} on ${position.dex} - Fees earned: $${feesEarnedUsd.toFixed(2)} (${durationDays.toFixed(1)} days)`);
        
        // In demo mode, add the rewards to USDC balance
        if (this.demoMode && feesEarnedUsd > 0.01) {
          this.demoFunds[this.tokenRegistry.USDC] += feesEarnedUsd;
          this.saveDemoFunds();
        }
      } catch (error) {
        this.log(`Error processing liquidity position ${position.pair}: ${error.message}`, 'error');
      }
    }
  }
  
