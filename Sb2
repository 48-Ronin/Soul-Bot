  /**
   * Update demo balances after a trade
   * @param {string} fromMint From token mint
   * @param {string} toMint To token mint
   * @param {number} fromAmount Amount of from token
   * @param {number} toAmount Amount of to token
   * @param {string} strategy Trading strategy
   * @returns {Object} Trade details
   */
  async updateDemoBalancesForTrade(fromMint, toMint, fromAmount, toAmount, strategy) {
    // Get token symbols
    const fromSymbol = Object.keys(this.tokenRegistry).find(key => this.tokenRegistry[key] === fromMint) || 'Unknown';
    const toSymbol = Object.keys(this.tokenRegistry).find(key => this.tokenRegistry[key] === toMint) || 'Unknown';
    
    // Calculate USD values
    const fromPrice = await this.getTokenPrice(fromMint);
    const toPrice = await this.getTokenPrice(toMint);
    
    const fromValueUsd = fromAmount * fromPrice;
    const toValueUsd = toAmount * toPrice;
    
    // Calculate profit/loss
    const tradeProfitUsd = toValueUsd - fromValueUsd;
    
    // Update demo balances
    this.demoFunds[fromMint] = (this.demoFunds[fromMint] || 0) - fromAmount;
    if (this.demoFunds[fromMint] < 0) this.demoFunds[fromMint] = 0; // Prevent negative balances
    
    this.demoFunds[toMint] = (this.demoFunds[toMint] || 0) + toAmount;
    
    // Update P&L
    this.demoProfitLoss += tradeProfitUsd;
    
    // Create trade record
    const trade = {
      timestamp: new Date().toISOString(),
      strategy,
      fromMint,
      fromSymbol,
      toMint,
      toSymbol,
      fromAmount,
      toAmount,
      fromValueUsd,
      toValueUsd,
      profitUsd: tradeProfitUsd,
      success: true
    };
    
    // Add to history
    this.demoTradeHistory.push(trade);
    if (this.demoTradeHistory.length > 100) {
      this.demoTradeHistory = this.demoTradeHistory.slice(-100); // Keep only last 100 trades
    }
    
    // Save updated demo funds
    this.saveDemoFunds();
    
    return trade;
  }
  
  /**
   * Get token price
   * @param {string} mint Token mint address
   * @returns {Promise<number>} Token price in USD
   */
  async getTokenPrice(mint) {
    try {
      // Check cache first
      const cached = this.tokenPriceCache.get(mint);
      const now = Date.now();
      if (cached && (now - cached.timestamp) < this.priceCacheTTL) {
        return cached.price;
      }
      
      // Special case for stablecoins
      if (mint === this.tokenRegistry.USDC || mint === this.tokenRegistry.USDT) {
        this.tokenPriceCache.set(mint, { price: 1.0, timestamp: now });
        return 1.0;
      }
      
      // Get price from Jupiter API
      const response = await fetch(`https://price.jup.ag/v4/price?ids=${mint}`);
      if (!response.ok) throw new Error(`Price API error: ${response.status}`);
      const data = await response.json();
      
      if (data && data.data && data.data[mint] && data.data[mint].price) {
        const price = data.data[mint].price;
        this.tokenPriceCache.set(mint, { price, timestamp: now });
        return price;
      }
      
      throw new Error('Invalid price data format');
    } catch (error) {
      this.log(`Error fetching token price for ${mint}: ${error.message}`, 'error');
      
      // Fallbacks for common tokens
      const fallbackPrices = {
        [this.tokenRegistry.SOL]: 150,
        [this.tokenRegistry.BONK]: 0.00001,
        [this.tokenRegistry.SAMO]: 0.02,
        [this.tokenRegistry.MSOL]: 155,
        [this.tokenRegistry.JUP]: 0.5,
      };
      
      if (fallbackPrices[mint]) {
        this.log(`Using fallback price for ${mint}: $${fallbackPrices[mint]}`, 'warn');
        this.tokenPriceCache.set(mint, {
          price: fallbackPrices[mint],
          timestamp: Date.now() - (this.priceCacheTTL / 2) // Shorter cache time for fallbacks
        });
        return fallbackPrices[mint];
      }
      
      return 0.00001; // Default fallback price
    }
  }
  
  /**
