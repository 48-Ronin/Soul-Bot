  /**
   * Send Discord notification using webhook
   * @param {string} message Message content
   * @param {string} level Message level (info, warn, error, alert)
   * @returns {Promise<void>}
   */
  async sendDiscordNotification(message, level = 'info') {
    try {
      // Skip if we're in simulation mode and this isn't an error/alert
      if (this.#simulationMode && !['error', 'alert'].includes(level)) {
        message = `[SIMULATION] ${message}`;
      }
      
      // Find Discord webhook handlers
      const discordHandlers = this.#notificationHandlers.filter(h => 
        h.isDiscord || (typeof h === 'object' && h.type === 'discord')
      );
      
      if (discordHandlers.length === 0) {
        return;
      }
      
      // Send to all Discord handlers
      for (const handler of discordHandlers) {
        try {
          if (typeof handler === 'function') {
            await handler(message, level);
          } else if (handler && typeof handler.send === 'function') {
            await handler.send(message, level);
          }
        } catch (e) {
          this.log(`Error sending Discord notification: ${e.message}`, 'error');
        }
      }
    } catch (error) {
      this.log(`Error building Discord notification: ${error.message}`, 'error');
    }
  }

  /**
   * Send daily summary to Discord
   * @returns {Promise<void>} 
   */
  async sendDailySummary() {
    try {
      // Calculate daily stats
      const balance = await this.calculatePortfolioValue();
      const dailyPnLPercent = this.#dailyStartBalance > 0 ? (this.#dailyPnL / this.#dailyStartBalance * 100) : 0;
      
      // Get today's trades
      const today = new Date().toISOString().split('T')[0];
      const todayTrades = this.#tradeHistory.filter(
        trade => trade.timestamp.startsWith(today) && (trade.status === 'success' || trade.status === 'simulated')
      );
      
      // Calculate success rate
      const todayTotal = todayTrades.length;
      const todaySuccessful = todayTrades.filter(t => t.status === 'success' || t.status === 'simulated' ).length;
      const successRate = todayTotal > 0 ? (todaySuccessful / todayTotal) * 100 : 0;
      
      // Calculate profits by strategy
      const strategyProfits = {};
      todayTrades.forEach(trade => {
        if (!strategyProfits[trade.strategy]) {
          strategyProfits[trade.strategy] = { trades: 0, profit: 0 };
        }
        strategyProfits[trade.strategy].trades++;
        strategyProfits[trade.strategy].profit += trade.profit || 0;
      });
      
      // Find best performing pair
      const pairProfits = {};
      todayTrades.forEach(trade => {
        if (!trade.input || !trade.output) return;
        const pair = `${trade.input.symbol}-${trade.output.symbol}`;
        if (!pairProfits[pair]) {
          pairProfits[pair] = 0;
        }
        pairProfits[pair] += trade.profit || 0;
      });
      
      let bestPair = null;
      let bestProfit = -Infinity;
      for (const [pair, profit] of Object.entries(pairProfits)) {
        if (profit > bestProfit) {
          bestPair = pair;
          bestProfit = profit;
        }
      }
      
      // Build the message
      let message = `📊 **DAILY TRADING SUMMARY**\n\n`;
      message += `+ **Date:** ${new Date().toLocaleDateString()}\n`;
      message += `+ **Total Trades:** ${todayTotal}\n`;
      message += `+ **Success Rate:** ${successRate.toFixed(1)}%\n`;
      message += `+ **Daily P&L:** ${this.#dailyPnL > 0 ? '+' : ''}$${this.#dailyPnL.toFixed(4)} (${dailyPnLPercent.toFixed(2)}%)\n\n`;
      message += `+ **Current Balance:** $${balance.toFixed(2)}\n`;
      
      // Add strategy breakdown
      if (Object.keys(strategyProfits).length > 0) {
        message += `\n**Strategy Breakdown:**\n`;
        for (const [strategy, data] of Object.entries(strategyProfits)) {
          message += `- ${strategy}: ${data.trades} trades, ${data.profit > 0 ? '+' : ''}$${data.profit.toFixed(4)}\n`;
        }
      }
      
      // Add best pair
      if (bestPair && bestProfit > 0) {
        message += `\n**Best Performing Pair:** ${bestPair} (${bestProfit > 0 ? '+' : ''}$${bestProfit.toFixed(4)})\n`;
      }
      
      // Add performance stats
      const allTimeProfit = this.#profitLoss;
      const percentGain = this.#startingBalanceUsd > 0 ? 
        ((balance - this.#startingBalanceUsd) / this.#startingBalanceUsd * 100) : 0;
      
      message += `\n**Overall Performance:**\n`;
      message += `- All-time P&L: ${allTimeProfit > 0 ? '+' : ''}$${allTimeProfit.toFixed(2)}\n`;
      message += `- Starting Balance: $${this.#startingBalanceUsd.toFixed(2)}\n`;
      message += `- Total Gain: ${percentGain > 0 ? '+' : ''}${percentGain.toFixed(2)}%\n`;
      
      await this.sendDiscordNotification(message, 'info');
    } catch (error) {
      this.log(`Error building Discord summary: ${error.message}`, 'error');
    }
  }

  /**
   * Run a full trading cycle
   * @returns {Promise<void>}
   * @private 
   */
  async #runTradingCycle() {
    // Skip if already running
    if (this.#isCycleRunning) {
      this.log('Trading cycle already in progress, skipping', 'debug');
      return;
    }

    this.#isCycleRunning = true;

    try {
      this.log('--- Starting Trading Cycle ---');
      
      // Check RPC health
      const rpcHealthy = await this.checkRpcHealth();
      if (!rpcHealthy) {
        this.log('RPC endpoint unhealthy, trying alternative', 'warn');
        await this.#switchRpcEndpoint();
      }
      
      // Track daily balance
      await this.trackDailyBalance();
      
      // Check daily loss limit
      if (this.#hasHitDailyLossLimit()) {
        this.log('Daily loss limit reached, skipping trading cycle', 'warn');
        return;
      }
      
      // Check SOL balance for transaction fees
      const solBalance = await this.getTokenBalance(this.#tokenRegistry.SOL);
      const minimumSolRequired = 0.01; // 0.01 SOL for transaction fees
      
      if (solBalance < minimumSolRequired) {
        this.notify(`⚠️ Insufficient SOL for transaction fees: ${solBalance.toFixed(6)} SOL. Need at least ${minimumSolRequired} SOL`, 'alert');
        return;
      }
      
      // Run strategies
      await this.findArbitrageOpportunities();
      await this.findDailyMoversOpportunities();
      
    } catch (error) {
      this.log(`Error in trading cycle: ${error.message}`, 'error');
      
      // Send Discord alert for critical errors
      if (error.message.includes('connection') || 
          error.message.includes('timeout') || 
          error.message.includes('network')) {
        await this.sendDiscordNotification(
          `⚠️ **TRADING CYCLE ERROR**\n${error.message}`,
          'error'
        );
      }
    } finally {
      this.#isCycleRunning = false;
      this.log('--- Trading Cycle Completed ---');
    }
  }

  /**
   * Check RPC connection health
   * @returns {Promise<boolean>} True if healthy 
   */
  async checkRpcHealth() {
    const MAX_RESPONSE_TIME = 5000; // 5 seconds
    
    try {
      const startTime = Date.now();
      
      // Use a race with timeout to avoid hanging
      const result = await Promise.race([
        this.#connection.getVersion(),
        new Promise((_, reject) => 
          setTimeout(() => reject(new Error('RPC Timeout')), MAX_RESPONSE_TIME)
        )
      ]);
      
      const endTime = Date.now();
      const responseTime = endTime - startTime;
      
      if (responseTime > 2000) {
        this.log(`RPC endpoint responding slowly: ${responseTime}ms`, 'warn');
        // Still functional but degraded
        return true;
      }
      
      return true;
    } catch (error) {
      this.log(`RPC health check failed: ${error.message}`, 'error');
      return false;
    }
  }

  /**
   * Start the trading bot
   * @returns {Promise<void>} 
   */
  async start() {
    if (this.#isRunning) {
      this.log('Bot is already running', 'warn');
      return;
    }

    try {
      this.#isRunning = true;
      this.log('Starting Solana trading bot...');
      
      // Initialize connection pool if not already done
      if (this.#connectionPool.length === 0) {
        await this.#initializeConnectionPool();
      }
      
      // Load trade history
      try {
        const tradesFile = path.join(this.#dataDir, 'trades.json');
        if (fs.existsSync(tradesFile)) {
          const content = fs.readFileSync(tradesFile, 'utf8');
          if (content) {
            const lines = content.split('\n').filter(line => line.trim());
            const trades = lines.map(line => {
              try {
                return JSON.parse(line);
              } catch (e) {
                return null;
              }
            }).filter(Boolean);
            
            this.#tradeHistory = trades.slice(-this.#maxTradeHistoryLength);
            this.log(`Loaded ${this.#tradeHistory.length} historical trades`);
          }
        }
      } catch (e) {
        this.log(`Error loading trade history: ${e.message}`, 'warn');
      }
      
      // Load daily balances
      try {
        const dailyBalancesStr = this.#getStoredValue('dailyBalances');
        if (dailyBalancesStr) {
          this.#dailyBalances = JSON.parse(dailyBalancesStr);
          this.log(`Loaded ${this.#dailyBalances.length} daily balance records`);
        }
      } catch (e) {
        this.log(`Error loading daily balances: ${e.message}`, 'warn');
      }
      
      // Load trade statistics
      this.#totalTrades = parseInt(this.#getStoredValue('totalTrades') || '0');
      this.#successfulTrades = parseInt(this.#getStoredValue('successfulTrades') || '0');
      this.#failedTrades = parseInt(this.#getStoredValue('failedTrades') || '0');
      this.#profitLoss = parseFloat(this.#getStoredValue('profitLoss') || '0');
      
      this.log(`Loaded trade statistics: ${this.#successfulTrades} successful, ${this.#failedTrades} failed, ${this.#profitLoss.toFixed(2)} P&L`);
      
      // Calculate starting balance
      this.#startingBalanceUsd = await this.calculatePortfolioValue();
      this.log(`Initial portfolio value: $${this.#startingBalanceUsd.toFixed(2)}`);
      
      // Send initial status to Discord
      await this.sendDiscordStatusMessage();
      
      // Run first cycle immediately
      await this.#runTradingCycle();
      
      // Set up intervals with jittered timing to avoid predictable patterns
      const baseInterval = 5 * 60 * 1000; // 5 minutes base
      const setupInterval = () => {
        const jitter = Math.random() * 60 * 1000; // Up to 1 minute jitter
        const interval = baseInterval + jitter;
        
        this.#runIntervalId = setTimeout(async () => {
          await this.#runTradingCycle();
          // Re-setup with new jitter each time
          if (this.#isRunning) {
            setupInterval();
          }
        }, interval);
        
        this.log(`Next trading cycle scheduled in ${(interval/60000).toFixed(1)} minutes`, 'debug');
      };
      
      setupInterval();
      
      // Set up daily summary (at midnight)
      this.#setupDailySummary();
      
      const modeText = this.#simulationMode ? 'SIMULATION' : 'LIVE TRADING';
      this.notify(`Bot started in ${modeText} mode`);
      
      // Send startup notification to Discord
      await this.sendDiscordNotification(
        `🚀 **BOT STARTED**\nMode: ${modeText}\nWallet: ${this.#wallet.publicKey.toString()}\nBalance: $${this.#startingBalanceUsd.toFixed(2)}`,
        'info'
      );
    } catch (error) {
      this.#isRunning = false;
      this.log(`Error starting bot: ${error.message}`, 'error');
      
      // Clean up interval if there was an error
      if (this.#runIntervalId) {
        clearTimeout(this.#runIntervalId);
        this.#runIntervalId = null;
      }
      
      // Send Discord alert for startup failure
      try {
        await this.sendDiscordNotification(
          `❌ **BOT STARTUP FAILED**\nError: ${error.message}`,
          'error'
        );
      } catch (e) {
        // Ignore notification errors on startup failure
      }
      
      throw error;
    }
  }

  /**
   * Set up daily summary scheduler
   * @private 
   */
  #setupDailySummary() {
    // Check every hour if it's time for daily summary
    const checkDailySummary = async () => {
      const now = new Date();
      
      // Send summary at midnight (00:00-00:05)
      if (now.getHours() === 0 && now.getMinutes() < 5) {
        await this.sendDailySummary();
      }
      
      // Reschedule if bot is still running
      if (this.#isRunning) {
        setTimeout(checkDailySummary, 60 * 60 * 1000); // Check every hour
      }
    };
    
    // Start the check cycle
    setTimeout(checkDailySummary, 60 * 60 * 1000);
  }

  /**
   * Send status message to Discord
   * @returns {Promise<void>} 
   */
  async sendDiscordStatusMessage() {
    try {
      const balance = await this.calculatePortfolioValue();
      const walletAddress = this.#wallet.publicKey.toString();
      const explorerUrl = `https://solscan.io/account/${walletAddress}`;
      
      const message = `🤖 **RONIN BOT STATUS**\n\n` +
                      `+ **Mode:** ${this.#simulationMode ? 'Simulation' : 'Live Trading'}\n` +
                      `+ **Balance:** $${balance.toFixed(2)}\n` +
                      `+ **Wallet:** [${walletAddress.slice(0, 6)}...${walletAddress.slice(-6)}](${explorerUrl})\n` +
                      `+ **Total Trades:** ${this.#totalTrades}\n` +
                      `+ **Success Rate:** ${this.#totalTrades > 0 ? (this.#successfulTrades / this.#totalTrades * 100).toFixed(1) : 0}%\n` +
                      `+ **P&L:** ${this.#profitLoss > 0 ? '+' : ''}$${this.#profitLoss.toFixed(2)}\n\n` +
                      `+ **Strategy Allocation:**\n` +
                      `+ - Arbitrage: ${this.#arbitrageAllocation}%\n` +
                      `+ - Daily Movers: ${this.#dailyMoversAllocation}%\n` +
                      `+ **Risk Settings:**\n` +
                      `+ - Risk per trade: ${this.#riskPercentage}%\n` +
                      `+ - Min profit threshold: ${this.#minProfitThreshold}%\n` +
                      `+ - Stop loss: ${this.#stopLossPercentage}%\n` +
                      `+ - Daily loss limit: ${this.#dailyLossLimit}%\n\n` +
                      `+ **Trading pairs:** ${this.#tradingPairs.join(', ')}`;
      
      await this.sendDiscordNotification(message, 'info');
    } catch (error) {
      this.log(`Error building Discord status: ${error.message}`, 'error');
    }
  }

  /**
   * Stop the trading bot
   * @returns {Promise<void>} 
   */
  async stop() {
    if (!this.#isRunning) {
      this.log('Bot is not running', 'warn');
      return;
    }

    this.log('Stopping bot...');

    // Clear interval
    if (this.#runIntervalId) {
      clearTimeout(this.#runIntervalId);
      this.#runIntervalId = null;
    }

    this.#isRunning = false;

    // Store current state
    try {
      const balance = await this.calculatePortfolioValue();
      this.#setStoredValue('lastKnownBalance', balance.toString());
      this.#setStoredValue('profitLoss', this.#profitLoss.toString());
      
      // Calculate uptime
      const uptime = (Date.now() - parseInt(this.#getStoredValue('startTime') || Date.now().toString())) / 1000;
      const hours = Math.floor(uptime / 3600);
      const minutes = Math.floor((uptime % 3600) / 60);
      
      // Send status update to Discord
      await this.sendDiscordNotification(
        `🛑 **BOT STOPPED**\n` +
        `+ Final Balance: $${balance.toFixed(2)}\n` +
        `+ Uptime: ${hours}h ${minutes}m\n` +
        `+ Trades: ${this.#totalTrades} (${this.#successfulTrades} successful)\n` +
        `+ P&L: ${this.#profitLoss >= 0 ? '+' : ''}$${this.#profitLoss.toFixed(2)}`,
        'info'
      );
    } catch (e) {
      this.log(`Error sending stop notification: ${e.message}`, 'error');
    }

    this.notify('Bot stopped');
  }

  /**
   * Add a Discord webhook for notifications
   * @param {string} webhookUrl Discord webhook URL 
   */
  addDiscordWebhook(webhookUrl) {
    try {
      // Create a notification handler that sends to Discord
      const discordHandler = async (message, level = 'info') => {
        try {
          // Determine color based on level
          let color;
          switch (level) {
            case 'error':
            case 'alert':
              color = 0xFF0000; // Red
              break;
            case 'warn':
              color = 0xFFAA00; // Orange
              break;
            case 'success':
              color = 0x00FF00; // Green
              break;
            default:
              color = 0x0099FF; // Blue
          }
          
          // Prepare embed
          const embed = {
            color: color,
            description: message,
            timestamp: new Date().toISOString()
          };
          
          // Add footer with bot info
          const mode = this.#simulationMode ? 'Simulation' : 'Live';
          embed.footer = {
            text: `Ronin Bot (${mode}) | ${new Date().toLocaleString()}`
          };
          
          const response = await fetch(webhookUrl, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              username: 'Ronin Trading Bot',
              avatar_url: 'https://i.imgur.com/8wPdoUe.png',
              embeds: [embed]
            })
          });
          
          if (!response.ok) {
            throw new Error(`Discord webhook error: ${response.status} ${response.statusText}`);
          }
        } catch (error) {
          this.log(`Discord webhook error: ${error.message}`, 'error');
        }
      };

      // Mark this handler as a Discord handler
      discordHandler.isDiscord = true;
      discordHandler.type = 'discord';

      // Add to notification handlers
      this.addNotificationHandler(discordHandler);
      this.log('Discord webhook added successfully');
      
      // Test the webhook
      discordHandler('🔄 **Discord notifications enabled**\nThis is a test message to confirm webhook functionality.', 'info');
    } catch (error) {
      this.log(`Error adding Discord webhook: ${error.message}`, 'error');
    }
  }

  /**
   * Set risk percentage (1-100)
   * @param {number} percentage Risk percentage 
   */
  setRiskPercentage(percentage) {
    if (percentage <= 0 || percentage > 100) {
      throw new Error('Risk percentage must be between 1 and 100');
    }
    this.#riskPercentage = percentage;
    this.log(`Risk percentage set to ${percentage}%`);
  }

  /**
   * Set minimum profit threshold
   * @param {number} threshold Profit threshold in percentage 
   */
  setMinProfitThreshold(threshold) {
    if (threshold < 0) {
      throw new Error('Minimum profit threshold cannot be negative');
    }
    this.#minProfitThreshold = threshold;
    this.log(`Minimum profit threshold set to ${threshold}%`);
  }

  /**
   * Set daily loss limit as percentage
   * @param {number} percentage Loss limit percentage 
   */
  setDailyLossLimit(percentage) {
    if (percentage <= 0) {
      throw new Error('Daily loss limit must be greater than 0');
    }
    this.#dailyLossLimit = percentage;
    this.log(`Daily loss limit set to ${percentage}%`);
  }

  /**
   * Set stop loss percentage
   * @param {number} percentage Stop loss percentage 
   */
  setStopLossPercentage(percentage) {
    if (percentage <= 0) {
      throw new Error('Stop loss percentage must be greater than 0');
    }
    this.#stopLossPercentage = percentage;
    this.log(`Stop loss percentage set to ${percentage}%`);
  }

  /**
   * Set maximum price impact
   * @param {number} percentage Maximum price impact percentage 
   */
  setMaxPriceImpact(percentage) {
    if (percentage <= 0) {
      throw new Error('Maximum price impact must be greater than 0');
    }
    this.#maxPriceImpact = percentage;
    this.log(`Maximum price impact set to ${percentage}%`);
  }

  /**
   * Set strategy allocation percentages
   * @param {number} dailyMoversAllocation Percentage for daily movers
   * @param {number} arbitrageAllocation Percentage for arbitrage 
   */
  setStrategyAllocation(dailyMoversAllocation, arbitrageAllocation) {
    const total = dailyMoversAllocation + arbitrageAllocation;
    if (total <= 0) {
      throw new Error('Total allocation must be greater than 0');
    }

    this.#dailyMoversAllocation = (dailyMoversAllocation / total) * 100;
    this.#arbitrageAllocation = (arbitrageAllocation / total) * 100;

    this.log(`Strategy allocation set to ${this.#dailyMoversAllocation}% Daily Movers, ${this.#arbitrageAllocation}% Arbitrage`);
  }

  /**
   * Add a trading pair
   * @param {string} pair Trading pair (e.g., "USDC-SOL") 
   */
  addTradingPair(pair) {
    if (!pair.includes('-')) {
      throw new Error('Invalid trading pair format. Use format like "USDC-SOL"');
    }

    const [fromSymbol, toSymbol] = pair.split('-');
    const fromMint = this.#symbolToMint(fromSymbol);
    const toMint = this.#symbolToMint(toSymbol);

    if (!fromMint || !toMint) {
      throw new Error('Unknown token symbol. Add to token registry first.');
    }

    if (!this.#tradingPairs.includes(pair)) {
      this.#tradingPairs.push(pair);
      this.log(`Added trading pair: ${pair}`);
    } else {
      this.log(`Trading pair ${pair} already exists`);
    }
  }

  /**
   * Remove a trading pair
   * @param {string} pair Trading pair to remove
   * @returns {boolean} True if removed, false if not found 
   */
  removeTradingPair(pair) {
    const index = this.#tradingPairs.indexOf(pair);
    if (index !== -1) {
      this.#tradingPairs.splice(index, 1);
      this.log(`Removed trading pair: ${pair}`);
      return true;
    }
    this.log(`Trading pair not found: ${pair}`);
    return false;
  }

  /**
   * Add a token to the registry
   * @param {string} symbol Token symbol
   * @param {string} mint Token mint address 
   */
  addToken(symbol, mint) {
    try {
      // Validate mint address
      new PublicKey(mint);
      
      // Add to registry
      this.#tokenRegistry[symbol.toUpperCase()] = mint;
      this.log(`Added token ${symbol} with mint ${mint}`);
      
      // Initialize volatility and slippage settings with defaults
      this.#tokenVolatility[mint] = 1.0;
      this.#tokenSlippageSettings[mint] = 0.5;
      this.#minimumViableAmounts[mint] = 0.001;
    } catch (error) {
      throw new Error(`Invalid mint address: ${error.message}`);
    }
  }

  /**
   * Add an RPC endpoint
   * @param {string} endpoint RPC endpoint URL 
   */
  async addRpcEndpoint(endpoint) {
    if (!this.#rpcEndpoints.includes(endpoint)) {
      this.#rpcEndpoints.push(endpoint);
      this.log(`Added RPC endpoint: ${endpoint}`);
      
      // Test the new endpoint
      try {
        const connection = new Connection(endpoint, {
          commitment: 'confirmed',
          confirmTransactionInitialTimeout: this.#transactionTimeoutMs,
          disableRetryOnRateLimit: false,
        });
        
        const startTime = Date.now();
        await Promise.race([
          connection.getVersion(),
          new Promise((_, reject) => setTimeout(() => reject(new Error('Timeout')), 5000))
        ]);
        const responseTime = Date.now() - startTime;
        
        this.log(`New RPC endpoint responded in ${responseTime}ms`);
        
        // Add to connection pool
        this.#connectionPool.push(connection);
      } catch (error) {
        this.log(`Warning: New RPC endpoint failed health check: ${error.message}`, 'warn');
      }
    }
  }

  /**
   * Get bot status
   * @returns {Object} Bot status 
   */
  getStatus() {
    return {
      isRunning: this.#isRunning,
      simulationMode: this.#simulationMode,
      currentBalanceUsd: this.#currentBalanceUsd,
      startingBalanceUsd: this.#startingBalanceUsd,
      dailyStartBalance: this.#dailyStartBalance,
      dailyPnL: this.#dailyPnL,
      dailyPnLPercent: this.#dailyStartBalance > 0 ? (this.#dailyPnL / this.#dailyStartBalance * 100) : 0,
      totalTrades: this.#totalTrades,
      successfulTrades: this.#successfulTrades,
      failedTrades: this.#failedTrades,
      successRate: this.#totalTrades > 0 ? (this.#successfulTrades / this.#totalTrades * 100) : 0,
      profitLoss: this.#profitLoss,
      riskParameters: {
        riskPercentage: this.#riskPercentage,
        minProfitThreshold: this.#minProfitThreshold,
        stopLossPercentage: this.#stopLossPercentage,
        dailyLossLimit: this.#dailyLossLimit,
        maxPriceImpact: this.#maxPriceImpact,
        dailyMoverThreshold: this.#dailyMoverThreshold,
      },
      strategyAllocation: {
        dailyMovers: this.#dailyMoversAllocation,
        arbitrage: this.#arbitrageAllocation,
      },
      tradingPairs: this.#tradingPairs,
      tokenRegistry: this.#tokenRegistry,
      rpcEndpoints: this.#rpcEndpoints,
      currentRpcEndpoint: this.#rpcEndpoints[this.#currentRpcIndex],
      walletAddress: this.#wallet.publicKey.toString(),
      connectionHealth: {
        poolSize: this.#connectionPool.length,
        activeIndex: this.#currentRpcIndex
      }
    };
  }

  /**
   * Get trade history
   * @param {number} limit Maximum number of trades to return
   * @returns {Array} Trade history 
   */
  getTradeHistory(limit = 100) {
    const tradeCount = this.#tradeHistory.length;
    return this.#tradeHistory.slice(Math.max(0, tradeCount - limit), tradeCount);
  }

  /**
   * Get daily balances history
   * @returns {Array} Daily balances 
   */
  getDailyBalances() {
    return this.#dailyBalances;
  }
}

module.exports = EnhancedSolanaBot;
