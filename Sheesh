  /**
   * Initialize connection pool with health checks
   * @private
   */
  async #initializeConnectionPool() {
    this.log('Initializing RPC connection pool...');
    
    // Check health of all endpoints
    const healthResults = await Promise.all(
      this.#rpcEndpoints.map(async (endpoint, index) => {
        try {
          const connection = new Connection(endpoint, {
            commitment: 'confirmed',
            confirmTransactionInitialTimeout: this.#transactionTimeoutMs,
            disableRetryOnRateLimit: false,
          });
          
          const startTime = Date.now();
          await Promise.race([
            connection.getVersion(),
            new Promise((_, reject) => 
              setTimeout(() => reject(new Error('Timeout')), this.#rpcHealthTimeout)
            )
          ]);
          const responseTime = Date.now() - startTime;
          
          return { 
            endpoint, 
            connection, 
            healthy: true, 
            responseTime,
            index 
          };
        } catch (error) {
          this.log(`Endpoint ${endpoint} is unhealthy: ${error.message}`, 'warn');
          return { 
            endpoint, 
            healthy: false, 
            responseTime: Infinity,
            index 
          };
        }
      })
    );
    
    // Filter for healthy endpoints and sort by response time
    const healthyEndpoints = healthResults
      .filter(result => result.healthy)
      .sort((a, b) => a.responseTime - b.responseTime);
    
    if (healthyEndpoints.length === 0) {
      throw new Error('No healthy RPC endpoints available');
    }
    
    // Create connection pool with all healthy endpoints
    this.#connectionPool = healthyEndpoints.map(result => result.connection);
    
    // Use the fastest endpoint as default
    this.#connection = this.#connectionPool[0];
    this.#currentRpcIndex = healthyEndpoints[0].index;
    
    this.log(`Selected ${this.#rpcEndpoints[this.#currentRpcIndex]} as primary endpoint (${healthyEndpoints[0].responseTime}ms response time)`);
    this.log(`Connection pool initialized with ${this.#connectionPool.length} healthy endpoints`);
    
    return this.#connection;
  }

