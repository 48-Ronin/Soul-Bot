  /**
   * Get token decimals from metadata or cache
   * @param {string} mint Token mint address
   * @returns {Promise<number>} Token decimals 
   */
  async getTokenDecimals(mint) {
    // Check cache first
    if (this.#tokenDecimalCache.has(mint)) {
      return this.#tokenDecimalCache.get(mint);
    }

    // Special case for SOL
    if (mint === this.#tokenRegistry.SOL) {
      this.#tokenDecimalCache.set(mint, 9);
      return 9;
    }

    try {
      // Get token metadata from Solana
      const info = await this.#connection.getParsedAccountInfo(new PublicKey(mint));
      
      if (info && info.value && info.value.data && 'parsed' in info.value.data) {
        const parsedData = info.value.data.parsed;
        if (parsedData && parsedData.info && parsedData.info.decimals) {
          const decimals = parsedData.info.decimals;
          this.#tokenDecimalCache.set(mint, decimals);
          return decimals;
        }
      }
      
      // Fallbacks for common tokens if metadata fetch fails
      const commonDecimals = {
        [this.#tokenRegistry.USDC]: 6,
        [this.#tokenRegistry.USDT]: 6,
        [this.#tokenRegistry.BONK]: 5,
        [this.#tokenRegistry.MSOL]: 9,
        [this.#tokenRegistry.SAMO]: 9,
        [this.#tokenRegistry.JUP]: 6,
      };
      
      if (commonDecimals[mint]) {
        this.#tokenDecimalCache.set(mint, commonDecimals[mint]);
        return commonDecimals[mint];
      }
      
      // Default to 9 decimals if we can't determine
      this.log(`Could not determine decimals for ${this.#mintToSymbol(mint)}, using default of 9`, 'warn');
      this.#tokenDecimalCache.set(mint, 9);
      return 9;
    } catch (error) {
      this.log(`Error getting token decimals for ${this.#mintToSymbol(mint)}: ${error.message}`, 'error');
      
      if (error.message.includes('rate limit') || error.message.includes('429')) {
        // Try with a different RPC endpoint
        await this.#switchRpcEndpoint();
        // Retry once with new endpoint
        try {
          const info = await this.#connection.getParsedAccountInfo(new PublicKey(mint));
          if (info && info.value && info.value.data && 'parsed' in info.value.data) {
            const decimals = info.value.data.parsed.info.decimals;
            this.#tokenDecimalCache.set(mint, decimals);
            return decimals;
          }
        } catch {
          // Fall through to default
        }
      }
      
      // Default to 9 decimals
      this.#tokenDecimalCache.set(mint, 9);
      return 9;
    }
  }

  /**
   * Get token balance
   * @param {string} mint Token mint address
   * @returns {Promise<number>} Token balance 
   */
  async getTokenBalance(mint) {
    const MAX_RETRIES = 3;
    for (let retries = 0; retries < MAX_RETRIES; retries++) {
      try {
        if (mint === this.#tokenRegistry.SOL) {
          return (await this.#connection.getBalance(this.#wallet.publicKey)) / 1e9;
        }

        const tokenAccount = await getAssociatedTokenAddressSync(
          new PublicKey(mint),
          this.#wallet.publicKey,
          false,
          TOKEN_PROGRAM_ID
        );

        try {
          const info = await this.#connection.getTokenAccountBalance(tokenAccount);
          return parseFloat(info.value.amount) / (10 ** info.value.decimals);
        } catch (e) {
          if (e.message.includes('Account not found') || e.message.includes('could not find account')) {
            return 0; // Handle non-existent ATA
          }
          throw e; // Other errors should be retried
        }
      } catch (e) {
        if (retries + 1 === MAX_RETRIES) {
          this.log(`Failed to get balance for ${this.#mintToSymbol(mint)}: ${e.message}`, 'error');
          
          // If we've retried with the current endpoint, try switching RPC
          if (this.#rpcEndpoints.length > 1) {
            await this.#switchRpcEndpoint();
            // One more try with new endpoint
            try {
              if (mint === this.#tokenRegistry.SOL) {
                return (await this.#connection.getBalance(this.#wallet.publicKey)) / 1e9;
              }
              const tokenAccount = await getAssociatedTokenAddressSync(
                new PublicKey(mint),
                this.#wallet.publicKey,
                false,
                TOKEN_PROGRAM_ID
              );
              const info = await this.#connection.getTokenAccountBalance(tokenAccount);
              return parseFloat(info.value.amount) / (10 ** info.value.decimals);
            } catch {
              return 0; // Give up if even the fallback RPC fails
            }
          }
          
          return 0;
        }

        // Exponential backoff
        const backoffMs = Math.pow(2, retries) * 1000;
        this.log(`Retrying balance check for ${this.#mintToSymbol(mint)} in ${backoffMs/1000}s`, 'debug');
        await new Promise(resolve => setTimeout(resolve, backoffMs));
      }
    }
    return 0; // Should not reach here but added for safety
  }

  /**
   * Estimate transaction fee based on network conditions including priority fees
   * @returns {Promise<number>} Estimated fee in lamports
   * @private 
   */
  async #estimateTransactionFee() {
    try {
      // Use cached estimate if available and not expired
      const now = Date.now();
      if (this.#cachedFeeEstimate && now < this.#cachedFeeEstimate.expiresAt) {
        return this.#cachedFeeEstimate.fee;
      }

      // Get recent blockhash and fee calculator
      const { feeCalculator, blockhash } = await this.#connection.getRecentBlockhash('finalized');

      // Base fee in lamports
      const baseFee = feeCalculator ? feeCalculator.lamportsPerSignature : 5000;

      // Get priority fee estimates
      let priorityFee = 0;
      try {
        const priorityFeeResponse = await this.#connection.getRecentPrioritizationFees();
        if (priorityFeeResponse && priorityFeeResponse.length > 0) {
          // Calculate the median priority fee from recent fees
          const sortedFees = priorityFeeResponse
            .map(item => item.prioritizationFee)
            .sort((a, b) => a - b);
          
          const medianIndex = Math.floor(sortedFees.length / 2);
          priorityFee = sortedFees[medianIndex];
          
          // Add a safety margin
          priorityFee = Math.ceil(priorityFee * 1.1);
        }
      } catch (e) {
        this.log(`Priority fee estimation failed: ${e.message}`, 'warn');
        // Default to a moderate priority fee
        priorityFee = 1000;
      }

      // Adjust based on network congestion
      let congestionMultiplier = 1.0;
      try {
        const performanceSamples = await this.#connection.getRecentPerformanceSamples(10);
        if (performanceSamples && performanceSamples.length > 0) {
          // Calculate average TPS
          const averageTps = performanceSamples.reduce((sum, sample) => sum + sample.numTransactions / sample.samplePeriodSecs, 0) / performanceSamples.length;
          
          // Adjust multiplier based on TPS
          if (averageTps < 1000) {
            congestionMultiplier = 2.0; // High congestion
          } else if (averageTps < 2000) {
            congestionMultiplier = 1.5; // Medium congestion
          }
        }
      } catch (error) {
        this.log(`Error checking network performance: ${error.message}`, 'warn');
      }

      // Additional fee for complex transactions
      const complexityMultiplier = 1.5; // Swaps are complex

      // Calculate final fee estimate
      const estimatedFee = Math.ceil((baseFee + priorityFee) * congestionMultiplier * complexityMultiplier);

      // Cache this estimate for a shorter period during high congestion
      const cacheMs = congestionMultiplier > 1.5 ? 5000 : 10000;
      this.#cachedFeeEstimate = {
        fee: estimatedFee,
        timestamp: now,
        expiresAt: now + cacheMs,
        blockhash
      };

      this.log(`Estimated fee: ${estimatedFee} lamports (base: ${baseFee}, priority: ${priorityFee}, congestion: ${congestionMultiplier.toFixed(1)}x)`, 'debug');
      return estimatedFee;
    } catch (error) {
      this.log(`Fee estimation error: ${error.message}`, 'error');
      // Fall back to safe default
      return 15000; // 15,000 lamports as safe default
    }
  }

  /**
   * Get token price from API or cache
   * @param {string} mint Token mint address
   * @returns {Promise<number>} Token price in USD 
   */
  async getTokenPrice(mint) {
    try {
      // Check cache first
      const cached = this.#tokenPriceCache.get(mint);
      const now = Date.now();
      if (cached && (now - cached.timestamp) < this.#priceCacheTTL) {
        return cached.price;
      }

      // Special case for stablecoins
      if (this.#isStablecoin(mint)) {
        this.#tokenPriceCache.set(mint, { price: 1.0, timestamp: now });
        return 1.0;
      }

      // Use circuit breaker for Jupiter API calls
      return await this.#jupiterQuoteCircuitBreaker.execute(
        async () => {
          const controller = new AbortController();
          const timeoutId = setTimeout(() => controller.abort(), 10000);

          try {
            const response = await fetch(`https://price.jup.ag/v4/price?ids=${mint}`, {
              signal: controller.signal
            });
            clearTimeout(timeoutId);

            if (!response.ok) throw new Error(`Price API error: ${response.status}`);
            const data = await response.json();

            if (data && data.data && data.data[mint] && data.data[mint].price) {
              const price = data.data[mint].price;
              this.#tokenPriceCache.set(mint, { price, timestamp: now });
              return price;
            }
            throw new Error('Invalid price data format');
          } catch (fetchError) {
            clearTimeout(timeoutId);
            throw fetchError;
          }
        },
        async () => {
          // Fallback when circuit is open
          return await this.#getTokenPriceFallback(mint);
        }
      );
    } catch (error) {
      this.log(`Error fetching token price for ${this.#mintToSymbol(mint)}: ${error.message}`, 'error');
      return await this.#getTokenPriceFallback(mint);
    }
  }

  /**
   * Fallback method for token pricing if Jupiter API fails
   * @param {string} mint Token mint address
   * @returns {Promise<number>} Token price in USD
   * @private 
   */
  async #getTokenPriceFallback(mint) {
    try {
      // Fallbacks for common tokens if price fetch fails
      const fallbackPrices = {
        [this.#tokenRegistry.SOL]: 150,
        [this.#tokenRegistry.BONK]: 0.00001,
        [this.#tokenRegistry.SAMO]: 0.02,
        [this.#tokenRegistry.MSOL]: 155,
        [this.#tokenRegistry.JUP]: 0.5,
      };

      if (fallbackPrices[mint]) {
        this.log(`Using fallback price for ${this.#mintToSymbol(mint)}: $${fallbackPrices[mint]}`, 'warn');
        this.#tokenPriceCache.set(mint, {
          price: fallbackPrices[mint],
          timestamp: Date.now() - (this.#priceCacheTTL / 2) // Shorter cache time for fallbacks
        });
        return fallbackPrices[mint];
      }

      // Try a different price source
      try {
        // We could add alternative price sources here
        // For example, Coingecko, CoinMarketCap, or other DEX APIs
      } catch (altError) {
        this.log(`Alternative price source failed: ${altError.message}`, 'debug');
      }

      // If no fallback available, use a very low price to minimize risk
      this.log(`No price data for ${this.#mintToSymbol(mint)}, using safe minimum`, 'warn');
      return 0.00001;
    } catch (error) {
      this.log(`Error in getTokenPriceFallback for ${this.#mintToSymbol(mint)}: ${error.message}`, 'error');
      return 0.00001; // Default fallback price
    }
  }

  /**
   * Get detailed transaction information using Helius Transaction API
   * @param {string} signature Transaction signature
   * @returns {Promise<Object>} Detailed transaction data 
   */
  async getTransactionDetails(signature) {
    try {
      const url = `${this.#heliusTransactionApi}?api-key=${this.#heliusApiKey}`;
      const response = await fetch(url, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          transactions: [signature]
        })
      });

      if (!response.ok) {
        throw new Error(`Helius API error: ${response.status} ${response.statusText}`);
      }

      const data = await response.json();
      if (!data || !Array.isArray(data) || data.length === 0) {
        throw new Error('Invalid response from Helius API');
      }
      
      return data[0]; // Return the first transaction's details
    } catch (error) {
      this.log(`Error fetching transaction details: ${error.message}`, 'error');
      return null;
    }
  }

  /**
   * Check transaction status with enhanced details
   * @param {string} signature Transaction signature
   * @returns {Promise<Object>} Transaction status with details 
   */
  async checkTransactionStatus(signature) {
    try {
      // First, check basic status with regular RPC
      const status = await this.#connection.getSignatureStatus(signature, {searchTransactionHistory: true});
      
      // Then, get enhanced details from Helius
      const details = await this.getTransactionDetails(signature);

      return {
        confirmed: status?.value?.confirmationStatus === 'confirmed' || status?.value?.confirmationStatus === 'finalized',
        status: status?.value?.confirmationStatus || 'unknown',
        slot: status?.context?.slot,
        details: details,
      };
    } catch (error) {
      this.log(`Error checking transaction status: ${error.message}`, 'error');
      return { confirmed: false, status: 'error', error: error.message };
    }
  }

  /**
   * Calculate total portfolio value
   * @returns {Promise<number>} Portfolio value in USD 
   */
  async calculatePortfolioValue() {
    const MAX_RETRIES = 3;
    for (let retries = 0; retries < MAX_RETRIES; retries++) {
      try {
        const uniqueTokens = new Set();

        // Add all tokens from trading pairs
        this.#tradingPairs.forEach(pair => {
          const [fromMint, toMint] = this.#parseTradingPair(pair);
          uniqueTokens.add(fromMint);
          uniqueTokens.add(toMint);
        });

        // Add major tokens like USDC, SOL
        uniqueTokens.add(this.#tokenRegistry.USDC);
        uniqueTokens.add(this.#tokenRegistry.SOL);

        let totalValue = 0;
        for (const mint of uniqueTokens) {
          const balance = await this.getTokenBalance(mint);
          if (balance > 0) {
            const price = await this.getTokenPrice(mint);
            const value = balance * price;
            totalValue += value;
            this.log(`${this.#mintToSymbol(mint)}: ${balance.toFixed(6)} @ $${price.toFixed(6)} = $${value.toFixed(2)}`, 'debug');
          }
        }

        this.#currentBalanceUsd = totalValue;
        return totalValue;
      } catch (e) {
        if (retries + 1 === MAX_RETRIES) {
          this.log(`Portfolio value calculation failed: ${e.message}`, 'error');
          return this.#currentBalanceUsd || 0;
        }
        const backoffMs = Math.pow(2, retries) * 1000;
        await new Promise(resolve => setTimeout(resolve, backoffMs));
      }
    }
    return this.#currentBalanceUsd || 0;
  }

  /**
   * Track daily balance and calculate P&L
   * @returns {Promise<number>} Current balance in USD 
   */
  async trackDailyBalance() {
    try {
      // Calculate current portfolio value
      const totalBalance = await this.calculatePortfolioValue();

      // Set as daily starting balance if not set yet today
      const today = new Date().toDateString();
      const lastBalanceDay = this.#getStoredValue('lastBalanceDay');
      
      if (lastBalanceDay !== today) {
        this.#dailyStartBalance = totalBalance;
        this.#dailyPnL = 0;
        this.#setStoredValue('lastBalanceDay', today);
        this.#setStoredValue('dailyStartBalance', this.#dailyStartBalance.toString());
        this.log(`New day detected. Setting starting balance: $${this.#dailyStartBalance.toFixed(2)}`);
        
        // Store historical balance
        const balanceRecord = {
          date: today,
          balance: totalBalance,
          change: 0
        };
        this.#dailyBalances.push(balanceRecord);
        if (this.#dailyBalances.length > 30) {
          this.#dailyBalances = this.#dailyBalances.slice(-30); // Keep only last 30 days
        }
        this.#setStoredValue('dailyBalances', JSON.stringify(this.#dailyBalances));
        
        // Send Discord notification for new day
        await this.sendDiscordNotification(
          `📅 **NEW TRADING DAY**\nStarting balance: $${this.#dailyStartBalance.toFixed(2)}`,
          'info'
        );
      } else if (this.#dailyStartBalance === 0) {
        // If we're restarting the bot during the same day, load saved value
        const savedBalance = this.#getStoredValue('dailyStartBalance');
        if (savedBalance) {
          this.#dailyStartBalance = parseFloat(savedBalance);
        } else {
          this.#dailyStartBalance = totalBalance;
          this.#setStoredValue('dailyStartBalance', this.#dailyStartBalance.toString());
        }
        this.log(`Loaded daily starting balance: $${this.#dailyStartBalance.toFixed(2)}`);
      }
      
      // Calculate current daily P&L
      this.#dailyPnL = totalBalance - this.#dailyStartBalance;
      const dailyPnLPercent = (this.#dailyPnL / this.#dailyStartBalance * 100);
      this.log(`Current daily P&L: $${this.#dailyPnL.toFixed(2)} (${dailyPnLPercent.toFixed(2)}%)`);
      
      // Store last known balance
      this.#setStoredValue('lastKnownBalance', totalBalance.toString());
      
      // Check daily loss limit
      if (this.#hasHitDailyLossLimit()) {
        this.notify(`⚠️ DAILY LOSS LIMIT REACHED: ${dailyPnLPercent.toFixed(2)}% loss exceeds ${this.#dailyLossLimit}% limit`, 'alert');
        
        // Send Discord alert for loss limit
        await this.sendDiscordNotification(
          `🚨 **DAILY LOSS LIMIT REACHED**\nTrading halted - Daily loss: ${dailyPnLPercent.toFixed(2)}% exceeds ${this.#dailyLossLimit}% limit\nCurrent balance: $${totalBalance.toFixed(2)}`,
          'error'
        );
      }
      
      return totalBalance;
    } catch (error) {
      this.log(`Error tracking daily balance: ${error.message}`, 'error');
      
      // Try to recover from stored data
      const lastKnownBalanceStr = this.#getStoredValue('lastKnownBalance');
      let lastKnownBalance = 0;
      
      if (lastKnownBalanceStr) {
        lastKnownBalance = parseFloat(lastKnownBalanceStr);
        this.log(`Using last known balance: $${lastKnownBalance}`, 'warn');
      }
      
      // If daily start balance is not set, try to load from storage
      if (this.#dailyStartBalance === 0) {
        const savedStartBalance = this.#getStoredValue('dailyStartBalance');
        if (savedStartBalance) {
          this.#dailyStartBalance = parseFloat(savedStartBalance);
          this.log(`Recovered daily starting balance: $${this.#dailyStartBalance}`, 'warn');
        } else if (lastKnownBalance > 0) {
          // Use last known balance as starting balance if we have nothing else
          this.#dailyStartBalance = lastKnownBalance;
          this.log(`Using last known balance as daily starting balance: $${this.#dailyStartBalance}`, 'warn');
        } else {
          // Absolute last resort - use a safe default
          this.#dailyStartBalance = 1000;
          this.log(`Using safe default for daily starting balance: $${this.#dailyStartBalance}`, 'warn');
        }
      }
      
      return lastKnownBalance > 0 ? lastKnownBalance : this.#dailyStartBalance;
    }
  }

  /**
   * Check if we've hit the daily loss limit
   * @returns {boolean} True if daily loss limit has been reached
   * @private 
   */
  #hasHitDailyLossLimit() {
    if (this.#dailyStartBalance <= 0) return false;

    const lossPercentage = (this.#dailyPnL / this.#dailyStartBalance) * 100;

    return lossPercentage <= -this.#dailyLossLimit;
  }

  /**
   * Get stop loss threshold based on token volatility
   * @param {string} mint Token mint address
   * @returns {number} Stop loss percentage
   * @private
   */
  #getTokenStopLossThreshold(mint) {
    const baseStopLoss = this.#stopLossPercentage;
    const volatilityFactor = this.#tokenVolatility[mint] || 1.0;
    
    // More volatile tokens get a higher stop loss threshold
    return baseStopLoss * volatilityFactor;
  }

  /**
   * Check if a token has hit its stop loss
   * @param {string} mint Token mint address
   * @param {number} currentValueUsd Current value in USD
   * @returns {Promise<{triggered: boolean, mint?: string, symbol?: string, dropPercentage?: number, highWaterMarkUsd?: number, currentValueUsd?: number}>} Stop loss status 
   */
  async checkStopLoss(mint, currentValueUsd) {
    try {
      const symbol = this.#mintToSymbol(mint);
      const stopLossKey = `stopLoss_${mint}`;

      // Get token-specific stop loss threshold
      const stopLossThreshold = this.#getTokenStopLossThreshold(mint);

      // Get the high-water mark for this token (if it exists)
      const highWaterMarkStr = this.#getStoredValue(stopLossKey);
      let highWaterMarkUsd = highWaterMarkStr ? parseFloat(highWaterMarkStr) : 0;

      // If current value is higher than high-water mark, update it
      if (currentValueUsd > highWaterMarkUsd) {
        highWaterMarkUsd = currentValueUsd;
        this.#setStoredValue(stopLossKey, highWaterMarkUsd.toString());
        return { triggered: false };
      }

      // Check if we're below stop loss threshold
      if (highWaterMarkUsd > 0) {
        const dropPercentage = (1 - (currentValueUsd / highWaterMarkUsd)) * 100;
        if (dropPercentage >= stopLossThreshold) {
          this.notify(`⚠️ STOP LOSS TRIGGERED for ${symbol}:`, 'alert');
          this.log(`Peak value: $${highWaterMarkUsd.toFixed(2)}`);
          this.log(`Current value: $${currentValueUsd.toFixed(2)}`);
          this.log(`Drop: ${dropPercentage.toFixed(2)}% (threshold: ${stopLossThreshold.toFixed(2)}%)`);
          
          return { 
            triggered: true, 
            mint, 
            symbol,
            dropPercentage,
            highWaterMarkUsd,
            currentValueUsd,
            threshold: stopLossThreshold
          };
        }
      }

      return { triggered: false };
    } catch (error) {
      this.log(`Error in stop loss check for ${this.#mintToSymbol(mint)}: ${error.message}`, 'error');
      return { triggered: false };
    }
  }

  /**
   * Execute exit trade for stop loss
   * @param {string} mint Token mint address to exit
   * @returns {Promise<boolean>} Success or failure 
   */
  async executeStopLossExit(mint) {
    try {
      const symbol = this.#mintToSymbol(mint);
      this.log(`Executing stop loss exit for ${symbol}`);

      // Get token balance
      const balance = await this.getTokenBalance(mint);
      const minViableAmount = this.#minimumViableAmounts[mint] || 0.001;
      
      if (balance <= minViableAmount) {
        this.log(`No significant balance for ${symbol}, skipping stop loss exit`, 'warn');
        return false;
      }

      // Choose appropriate stable coin as destination
      const stableMint = this.#tokenRegistry.USDC;

      // Get exit quote - sell 98% of the balance (leave a bit for dust)
      const exitAmount = balance * 0.98;

      // Log the exit attempt
      this.log(`Stop loss exit: selling ${exitAmount.toFixed(6)} ${symbol} for USDC`);

      // Get quote for the exit trade
      const quote = await this.getJupiterQuote(mint, stableMint, exitAmount);
      if (!quote) {
        this.log(`Failed to get quote for stop loss exit of ${symbol}`, 'error');
        return false;
      }

      // Ignore profit threshold for stop loss - execute at market price
      const result = await this.executeTrade(
        mint,
        stableMint,
        exitAmount,
        quote,
        'STOP_LOSS'
      );

      if (result) {
        // Reset stop loss high-water mark after successful exit
        this.#setStoredValue(`stopLoss_${mint}`, "0");
        
        // Send urgent notification for stop loss
        await this.sendDiscordNotification(
          `🛑 **STOP LOSS EXECUTED FOR ${symbol}**\nSold ${exitAmount.toFixed(6)} ${symbol} for USDC`,
          'alert'
        );
        
        this.notify(`✅ Stop loss exit completed for ${symbol}`);
        return true;
      } else {
        this.log(`Stop loss exit failed for ${symbol}`, 'error');
        return false;
      }
    } catch (error) {
      this.log(`Error executing stop loss exit for ${this.#mintToSymbol(mint)}: ${error.message}`, 'error');
      return false;
    }
  }

  /**
   * Query Jupiter API for routes with exponential backoff retry
   * @param {string} inputMint Input token mint address
   * @param {string} outputMint Output token mint address
   * @param {number} amount Amount to swap
   * @param {number} slippageBps Slippage in basis points
   * @returns {Promise<any>} Jupiter quote response 
   */
  async getJupiterQuote(inputMint, outputMint, amount, slippageBps = 50) {
    // Use token-specific slippage if available
    const tokenSlippage = this.#tokenSlippageSettings[inputMint] || 
                         this.#tokenSlippageSettings[outputMint] || 
                         0.5; // Default 0.5%
    
    // Convert slippage from percentage to basis points if not provided
    if (!slippageBps) {
      slippageBps = Math.floor(tokenSlippage * 100);
    }
    
    try {
      // Get token decimals
      const inputDecimals = await this.getTokenDecimals(inputMint);
      const inputAmount = Math.floor(amount * Math.pow(10, inputDecimals));

      const params = new URLSearchParams({
        inputMint,
        outputMint,
        amount: inputAmount.toString(),
        slippageBps: slippageBps.toString(),
        feeBps: '4',
        onlyDirectRoutes: 'false',
        asLegacyTransaction: 'false',
      });

      // Use circuit breaker for Jupiter API
      return await this.#jupiterQuoteCircuitBreaker.execute(
        async () => {
          const MAX_RETRIES = 3;
          let lastError = null;
          
          for (let attempt = 0; attempt < MAX_RETRIES; attempt++) {
            try {
              const controller = new AbortController();
              const timeoutId = setTimeout(() => controller.abort(), 15000);
              
              const response = await fetch(`${this.#jupiterApiUrl}/quote?${params}`, {
                signal: controller.signal
              });
              clearTimeout(timeoutId);
      
              if (!response.ok) {
                throw new Error(`Jupiter API error: ${response.status} ${response.statusText}`);
              }
              
              const quote = await response.json();
              if (!quote || !quote.outAmount) {
                throw new Error('Invalid quote response');
              }
              
              return quote;
            } catch (error) {
              lastError = error;
              
              if (error.name === 'AbortError') {
                this.log('Jupiter quote API request timed out', 'warn');
              } else {
                this.log(`Jupiter quote error (attempt ${attempt+1}/${MAX_RETRIES}): ${error.message}`, 'warn');
              }
              
              // Switch RPC endpoint if it's a server error
              if (error.message.includes('5') || error.message.includes('429')) {
                await this.#switchRpcEndpoint();
              }
              
              if (attempt < MAX_RETRIES - 1) {
                // Exponential backoff before retry
                const backoffMs = Math.pow(2, attempt) * 1000;
                this.log(`Retrying Jupiter quote in ${backoffMs/1000}s`, 'debug');
                await new Promise(resolve => setTimeout(resolve, backoffMs));
              }
            }
          }
          
          // If we got here, all retries failed
          throw lastError || new Error('Failed to get Jupiter quote after multiple attempts');
        },
        async () => {
          // Fallback when circuit is open
          this.log('Jupiter quote API circuit breaker open, using fallback method', 'warn');
          return null;
        }
      );
    } catch (error) {
      this.log(`Error in getJupiterQuote: ${error.message}`, 'error');
      return null;
    }
  }

  /**
   * Find the best price from available routes with price impact protection
   * @param {Array} routes Routes information
   * @param {string} inputMint Input token mint address
   * @param {string} outputMint Output token mint address
   * @returns {Object|null} Best route or null if none found
   * @private 
   */
  #findBestPrice(routes, inputMint, outputMint) {
    if (!routes || routes.length === 0) {
      return null;
    }

    // Get token-specific max price impact
    const tokenVolatilityFactorIn = this.#tokenVolatility[inputMint] || 1.0;
    const tokenVolatilityFactorOut = this.#tokenVolatility[outputMint] || 1.0;
    const volatilityFactor = Math.max(tokenVolatilityFactorIn, tokenVolatilityFactorOut);
    
    // Adjust price impact threshold based on token volatility
    const adjustedMaxPriceImpact = this.#maxPriceImpact * volatilityFactor;

    // Remove routes with excessive price impact
    const filteredRoutes = routes.filter(route => 
      route.priceImpactPct < adjustedMaxPriceImpact
    );

    if (filteredRoutes.length === 0) {
      this.log(`All routes exceed maximum price impact (${adjustedMaxPriceImpact.toFixed(2)}%), falling back to best available`, 'warn');
      // Sort by best output in descending order
      const sortedRoutes = routes.sort((a, b) => 
        parseFloat(b.outAmount) - parseFloat(a.outAmount)
      );
      
      this.log(`Selected route has high price impact: ${sortedRoutes[0].priceImpactPct.toFixed(2)}%`, 'warn');
      return sortedRoutes[0];
    }

    // Sort by expected output in descending order (higher is better)
    const sortedRoutes = filteredRoutes.sort((a, b) => 
      parseFloat(b.outAmount) - parseFloat(a.outAmount)
    );
    
    return sortedRoutes[0];
  }

  /**
   * Calculate adaptive slippage based on price impact and market volatility
   * @param {number} priceImpact Price impact percentage
   * @param {string} inputMint Input token mint
   * @param {string} outputMint Output token mint
   * @returns {number} Slippage percentage
   * @private 
   */
  #calculateAdaptiveSlippage(priceImpact, inputMint, outputMint) {
    // Get token-specific base slippage
    const inputTokenSlippage = this.#tokenSlippageSettings[inputMint] || 0.5;
    const outputTokenSlippage = this.#tokenSlippageSettings[outputMint] || 0.5;
    
    // Use the higher of the two token slippages as base
    let slippage = Math.max(inputTokenSlippage, outputTokenSlippage);
    
    // Get token volatility factors
    const inputVolatility = this.#tokenVolatility[inputMint] || 1.0;
    const outputVolatility = this.#tokenVolatility[outputMint] || 1.0;
    
    // Use the higher volatility factor
    const volatilityFactor = Math.max(inputVolatility, outputVolatility);

    // Adjust slippage based on volatility
    slippage *= volatilityFactor;

    // Adjust based on price impact
    if (priceImpact > 1) {
      slippage += priceImpact * 0.5; // Add 0.5% for each 1% of price impact
    }

    // Additional adjustment for higher impacts
    if (priceImpact > 3) {
      slippage += priceImpact * 0.3; // Add another 0.3% per 1% for high impacts
    }

    // Check current market conditions - higher volatility needs more slippage
    const marketConditionMultiplier = 1.0; // Default normal market
    
    // Apply market condition multiplier
    slippage *= marketConditionMultiplier;

    // Cap maximum slippage at 8% for extremely volatile conditions
    // but allow token-specific overrides for extremely volatile tokens
    const maxSlippage = volatilityFactor > 2 ? 12 : 8;
    
    return Math.min(slippage, maxSlippage);
  }

  /**
   * Create swap transaction
   * @param {Object} route Jupiter route info
   * @param {number} slippageBps Slippage in basis points
   * @returns {Promise<Transaction|VersionedTransaction|null>} Transaction object or null 
   */
  async #createSwapTransaction(route, slippageBps) {
    try {
      // Use circuit breaker for Jupiter swap API
      return await this.#jupiterSwapCircuitBreaker.execute(
        async () => {
          const MAX_RETRIES = 2;
          let lastError = null;
          
          for (let attempt = 0; attempt < MAX_RETRIES; attempt++) {
            try {
              const controller = new AbortController();
              const timeoutId = setTimeout(() => controller.abort(), 30000);
              
              const response = await fetch(`${this.#jupiterApiUrl}/swap`, {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                  route: route,
                  userPublicKey: this.#wallet.publicKey.toString(),
                  slippageBps
                }),
                signal: controller.signal
              });
              clearTimeout(timeoutId);
      
              if (!response.ok) {
                throw new Error(`Jupiter swap API error: ${response.status}`);
              }
      
              const swapData = await response.json();
              if (!swapData || !swapData.swapTransaction) {
                throw new Error('No swap transaction received from Jupiter');
              }
              
              // Proper handling for Jupiter v6 transactions
              try {
                // First deserialize to determine if it's a versioned transaction
                const messageBytes = Buffer.from(swapData.swapTransaction, 'base64');
                
                // Check if it's a versioned transaction (first byte is 0x80)
                if ((messageBytes[0] & 0x80) !== 0) {
                  // It's a versioned transaction
                  this.log('Processing versioned transaction from Jupiter', 'debug');
                  const versionedTx = VersionedTransaction.deserialize(messageBytes);
                  
                  // Add blockhash and recent priority fee if needed
                  const { blockhash } = await this.#connection.getLatestBlockhash('finalized');
                  
                  // Sign the transaction properly
                  const signers = [this.#wallet];
                  const signatures = signers.map(signer => {
                    const signature = nacl.sign.detached(
                      versionedTx.message.serialize(),
                      signer.secretKey
                    );
                    return { pubkey: signer.publicKey, signature };
                  });
                  
                  versionedTx.addSignature(this.#wallet.publicKey, signatures[0].signature);
                  return versionedTx;
                } else {
                  // It's a legacy transaction
                  this.log('Processing legacy transaction from Jupiter', 'debug');
                  const legacyTx = Transaction.from(messageBytes);
                  
                  // Partial sign with our wallet
                  legacyTx.partialSign(this.#wallet);
                  return legacyTx;
                }
              } catch (error) {
                this.log(`Error processing transaction: ${error.message}`, 'error');
                throw error;
              }
            } catch (error) {
              lastError = error;
              
              if (error.name === 'AbortError') {
                this.log('Jupiter swap API request timed out', 'warn');
              } else {
                this.log(`Error creating swap transaction (attempt ${attempt+1}/${MAX_RETRIES}): ${error.message}`, 'warn');
              }
              
              if (attempt < MAX_RETRIES - 1) {
                // Switch RPC endpoint if it seems like a server error
                if (error.message.includes('5') || error.message.includes('429')) {
                  await this.#switchRpcEndpoint();
                }
                
                // Exponential backoff
                const backoffMs = Math.pow(2, attempt) * 2000;
                this.log(`Retrying swap transaction creation in ${backoffMs/1000}s`, 'debug');
                await new Promise(resolve => setTimeout(resolve, backoffMs));
              }
            }
          }
          
          // If we got here, all retries failed
          throw lastError || new Error('Failed to create swap transaction after multiple attempts');
        },
        async () => {
          // Fallback when circuit is open
          this.log('Jupiter swap API circuit breaker open, cannot create transaction', 'error');
          return null;
        }
      );
    } catch (error) {
      this.log(`Error in createSwapTransaction: ${error.message}`, 'error');
      return null;
    }
  }

  /**
   * Send and confirm transaction with exponential backoff retries
   * @param {Transaction|VersionedTransaction} transaction Transaction to send
   * @returns {Promise<string|null>} Transaction signature or null if failed
   * @private 
   */
  async #sendAndConfirmTransaction(transaction) {
    const maxRetries = this.#maxTransactionRetries;
    let currentRetry = 0;

    while (currentRetry < maxRetries) {
      try {
        let signature;
        
        // Use adaptive timeout based on network congestion
        const adaptiveTimeoutMs = await this.#getAdaptiveTransactionTimeout();
        
        if (transaction instanceof VersionedTransaction) {
          // Handle versioned transaction
          signature = await this.#connection.sendTransaction(transaction);
          
          // Wait for confirmation with adaptive timeout
          const confirmedSig = await this.#waitForConfirmation(signature, adaptiveTimeoutMs);
          
          if (confirmedSig) {
            return confirmedSig;
          }
          throw new Error('Transaction confirmation timed out');
        } else {
          // Handle legacy transaction
          signature = await sendAndConfirmTransaction(
            this.#connection,
            transaction,
            [this.#wallet],
            {
              skipPreflight: false,
              commitment: 'confirmed',
              maxRetries: 5,
              confirmTransactionInitialTimeout: adaptiveTimeoutMs
            }
          );
          return signature;
        }
      } catch (error) {
        currentRetry++;
        
        // Check if this is a retryable error
        const isRetryable = 
          error.message?.includes('timeout') || 
          error.message?.includes('block height exceeded') ||
          error.message?.includes('too many requests') ||
          error.message?.includes('rate limit') ||
          error.message?.includes('throttled') ||
          error.message?.includes('blockhash not found') ||
          error.message?.includes('503') ||
          error.message?.includes('500') ||
          error.message?.includes('429');
        
        if (isRetryable && currentRetry < maxRetries) {
          // Exponential backoff with random jitter
          const baseDelay = Math.pow(2, currentRetry) * 1000;
          const jitter = Math.random() * 1000;
          const delay = baseDelay + jitter;
          
          this.log(`Transaction failed, retrying in ${(delay/1000).toFixed(1)}s (attempt ${currentRetry}/${maxRetries}): ${error.message}`, 'warn');
          await new Promise(resolve => setTimeout(resolve, delay));
          
          // If blockhash expired or RPC issue, switch endpoint
          if (error.message?.includes('blockhash') || 
              error.message?.includes('5') || 
              error.message?.includes('429')) {
            await this.#switchRpcEndpoint();
          }
        } else {
          this.log(`Error sending transaction: ${error.message}`, 'error');
          
          // Send Discord notification for failed transaction
          await this.sendDiscordNotification(
            `❌ **TRANSACTION FAILED**\nError: ${error.message}`,
            'error'
          );
          
          return null;
        }
      }
    }

    this.log(`Failed to send transaction after ${maxRetries} attempts`, 'error');
    return null;
  }

  /**
   * Get adaptive transaction timeout based on network conditions
   * @returns {Promise<number>} Timeout in milliseconds
   * @private
   */
  async #getAdaptiveTransactionTimeout() {
    try {
      // Base timeout
      let timeout = this.#transactionTimeoutMs;
      
      // Check network congestion
      const performanceSamples = await this.#connection.getRecentPerformanceSamples(5);
      if (performanceSamples && performanceSamples.length > 0) {
        // Calculate average TPS
        const averageTps = performanceSamples.reduce((sum, sample) => sum + sample.numTransactions / sample.samplePeriodSecs, 0) / performanceSamples.length;
        
        // Adjust timeout based on TPS (lower TPS = network congestion)
        if (averageTps < 1000) {
          // High congestion, increase timeout significantly
          timeout *= 2;
        } else if (averageTps < 2000) {
          // Medium congestion, moderate increase
          timeout *= 1.5;
        }
      }
      
      return timeout;
    } catch (error) {
      // If we can't determine network conditions, use default
      return this.#transactionTimeoutMs;
    }
  }

  /**
   * Wait for transaction confirmation with adaptive backoff
   * @param {string} signature Transaction signature
   * @param {number} timeoutMs Maximum timeout in milliseconds
   * @returns {Promise<string|null>} Confirmed signature or null if timed out
   * @private 
   */
  async #waitForConfirmation(signature, timeoutMs = this.#transactionTimeoutMs) {
    const startTime = Date.now();
    let checkCount = 0;
    
    while (Date.now() - startTime < timeoutMs) {
      try {
        checkCount++;
        const confirmation = await this.#connection.getSignatureStatus(signature);
        
        if (confirmation && confirmation.value && 
            (confirmation.value.confirmationStatus === 'confirmed' || 
             confirmation.value.confirmationStatus === 'finalized')) {
          return signature;
        }
        
        // Adaptive backoff - start with quick checks and then slow down
        const waitTime = Math.min(2000 * Math.pow(1.5, Math.min(checkCount, 5) - 1), 10000);
        
        this.log(`Transaction not confirmed yet, checking again in ${waitTime/1000}s (attempt ${checkCount})`, 'debug');
        await new Promise(resolve => setTimeout(resolve, waitTime));
      } catch (error) {
        this.log(`Error checking tx confirmation: ${error.message}`, 'warn');
        
        // Increase check interval on error
        await new Promise(resolve => setTimeout(resolve, 3000));
      }
    }

    this.log(`Transaction confirmation timed out after ${timeoutMs/1000}s`, 'error');
    return null; // Timed out
  }

  /**
   * Check if token account exists, create if it doesn't
   * @param {string} mint Token mint address
   * @returns {Promise<boolean>} True if account exists or was created 
   */
  async ensureTokenAccount(mint) {
    if (mint === this.#tokenRegistry.SOL) {
      // SOL doesn't need an associated token account
      return true;
    }

    try {
      const mintPubkey = new PublicKey(mint);
      const associatedTokenAddress = getAssociatedTokenAddressSync(
        mintPubkey,
        this.#wallet.publicKey,
        false,
        TOKEN_PROGRAM_ID
      );
      
      // Check if account exists
      const account = await this.#connection.getAccountInfo(associatedTokenAddress);
      
      if (account) {
        return true; // Account exists
      }
      
      // Account doesn't exist, create it
      this.log(`Creating token account for ${this.#mintToSymbol(mint)}`);
      
      const transaction = new Transaction().add(
        createAssociatedTokenAccountInstruction(
          this.#wallet.publicKey, // payer
          associatedTokenAddress, // associated token account
          this.#wallet.publicKey, // owner
          mintPubkey, // mint
          TOKEN_PROGRAM_ID
        )
      );
      
      // Get recent blockhash
      const { blockhash } = await this.#connection.getRecentBlockhash('finalized');
      transaction.recentBlockhash = blockhash;
      transaction.feePayer = this.#wallet.publicKey;
      
      // Send and confirm transaction
      const signature = await this.#sendAndConfirmTransaction(transaction);
      
      if (!signature) {
        throw new Error('Failed to create token account');
      }
      
      this.log(`Created token account for ${this.#mintToSymbol(mint)}: ${signature}`, 'debug');
      
      // Verify account was created - with retries
      for (let i = 0; i < 3; i++) {
        try {
          const confirmedAccount = await this.#connection.getAccountInfo(associatedTokenAddress);
          if (confirmedAccount) {
            return true;
          }
          await new Promise(resolve => setTimeout(resolve, 1000));
        } catch (e) {
          if (i === 2) throw e;
          await new Promise(resolve => setTimeout(resolve, 1000));
        }
      }
      
      throw new Error('Token account creation not confirmed');
    } catch (error) {
      this.log(`Error creating token account for ${this.#mintToSymbol(mint)}: ${error.message}`, 'error');
      
      // Try one more time with a different RPC endpoint
      if (this.#rpcEndpoints.length > 1) {
        try {
          await this.#switchRpcEndpoint();
          return await this.ensureTokenAccount(mint);
        } catch (e) {
          this.log(`Retry failed: ${e.message}`, 'error');
        }
      }
      
      return false;
    }
  }

  /**
   * Execute a trade with Jupiter
   * @param {string} inputMint Input token mint
   * @param {string} outputMint Output token mint
   * @param {number} amount Amount to swap
   * @param {Object} quote Jupiter quote
   * @param {string} strategy Strategy name
   * @param {number} priceMovement Price movement percentage (for daily movers)
   * @returns {Promise<boolean>} Success or failure 
   */
  async executeTrade(inputMint, outputMint, amount, quote, strategy, priceMovement = 0) {
    try {
      const inputSymbol = this.#mintToSymbol(inputMint);
      const outputSymbol = this.#mintToSymbol(outputMint);
      const tradeType = strategy === 'ARBITRAGE' ? 'SWAP' : (inputMint === this.#tokenRegistry.USDC ? 'BUY' : 'SELL');

      // Validate minimum viable amount
      const inputPrice = await this.getTokenPrice(inputMint);
      const inputValueUsd = amount * inputPrice;
      const minViableUsd = 0.1; // $0.10 minimum value
      
      if (inputValueUsd < minViableUsd) {
        this.log(`Trade value too small: $${inputValueUsd.toFixed(4)} < $${minViableUsd}`, 'warn');
        return false;
      }

      // Get token decimals
      const inputDecimals = await this.getTokenDecimals(inputMint);
      const outputDecimals = await this.getTokenDecimals(outputMint);

      // Correctly format amounts with proper decimals
      const inputAmount = amount;
      const outputAmount = parseFloat(quote.outAmount) / Math.pow(10, outputDecimals);

      const tradeDetails = {
        timestamp: new Date().toISOString(),
        strategy,
        tradeType,
        input: {
          mint: inputMint,
          symbol: inputSymbol,
          amount: inputAmount
        },
        output: {
          mint: outputMint,
          symbol: outputSymbol,
          amount: outputAmount
        },
        priceMovement,
      };

      this.#totalTrades++;

      // In simulation mode, just log the trade
      if (this.#simulationMode) {
        this.notify(`[SIMULATION] [${strategy}] ${tradeType}: ${inputAmount.toFixed(6)} ${inputSymbol} → ${outputAmount.toFixed(6)} ${outputSymbol}`);
        this.#successfulTrades++;

        // Calculate profit/loss
        const outputPrice = await this.getTokenPrice(outputMint);
        const profit = (outputAmount * outputPrice) - (inputAmount * inputPrice);
        this.#profitLoss += profit;
        this.#currentBalanceUsd += profit;

        // Add to trade history
        tradeDetails.status = 'simulated';
        tradeDetails.profit = profit;
        this.#addTradeToHistory(tradeDetails);
        
        // Send Discord notification
        if (Math.abs(profit) > 0.01) {
          await this.sendDiscordSimulatedTradeNotification(tradeDetails, profit);
        }
        return true;
      }

      // Check if token accounts exist, create if needed
      const inputAccountExists = await this.ensureTokenAccount(inputMint);
      const outputAccountExists = await this.ensureTokenAccount(outputMint);

      if (!inputAccountExists || !outputAccountExists) {
        this.log(`Failed to ensure token accounts exist`, 'error');
        this.#failedTrades++;
        tradeDetails.status = 'failed';
        tradeDetails.error = 'Token account creation failed';
        this.#addTradeToHistory(tradeDetails);
        return false;
      }

      // Calculate adaptive slippage based on token properties
      const priceImpact = quote.priceImpactPct || 0;
      const adaptiveSlippage = this.#calculateAdaptiveSlippage(priceImpact, inputMint, outputMint);
      const slippageBps = Math.floor(adaptiveSlippage * 100);
      
      this.log(`Using adaptive slippage of ${adaptiveSlippage.toFixed(2)}% (${slippageBps} bps) for ${inputSymbol}-${outputSymbol}`, 'debug');

      // Create swap transaction
      const transaction = await this.#createSwapTransaction(quote, slippageBps);
      if (!transaction) {
        this.log(`Failed to create swap transaction`, 'error');
        this.#failedTrades++;
        tradeDetails.status = 'failed';
        tradeDetails.error = 'Failed to create transaction';
        this.#addTradeToHistory(tradeDetails);
        return false;
      }

      // Calculate estimated fee before sending
      const estimatedFeeInLamports = await this.#estimateTransactionFee();
      const solPrice = await this.getTokenPrice(this.#tokenRegistry.SOL);
      const estimatedFeeUsd = (estimatedFeeInLamports / 1e9) * solPrice;
      
      this.log(`Estimated transaction fee: ${estimatedFeeInLamports} lamports ($${estimatedFeeUsd.toFixed(4)})`, 'debug');

      // Pre-trade notification to Discord
      await this.sendDiscordNotification(
        `🔄 **EXECUTING TRADE**\n${strategy} ${tradeType}: ${inputAmount.toFixed(6)} ${inputSymbol} → ${outputAmount.toFixed(6)} ${outputSymbol}`,
        'info'
      );

      // Send and confirm transaction
      const txid = await this.#sendAndConfirmTransaction(transaction);
      if (!txid) {
        this.log(`Transaction failed to confirm`, 'error');
        this.#failedTrades++;
        tradeDetails.status = 'failed';
        tradeDetails.error = 'Transaction failed to confirm';
        this.#addTradeToHistory(tradeDetails);
        return false;
      }

      // Get enhanced transaction details from Helius
      const enhancedStatus = await this.checkTransactionStatus(txid);

      // Calculate profit/loss
      const outputPrice = await this.getTokenPrice(outputMint);
      const profit = (outputAmount * outputPrice) - (inputAmount * inputPrice);
      const profitWithFees = profit - estimatedFeeUsd;

      // Add to trade history with enhanced data
      tradeDetails.status = 'success';
      tradeDetails.txid = txid;
      tradeDetails.profit = profitWithFees;
      tradeDetails.enhancedData = {
        slot: enhancedStatus.slot,
        confirmedAt: new Date().toISOString(),
        fee: enhancedStatus.details?.fee || estimatedFeeInLamports,
        feeUsd: estimatedFeeUsd
      };

      this.#addTradeToHistory(tradeDetails);

      // Store the full transaction details separately
      if (enhancedStatus.details) {
        await this.#storeTransactionDetails(txid, enhancedStatus.details);
      }

      // Update stats
      this.#successfulTrades++;
      this.#profitLoss += profitWithFees;

      // Notify about the trade
      this.notify(`[${strategy}] ${tradeType} executed: ${inputAmount.toFixed(6)} ${inputSymbol} → ${outputAmount.toFixed(6)} ${outputSymbol} (${profitWithFees >= 0 ? '+' : ''}$${profitWithFees.toFixed(4)})`);
      
      // Send detailed Discord notification
      await this.sendDiscordTradeNotification({
        strategy,
        tradeType,
        inputAmount,
        inputSymbol,
        outputAmount,
        outputSymbol,
        profit: profitWithFees,
        txid,
        priceMovement
      });

      return true;
    } catch (error) {
      this.log(`Trade execution failed: ${error.message}`, 'error');
      this.#failedTrades++;

      // Add failed trade to history
      const tradeDetails = {
        timestamp: new Date().toISOString(),
        strategy,
        tradeType: strategy === 'ARBITRAGE' ? 'SWAP' : (inputMint === this.#tokenRegistry.USDC ? 'BUY' : 'SELL'),
        input: {
          mint: inputMint,
          symbol: this.#mintToSymbol(inputMint),
          amount
        },
        output: {
          mint: outputMint,
          symbol: this.#mintToSymbol(outputMint),
          amount: 0
        },
        status: 'failed',
        error: error.message,
        priceMovement,
      };

      this.#addTradeToHistory(tradeDetails);
      
      // Send Discord failure notification
      await this.sendDiscordNotification(
        `❌ **TRADE FAILED**\n${strategy} ${tradeDetails.tradeType}: ${amount.toFixed(6)} ${this.#mintToSymbol(inputMint)} → ${this.#mintToSymbol(outputMint)}\nError: ${error.message}`,
        'error'
      );
      
      return false;
    }
  }

  /**
   * Send Discord notification for a simulated trade
   * @param {Object} tradeDetails Trade details
   * @param {number} profit Trade profit/loss
   * @private
   */
  async sendDiscordSimulatedTradeNotification(tradeDetails, profit) {
    const { strategy, tradeType, input, output, priceMovement } = tradeDetails;
    
    let message = `[SIMULATION] `;
    
    if (strategy === 'ARBITRAGE') {
      message += `💰 **ARBITRAGE ${tradeType}**\n`;
    } else if (strategy === 'DAILY_MOVER') {
      const emoji = tradeType === 'BUY' ? '📉➡️📈' : '📈➡️💵';
      message += `${emoji} **DAILY MOVER ${tradeType}**\n`;
      if (priceMovement) {
        message += `+ Price Change: **${priceMovement.toFixed(2)}%**\n`;
      }
    } else if (strategy === 'STOP_LOSS') {
      message += `🛑 **STOP LOSS EXIT**\n`;
    }
    
    message += `+ Traded: ${input.amount.toFixed(6)} ${input.symbol} → ${output.amount.toFixed(6)} ${output.symbol}\n`;
    message += `+ Profit: **${profit >= 0 ? '+' : ''}$${profit.toFixed(4)}**`;
    
    await this.sendDiscordNotification(message, 'info');
  }

  /**
   * Add trade to history and manage history size
   * @param {Object} trade Trade details
   * @private 
   */
  #addTradeToHistory(trade) {
    // Add to in-memory history
    this.#tradeHistory.push(trade);

    // Limit history size
    if (this.#tradeHistory.length > this.#maxTradeHistoryLength) {
      this.#tradeHistory = this.#tradeHistory.slice(-this.#maxTradeHistoryLength);
    }

    // Queue trade storage to disk
    this.#queueFileOperation(async () => {
      try {
        const tradesFile = path.join(this.#dataDir, 'trades.json');
        await appendFileAsync(tradesFile, JSON.stringify(trade) + '\n');
      } catch (error) {
        this.log(`Error saving trade to history: ${error.message}`, 'error');
      }
    });

    // Update trade stats in storage
    this.#setStoredValue('totalTrades', this.#totalTrades.toString());
    this.#setStoredValue('successfulTrades', this.#successfulTrades.toString());
    this.#setStoredValue('failedTrades', this.#failedTrades.toString());
    this.#setStoredValue('profitLoss', this.#profitLoss.toString());
  }

  /**
   * Store detailed transaction data
   * @param {string} signature Transaction signature
   * @param {Object} details Transaction details
   * @private 
   */
  async #storeTransactionDetails(signature, details) {
    this.#queueFileOperation(async () => {
      try {
        const detailsDir = path.join(this.#dataDir, 'transactions');
        if (!fs.existsSync(detailsDir)) {
          fs.mkdirSync(detailsDir, { recursive: true });
        }
        
        const filePath = path.join(detailsDir, `${signature}.json`);
        const tempFilePath = `${filePath}.tmp`;
        
        // Write to temp file first to ensure atomic operation
        await writeFileAsync(tempFilePath, JSON.stringify(details, null, 2));
        await renameAsync(tempFilePath, filePath);
      } catch (error) {
        this.log(`Error storing transaction details: ${error.message}`, 'error');
      }
    });
  }

  /**
   * Get stored value from persistent storage
   * @param {string} key Storage key
   * @returns {string|null} Stored value or null
   * @private 
   */
  #getStoredValue(key) {
    try {
      const storageFile = path.join(this.#dataDir, 'storage.json');
      if (!fs.existsSync(storageFile)) {
        return null;
      }
      const data = JSON.parse(fs.readFileSync(storageFile, 'utf8'));
      return data[key] || null;
    } catch (error) {
      this.log(`Error reading from storage: ${error.message}`, 'error');
      return null;
    }
  }

  /**
   * Store value in persistent storage
   * @param {string} key Storage key
   * @param {string} value Value to store
   * @private 
   */
  #setStoredValue(key, value) {
    this.#queueFileOperation(async () => {
      try {
        const storageFile = path.join(this.#dataDir, 'storage.json');
        let data = {};
        
        if (fs.existsSync(storageFile)) {
          try {
            data = JSON.parse(fs.readFileSync(storageFile, 'utf8'));
          } catch (e) {
            this.log(`Error parsing storage file, creating new one: ${e.message}`, 'warn');
            data = {};
          }
        }
        
        data[key] = value;

        // Write atomically using temporary file
        const tempFile = `${storageFile}.tmp`;
        await writeFileAsync(tempFile, JSON.stringify(data, null, 2));
        await renameAsync(tempFile, storageFile);
      } catch (error) {
        this.log(`Error writing to storage: ${error.message}`, 'error');
      }
    });
  }

  /**
   * Switch to next RPC endpoint
   * @returns {Promise<boolean>} Success or failure
   * @private 
   */
  async #switchRpcEndpoint() {
    if (this.#rpcEndpoints.length <= 1) {
      this.log('No alternative RPC endpoints available', 'warn');
      return false;
    }

    // Calculate next endpoint index using round-robin
    const prevIndex = this.#currentRpcIndex;
    this.#currentRpcIndex = (this.#currentRpcIndex + 1) % this.#rpcEndpoints.length;
    
    // Check if we've tried all endpoints
    if (this.#currentRpcIndex === prevIndex) {
      this.log('Tried all RPC endpoints, none working properly', 'error');
      return false;
    }

    const newEndpoint = this.#rpcEndpoints[this.#currentRpcIndex];

    try {
      this.log(`Switching to RPC endpoint: ${newEndpoint}`, 'debug');
      
      // Create new connection
      const newConnection = new Connection(newEndpoint, {
        commitment: 'confirmed',
        confirmTransactionInitialTimeout: this.#transactionTimeoutMs,
        disableRetryOnRateLimit: false,
      });
      
      // Verify the connection works before switching
      try {
        const startTime = Date.now();
        await Promise.race([
          newConnection.getVersion(),
          new Promise((_, reject) => setTimeout(() => reject(new Error('Timeout')), 5000))
        ]);
        const responseTime = Date.now() - startTime;
        
        // Connection works, update the current connection
        this.#connection = newConnection;
        this.log(`Switched to ${newEndpoint} (${responseTime}ms response time)`, 'info');
        
        // Update the connection pool
        if (this.#connectionPool[this.#currentRpcIndex]) {
          this.#connectionPool[this.#currentRpcIndex] = newConnection;
        }
        
        // Clear cached fee estimates after changing endpoint
        this.#cachedFeeEstimate = null;
        
        return true;
      } catch (e) {
        this.log(`New endpoint ${newEndpoint} is unhealthy, trying next one`, 'warn');
        return await this.#switchRpcEndpoint(); // Recursively try the next one
      }
    } catch (error) {
      this.log(`Error switching to RPC endpoint ${newEndpoint}: ${error.message}`, 'error');
      return false;
    }
  }

  /**
   * Find arbitrage opportunities and execute trades
   * @returns {Promise<void>} 
   */
  async findArbitrageOpportunities() {
    // Skip if already running
    if (this.#isArbitrageRunning) {
      this.log('Arbitrage strategy already running, skipping', 'debug');
      return;
    }

    this.#isArbitrageRunning = true;

    try {
      this.log('Checking arbitrage opportunities...');
      
      // Skip if daily loss limit hit
      if (this.#hasHitDailyLossLimit()) {
        this.log('Daily loss limit reached, skipping arbitrage', 'warn');
        return;
      }
      
      // Calculate available capital
      const portfolioValue = await this.calculatePortfolioValue();
      const arbitrageCapital = portfolioValue * (this.#arbitrageAllocation / 100);
      const tradeRiskAmount = arbitrageCapital * (this.#riskPercentage / 100);
      
      this.log(`Arbitrage capital: $${arbitrageCapital.toFixed(2)}, Trade risk: $${tradeRiskAmount.toFixed(2)}`, 'debug');
      
      // Add SOL balance check to ensure we have enough for transaction fees
      const solBalance = await this.getTokenBalance(this.#tokenRegistry.SOL);
      const minimumSolRequired = 0.01; // 0.01 SOL for transaction fees
      
      if (solBalance < minimumSolRequired) {
        this.log(`Insufficient SOL for transaction fees: ${solBalance.toFixed(6)} SOL, needed: ${minimumSolRequired} SOL`, 'warn');
        
        // Send Discord notification for low SOL balance
        await this.sendDiscordNotification(
          `⚠️ **LOW SOL BALANCE**\nC
this.log(`Insufficient SOL for transaction fees: ${solBalance.toFixed(6)} SOL, needed: ${minimumSolRequired} SOL`, 'warn');
        
        // Send Discord notification for low SOL balance
        await this.sendDiscordNotification(
          `⚠️ **LOW SOL BALANCE**\nCurrent: ${solBalance.toFixed(6)} SOL\nRequired: ${minimumSolRequired} SOL\nPlease add SOL for transaction fees.`,
          'warn'
        );
        
        return;
      }
      
      // Check for arbitrage across all trading pairs
      for (const pair of this.#tradingPairs) {
        try {
          const [fromMint, toMint] = this.#parseTradingPair(pair);
          
          // Skip pairs with recent failed attempts (circuit breaker pattern)
          const pairKey = `${fromMint}-${toMint}`;
          const lastFailTime = parseInt(this.#getStoredValue(`lastFail_${pairKey}`) || '0');
          const backoffPeriod = parseInt(this.#getStoredValue(`backoff_${pairKey}`) || '60000');
          
          if (Date.now() - lastFailTime < backoffPeriod) {
            this.log(`Skipping recently failed pair ${pair} (in backoff period)`, 'debug');
            continue;
          }
          
          // Check token balances
          const fromBalance = await this.getTokenBalance(fromMint);
          if (fromBalance <= 0) {
            this.log(`No balance for ${this.#mintToSymbol(fromMint)}, skipping pair ${pair}`, 'debug');
            continue;
          }
          
          // Check if token has hit stop loss
          const fromPrice = await this.getTokenPrice(fromMint);
          const fromValueUsd = fromBalance * fromPrice;
          
          const stopLossCheck = await this.checkStopLoss(fromMint, fromValueUsd);
          if (stopLossCheck.triggered) {
            this.log(`Stop loss triggered for ${this.#mintToSymbol(fromMint)}, executing exit trade`, 'warn');
            await this.executeStopLossExit(fromMint);
            continue;
          }
          
          // Calculate trade size - adjust based on token-specific min amounts
          const minViableAmount = this.#minimumViableAmounts[fromMint] || 0.001;
          const tradeSize = Math.max(
            Math.min(tradeRiskAmount / fromPrice, fromBalance * 0.98),
            minViableAmount
          );
          
          if (tradeSize * fromPrice < 0.1) { // Ensure at least $0.10 worth
            this.log(`Trade size too small for ${pair}, skipping`, 'debug');
            continue;
          }
          
          this.log(`Checking arbitrage for ${pair} with size ${tradeSize.toFixed(6)} ${this.#mintToSymbol(fromMint)}`, 'debug');
          
          // Get quote
          const quote = await this.getJupiterQuote(fromMint, toMint, tradeSize);
          if (!quote) {
            // Record failure with exponential backoff
            const currentBackoff = parseInt(this.#getStoredValue(`backoff_${pairKey}`) || '60000');
            const newBackoff = Math.min(currentBackoff * 2, 3600000); // Max 1 hour
            this.#setStoredValue(`lastFail_${pairKey}`, Date.now().toString());
            this.#setStoredValue(`backoff_${pairKey}`, newBackoff.toString());
            
            this.log(`Failed to get quote for ${pair}, backoff increased to ${newBackoff/1000}s`, 'warn');
            continue;
          }
          
          // Reset backoff on successful quote
          this.#setStoredValue(`backoff_${pairKey}`, '60000');
          
          // Calculate profit
          const outAmount = parseFloat(quote.outAmount) / Math.pow(10, await this.getTokenDecimals(toMint));
          const toPrice = await this.getTokenPrice(toMint);
          
          const inputValue = tradeSize * fromPrice;
          const outputValue = outAmount * toPrice;
          const profitPercentage = ((outputValue - inputValue) / inputValue) * 100;
          
          // Estimate transaction fee
          const estimatedFeeInLamports = await this.#estimateTransactionFee();
          const solPrice = await this.getTokenPrice(this.#tokenRegistry.SOL);
          const transactionFeeUsd = (estimatedFeeInLamports / 1e9) * solPrice;
          
          // Calculate net profit after fees
          const netProfitUsd = outputValue - inputValue - transactionFeeUsd;
          const netProfitPercentage = (netProfitUsd / inputValue) * 100;
          
          this.log(`${pair} arbitrage: ${profitPercentage.toFixed(2)}% profit (${netProfitPercentage.toFixed(2)}% after fees)`, 'debug');
          
          // Execute if profitable
          if (netProfitPercentage > this.#minProfitThreshold) {
            this.log(`Executing arbitrage for ${pair} with ${netProfitPercentage.toFixed(2)}% profit`);
            const success = await this.executeTrade(fromMint, toMint, tradeSize, quote, 'ARBITRAGE');
            
            if (success) {
              // Send Discord notification with detailed info
              await this.sendDiscordTradeNotification({
                strategy: 'ARBITRAGE',
                tradeType: 'SWAP',
                inputAmount: tradeSize,
                inputSymbol: this.#mintToSymbol(fromMint),
                outputAmount: outAmount,
                outputSymbol: this.#mintToSymbol(toMint),
                profit: netProfitUsd,
                profitPercent: netProfitPercentage
              });
            }
            
            // Wait a bit after successful trade
            await new Promise(resolve => setTimeout(resolve, 5000));
          }
        } catch (e) {
          this.log(`Error checking arbitrage for ${pair}: ${e.message}`, 'error');
        }
      }
    } catch (error) {
      this.log(`Error in arbitrage strategy: ${error.message}`, 'error');
    } finally {
      this.#isArbitrageRunning = false;
    }
  }

  /**
   * Get token price movements with market volatility monitoring
   * @returns {Promise<Map<string, Object>>} Map of token price movements 
   */
  async getTokenPriceMovements() {
    try {
      // Create set of unique tokens
      const uniqueTokens = new Set();

      // Add all tokens from trading pairs
      this.#tradingPairs.forEach(pair => {
        const [fromMint, toMint] = this.#parseTradingPair(pair);
        uniqueTokens.add(fromMint);
        uniqueTokens.add(toMint);
      });

      // Add major tokens
      Object.values(this.#tokenRegistry).forEach(mint => uniqueTokens.add(mint));

      // Create comma-separated list of mints
      const mints = Array.from(uniqueTokens).join(',');

      // Use circuit breaker for Jupiter Price API
      return await this.#jupiterQuoteCircuitBreaker.execute(
        async () => {
          const controller = new AbortController();
          const timeoutId = setTimeout(() => controller.abort(), 15000);
          
          try {
            const response = await fetch(`https://price.jup.ag/v4/price?ids=${mints}`, {
              signal: controller.signal
            });
            clearTimeout(timeoutId);
    
            if (!response.ok) throw new Error(`Price API error: ${response.status}`);
            const data = await response.json();
    
            // Process results
            const movements = new Map();
            let marketVolatilitySum = 0;
            let volatileTokenCount = 0;
            
            for (const mint of uniqueTokens) {
              const tokenData = data.data[mint] || {};
              const priceChange = (tokenData.priceChange24h || 0) * 100;
              
              // Track market volatility (excluding stablecoins)
              if (!this.#isStablecoin(mint) && tokenData.price > 0) {
                marketVolatilitySum += Math.abs(priceChange);
                volatileTokenCount++;
              }
              
              movements.set(mint, {
                priceChange24h: priceChange,
                volume24h: tokenData.volume24h || 0,
                price: tokenData.price || 0
              });
            }
            
            // Calculate average market volatility
            const avgMarketVolatility = volatileTokenCount > 0 ? 
              marketVolatilitySum / volatileTokenCount : 0;
            
            // Store market volatility for reference
            this.#setStoredValue('marketVolatility', avgMarketVolatility.toString());
            
            if (avgMarketVolatility > 10) {
              this.log(`High market volatility detected: ${avgMarketVolatility.toFixed(2)}%`, 'warn');
              // Send warning for extremely volatile markets
              if (avgMarketVolatility > 15) {
                await this.sendDiscordNotification(
                  `⚠️ **HIGH MARKET VOLATILITY ALERT**\nAverage 24h price change: ${avgMarketVolatility.toFixed(2)}%\nTrading with extra caution`,
                  'warn'
                );
              }
            }
            
            return movements;
          } catch (error) {
            clearTimeout(timeoutId);
            throw error;
          }
        },
        async () => {
          // Fallback when circuit is open
          this.log('Price API circuit breaker open, using fallback', 'warn');
          return new Map();
        }
      );
    } catch (e) {
      this.log(`Error fetching price movements: ${e.message}`, 'error');
      return new Map();
    }
  }

  /**
   * Find and execute daily movers opportunities
   * @returns {Promise<void>} 
   */
  async findDailyMoversOpportunities() {
    // Skip if already running
    if (this.#isDailyMoversRunning) {
      this.log('Daily movers strategy already running, skipping', 'debug');
      return;
    }

    this.#isDailyMoversRunning = true;

    try {
      this.log('Scanning for daily movers...');
      
      // Skip if daily loss limit hit
      if (this.#hasHitDailyLossLimit()) {
        this.log('Daily loss limit reached, skipping daily movers', 'warn');
        return;
      }
      
      // Calculate available capital
      const portfolioValue = await this.calculatePortfolioValue();
      const dailyMoverCapital = portfolioValue * (this.#dailyMoversAllocation / 100);
      const tradeRiskAmount = dailyMoverCapital * (this.#riskPercentage / 100);
      
      this.log(`Daily movers capital: $${dailyMoverCapital.toFixed(2)}, Trade risk: $${tradeRiskAmount.toFixed(2)}`, 'debug');
      
      // Add SOL balance check to ensure we have enough for transaction fees
      const solBalance = await this.getTokenBalance(this.#tokenRegistry.SOL);
      const minimumSolRequired = 0.01; // 0.01 SOL for transaction fees
      
      if (solBalance < minimumSolRequired) {
        this.log(`Insufficient SOL for transaction fees: ${solBalance.toFixed(6)} SOL, needed: ${minimumSolRequired} SOL`, 'warn');
        return;
      }
      
      // Get price movements
      const tokenMovements = await this.getTokenPriceMovements();
      
      // Check market volatility and adjust threshold
      const marketVolatility = parseFloat(this.#getStoredValue('marketVolatility') || '0');
      let adjustedThreshold = this.#dailyMoverThreshold;
      
      // In highly volatile markets, increase threshold to avoid false signals
      if (marketVolatility > 12) {
        adjustedThreshold = this.#dailyMoverThreshold * 1.5;
        this.log(`Increased daily mover threshold to ${adjustedThreshold.toFixed(1)}% due to high market volatility`, 'info');
      }
      
      // Filter for significant movers
      const significantMovers = [...tokenMovements.entries()]
        .filter(([mint, data]) => {
          // Skip stablecoins
          if (this.#isStablecoin(mint)) return false;
          
          // Skip tokens with insufficient price data
          if (!data.price || data.price === 0) return false;
          
          // Check for significant movement and volume
          const significantMove = Math.abs(data.priceChange24h) >= adjustedThreshold;
          const sufficientVolume = data.volume24h > 50000; // $50k minimum volume
          
          return significantMove && sufficientVolume;
        })
        .sort((a, b) => Math.abs(b[1].priceChange24h) - Math.abs(a[1].priceChange24h));
      
      if (significantMovers.length === 0) {
        this.log('No significant daily movers found', 'debug');
        return;
      }
      
      this.log(`Found ${significantMovers.length} significant daily movers`);
      
      // Send Discord notification with found movers
      if (significantMovers.length > 0) {
        let moversMessage = `📊 **DAILY MOVERS DETECTED**\n`;
        significantMovers.slice(0, 5).forEach(([mint, data], index) => {
          const symbol = this.#mintToSymbol(mint);
          const change = data.priceChange24h.toFixed(2);
          const direction = data.priceChange24h > 0 ? '📈' : '📉';
          moversMessage += `${index+1}. ${direction} **${symbol}**: ${change}% ($${(data.volume24h/1000).toFixed(0)}k vol)\n`;
        });
        
        if (significantMovers.length > 5) {
          moversMessage += `...and ${significantMovers.length - 5} more`;
        }
        
        await this.sendDiscordNotification(moversMessage, 'info');
      }
      
      // Process each significant mover
      for (const [mint, data] of significantMovers) {
        const symbol = this.#mintToSymbol(mint);
        this.log(`${symbol}: ${data.priceChange24h.toFixed(2)}% price change, $${data.volume24h.toFixed(0)} volume`, 'debug');
        
        // Determine trade direction:
        // - Negative price change: BUY (price dropped, expect recovery)
        // - Positive price change: SELL (price jumped, take profit)
        const direction = data.priceChange24h <= -adjustedThreshold ? 'BUY' : 'SELL';
        
        // For BUY: use USDC as source
        // For SELL: use the token as source
        const fromMint = direction === 'BUY' ? this.#tokenRegistry.USDC : mint;
        const toMint = direction === 'BUY' ? mint : this.#tokenRegistry.USDC;
        
        const success = await this.tradeDailyMover(fromMint, toMint, data.priceChange24h, direction, tradeRiskAmount);
        
        if (success) {
          // Wait a bit between trades
          await new Promise(resolve => setTimeout(resolve, 5000));
        }
      }
    } catch (error) {
      this.log(`Error in daily movers strategy: ${error.message}`, 'error');
    } finally {
      this.#isDailyMoversRunning = false;
    }
  }

  /**
   * Execute trade for daily mover strategy
   * @param {string} fromMint From token mint
   * @param {string} toMint To token mint
   * @param {number} priceChange Price change percentage
   * @param {string} direction Trade direction (BUY/SELL)
   * @param {number} maxTradeSize Maximum trade size in USD
   * @returns {Promise<boolean>} Success or failure 
   */
  async tradeDailyMover(fromMint, toMint, priceChange, direction, maxTradeSize) {
    try {
      const fromSymbol = this.#mintToSymbol(fromMint);
      const toSymbol = this.#mintToSymbol(toMint);
      
      this.log(`Evaluating ${direction} opportunity for ${fromSymbol} → ${toSymbol} (${priceChange.toFixed(2)}% move)`);
      
      // Check balance
      const fromBalance = await this.getTokenBalance(fromMint);
      if (fromBalance <= 0) {
        this.log(`No balance for ${fromSymbol}, skipping trade`, 'debug');
        return false;
      }
      
      // Check if token has hit stop loss
      const fromPrice = await this.getTokenPrice(fromMint);
      const fromValueUsd = fromBalance * fromPrice;
      
      const stopLossCheck = await this.checkStopLoss(fromMint, fromValueUsd);
      if (stopLossCheck.triggered) {
        this.log(`Stop loss triggered for ${fromSymbol}, executing exit trade`, 'warn');
        await this.executeStopLossExit(fromMint);
        return false;
      }
      
      // Calculate safe trade size (accounting for token-specific min amounts)
      const minViableAmount = this.#minimumViableAmounts[fromMint] || 0.001;
      const maxSafeAmount = fromBalance * 0.98; // Leave 2% to account for price fluctuations
      
      // Determine optimal trade size
      let tradeSize;
      if (direction === 'BUY') {
        // For buys, use a percentage of the max trade size to diversify risk
        const buyPercentage = Math.min(30 + Math.abs(priceChange), 70) / 100; // 30-70% based on price drop
        tradeSize = Math.min(maxTradeSize * buyPercentage / fromPrice, maxSafeAmount);
      } else {
        // For sells, use a higher percentage of available balance to lock in profits
        const sellPercentage = Math.min(50 + Math.abs(priceChange) / 2, 90) / 100; // 50-90% based on price jump
        tradeSize = Math.min(maxSafeAmount * sellPercentage, maxTradeSize / fromPrice);
      }
      
      // Ensure minimum viable amount
      tradeSize = Math.max(tradeSize, minViableAmount);
      
      if (tradeSize * fromPrice < 0.1) { // Ensure at least $0.10 value
        this.log(`Trade size too small for ${fromSymbol}, skipping`, 'debug');
        return false;
      }
      
      // Get quote
      const quote = await this.getJupiterQuote(fromMint, toMint, tradeSize);
      if (!quote) {
        this.log(`Failed to get quote for ${fromSymbol} → ${toSymbol}`, 'warn');
        return false;
      }
      
      // Calculate output
      const outAmount = parseFloat(quote.outAmount) / Math.pow(10, await this.getTokenDecimals(toMint));
      const toPrice = await this.getTokenPrice(toMint);
      
      // Determine if trade is favorable
      let shouldTrade = false;
      
      if (direction === 'BUY') {
        // For buys, check execution price vs expected
        const executionPriceChange = ((tradeSize * fromPrice / outAmount) - toPrice) / toPrice * 100;
        
        // Trade is favorable if execution price is within 3% of market price
        shouldTrade = Math.abs(executionPriceChange) < 3.0;
        
        // Additional check for severe price drops (>15%) to avoid catching falling knives
        if (priceChange < -15 && !this.#getStoredValue(`confirmed_drop_${toMint}`)) {
          // Only buy after confirming the drop in a second scan
          this.#setStoredValue(`confirmed_drop_${toMint}`, 'true');
          this.log(`Large price drop for ${toSymbol} (${priceChange.toFixed(2)}%), waiting for confirmation`, 'warn');
          shouldTrade = false;
        }
      } else {
        // For sells, always execute to lock in profits, unless execution price is terrible
        const executionPriceChange = (toPrice - (outAmount / tradeSize)) / toPrice * 100;
        shouldTrade = executionPriceChange < 5.0; // Allow up to 5% slippage for sells
      }
      
      if (shouldTrade) {
        this.log(`Executing ${direction} for ${fromSymbol} → ${toSymbol} (${priceChange.toFixed(2)}% move)`);
        return await this.executeTrade(fromMint, toMint, tradeSize, quote, 'DAILY_MOVER', priceChange);
      } else {
        this.log(`Skipping ${direction} for ${fromSymbol} → ${toSymbol} - unfavorable execution`, 'debug');
        return false;
      }
    } catch (error) {
      this.log(`Error in daily mover trade: ${error.message}`, 'error');
      return false;
    }
  }

