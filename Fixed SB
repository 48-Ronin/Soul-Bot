// Manages storage operations with queueing to prevent concurrent writes
class StorageManager {
  constructor(dataDir) {
    this.dataDir = dataDir || path.join(os.homedir(), '.solana-bot');
    this.logsDir = path.join(this.dataDir, 'logs');
    this.transactionsDir = path.join(this.dataDir, 'transactions');
    this.writeQueue = [];
    this.isProcessingQueue = false;
    this.setupDirectories();
  }

  setupDirectories() {
    try {
      [this.dataDir, this.logsDir, this.transactionsDir].forEach(dir => {
        if (!fs.existsSync(dir)) {
          fs.mkdirSync(dir, { recursive: true });
          console.log(`Created directory: ${dir}`);
        }
      });
    } catch (error) {
      console.error(`Failed to create directories: ${error.message}`);
    }
  }

  queueFileOperation(operation) {
    this.writeQueue.push(operation);
    if (!this.isProcessingQueue) {
      this.processWriteQueue();
    }
  }

  async processWriteQueue() {
    if (this.isProcessingQueue || this.writeQueue.length === 0) {
      return;
    }
    
    this.isProcessingQueue = true;
    
    try {
      while (this.writeQueue.length > 0) {
        const operation = this.writeQueue.shift();
        await operation();
      }
    } catch (error) {
      console.error('Error processing write queue:', error.message);
    } finally {
      this.isProcessingQueue = false;
    }
  }

  queueLogWrite(message) {
    this.queueFileOperation(async () => {
      try {
        const logFile = path.join(this.logsDir, `bot-${new Date().toISOString().split('T')[0]}.log`);
        await appendFileAsync(logFile, message + '\n');
      } catch (e) {
        console.error('Failed to write to log file:', e.message);
      }
    });
  }

  getStoredValue(key) {
    try {
      const storageFile = path.join(this.dataDir, 'storage.json');
      if (!fs.existsSync(storageFile)) {
        return null;
      }
      const data = JSON.parse(fs.readFileSync(storageFile, 'utf8'));
      return data[key] || null;
    } catch (error) {
      console.error(`Error reading from storage: ${error.message}`);
      return null;
    }
  }

  setStoredValue(key, value) {
    this.queueFileOperation(async () => {
      try {
        const storageFile = path.join(this.dataDir, 'storage.json');
        let data = {};
        
        if (fs.existsSync(storageFile)) {
          try {
            data = JSON.parse(fs.readFileSync(storageFile, 'utf8'));
          } catch (e) {
            console.warn(`Error parsing storage file, creating new one: ${e.message}`);
            data = {};
          }
        }
        
        data[key] = value;
        const tempFile = `${storageFile}.tmp`;
        await writeFileAsync(tempFile, JSON.stringify(data, null, 2));
        await renameAsync(tempFile, storageFile);
      } catch (error) {
        console.error(`Error writing to storage: ${error.message}`);
      }
    });
  }

  storeTransactionDetails(signature, details) {
    this.queueFileOperation(async () => {
      try {
        const filePath = path.join(this.transactionsDir, `${signature}.json`);
        const tempFilePath = `${filePath}.tmp`;
        await writeFileAsync(tempFilePath, JSON.stringify(details, null, 2));
        await renameAsync(tempFilePath, filePath);
      } catch (error) {
        console.error(`Error storing transaction details: ${error.message}`);
      }
    });
  }
}

// Manages RPC connections and health checks
class RpcManager {
  constructor(endpoints) {
    this.endpoints = Array.isArray(endpoints) ? endpoints : [endpoints];
    this.connectionPool = [];
    this.currentIndex = 0;
    this.connection = null;
    this.healthTimeout = 5000;
    this.transactionTimeoutMs = 60000;
  }

  async initializeConnectionPool() {
    console.log('Initializing RPC connection pool...');
    
    const healthResults = await Promise.all(
      this.endpoints.map(async (endpoint, index) => {
        try {
          const connection = new Connection(endpoint, {
            commitment: 'confirmed',
            confirmTransactionInitialTimeout: this.transactionTimeoutMs,
            disableRetryOnRateLimit: false,
          });
          
          const startTime = Date.now();
          await Promise.race([
            connection.getVersion(),
            new Promise((_, reject) => 
              setTimeout(() => reject(new Error('Timeout')), this.healthTimeout)
            )
          ]);
          const responseTime = Date.now() - startTime;
          
          return { endpoint, connection, healthy: true, responseTime, index };
        } catch (error) {
          console.warn(`Endpoint ${endpoint} is unhealthy: ${error.message}`);
          return { endpoint, healthy: false, responseTime: Infinity, index };
        }
      })
    );
    
    const healthyEndpoints = healthResults
      .filter(result => result.healthy)
      .sort((a, b) => a.responseTime - b.responseTime);
    
    if (healthyEndpoints.length === 0) {
      throw new Error('No healthy RPC endpoints available');
    }
    
    this.connectionPool = healthyEndpoints.map(result => result.connection);
    this.connection = this.connectionPool[0];
    this.currentIndex = healthyEndpoints[0].index;
    
    console.log(`Selected ${this.endpoints[this.currentIndex]} as primary endpoint`);
    console.log(`Connection pool initialized with ${this.connectionPool.length} healthy endpoints`);
    
    return this.connection;
  }

  async switchEndpoint() {
    if (this.endpoints.length <= 1) {
      console.warn('No alternative RPC endpoints available');
      return false;
    }

    const prevIndex = this.currentIndex;
    this.currentIndex = (this.currentIndex + 1) % this.endpoints.length;
    
    if (this.currentIndex === prevIndex) {
      console.error('Tried all RPC endpoints, none working properly');
      return false;
    }

    const newEndpoint = this.endpoints[this.currentIndex];

    try {
      console.log(`Switching to RPC endpoint: ${newEndpoint}`);
      
      const newConnection = new Connection(newEndpoint, {
        commitment: 'confirmed',
        confirmTransactionInitialTimeout: this.transactionTimeoutMs,
        disableRetryOnRateLimit: false,
      });
      
      try {
        const startTime = Date.now();
        await Promise.race([
          newConnection.getVersion(),
          new Promise((_, reject) => setTimeout(() => reject(new Error('Timeout')), 5000))
        ]);
        const responseTime = Date.now() - startTime;
        
        this.connection = newConnection;
        console.log(`Switched to ${newEndpoint} (${responseTime}ms response time)`);
        
        if (this.connectionPool[this.currentIndex]) {
          this.connectionPool[this.currentIndex] = newConnection;
        }
        
        return true;
      } catch (e) {
        console.warn(`New endpoint ${newEndpoint} is unhealthy, trying next one`);
        return await this.switchEndpoint();
      }
    } catch (error) {
      console.error(`Error switching to RPC endpoint ${newEndpoint}: ${error.message}`);
      return false;
    }
  }

  async checkHealth() {
    try {
      const startTime = Date.now();
      await Promise.race([
        this.connection.getVersion(),
        new Promise((_, reject) => setTimeout(() => reject(new Error('RPC Timeout')), this.healthTimeout))
      ]);
      const responseTime = Date.now() - startTime;
      
      if (responseTime > 2000) {
        console.warn(`RPC endpoint responding slowly: ${responseTime}ms`);
      }
      
      return true;
    } catch (error) {
      console.error(`RPC health check failed: ${error.message}`);
      return false;
    }
  }

  addEndpoint(endpoint) {
    if (!this.endpoints.includes(endpoint)) {
      this.endpoints.push(endpoint);
      console.log(`Added RPC endpoint: ${endpoint}`);
      
      // Test the new endpoint
      try {
        const connection = new Connection(endpoint, {
          commitment: 'confirmed',
          confirmTransactionInitialTimeout: this.transactionTimeoutMs,
          disableRetryOnRateLimit: false,
        });
        
        this.connectionPool.push(connection);
        return true;
      } catch (error) {
        console.warn(`Warning: New RPC endpoint failed health check: ${error.message}`);
        return false;
      }
    }
    return false;
  }

  getCurrentEndpoint() {
    return this.endpoints[this.currentIndex];
  }
}

// Manages wallet initialization and operations
class WalletManager {
  static initializeWallet(config) {
    try {
      let privateKeyData;
      if (config.privateKeyPath) {
        privateKeyData = fs.readFileSync(config.privateKeyPath, 'utf8').trim();
        if (privateKeyData.startsWith('[') && privateKeyData.endsWith(']')) {
          privateKeyData = JSON.parse(privateKeyData);
        } else if (privateKeyData.includes(',')) {
          privateKeyData = privateKeyData.split(',').map(num => parseInt(num.trim()));
        }
      } else {
        privateKeyData = config.privateKey;
      }
      
      if (typeof privateKeyData === 'string') {
        if (privateKeyData.match(/^[A-HJ-NP-Za-km-z1-9]*$/)) {
          privateKeyData = bs58.decode(privateKeyData);
        } else {
          privateKeyData = Buffer.from(privateKeyData, 'hex');
        }
      }

      return Keypair.fromSecretKey(
        Array.isArray(privateKeyData) ? Uint8Array.from(privateKeyData) : privateKeyData
      );
    } catch (error) {
      throw new Error(`Invalid private key: ${error.message}`);
    }
  }
}

// Tracks trading statistics
class TradingStats {
  constructor(storage) {
    this.storage = storage;
    this.totalTrades = 0;
    this.successfulTrades = 0;
    this.failedTrades = 0;
    this.profitLoss = 0;
    this.startingBalanceUsd = 0;
    this.currentBalanceUsd = 0;
    this.dailyStartBalance = 0;
    this.dailyPnL = 0;
    this.dailyBalances = [];
    this.tradeHistory = [];
    this.maxTradeHistoryLength = 1000;
  }

  async loadHistoricalData() {
    // Load trade history
    try {
      const tradesFile = path.join(this.storage.dataDir, 'trades.json');
      if (fs.existsSync(tradesFile)) {
        const content = fs.readFileSync(tradesFile, 'utf8');
        if (content) {
          const lines = content.split('\n').filter(line => line.trim());
          const trades = lines
            .map(line => {
              try { return JSON.parse(line); }
              catch (e) { return null; }
            })
            .filter(Boolean);
          
          this.tradeHistory = trades.slice(-this.maxTradeHistoryLength);
          console.log(`Loaded ${this.tradeHistory.length} historical trades`);
        }
      }
    } catch (e) {
      console.warn(`Error loading trade history: ${e.message}`);
    }
    
    // Load daily balances
    try {
      const dailyBalancesStr = this.storage.getStoredValue('dailyBalances');
      if (dailyBalancesStr) {
        this.dailyBalances = JSON.parse(dailyBalancesStr);
      }
    } catch (e) {
      console.warn(`Error loading daily balances: ${e.message}`);
    }
    
    // Load trade statistics
    this.totalTrades = parseInt(this.storage.getStoredValue('totalTrades') || '0');
    this.successfulTrades = parseInt(this.storage.getStoredValue('successfulTrades') || '0');
    this.failedTrades = parseInt(this.storage.getStoredValue('failedTrades') || '0');
    this.profitLoss = parseFloat(this.storage.getStoredValue('profitLoss') || '0');
  }

  addTradeToHistory(trade) {
    this.tradeHistory.push(trade);

    if (this.tradeHistory.length > this.maxTradeHistoryLength) {
      this.tradeHistory = this.tradeHistory.slice(-this.maxTradeHistoryLength);
    }

    this.storage.queueFileOperation(async () => {
      try {
        const tradesFile = path.join(this.storage.dataDir, 'trades.json');
        await appendFileAsync(tradesFile, JSON.stringify(trade) + '\n');
      } catch (error) {
        console.error(`Error saving trade to history: ${error.message}`);
      }
    });

    // Update trade stats in storage
    this.storage.setStoredValue('totalTrades', this.totalTrades.toString());
    this.storage.setStoredValue('successfulTrades', this.successfulTrades.toString());
    this.storage.setStoredValue('failedTrades', this.failedTrades.toString());
    this.storage.setStoredValue('profitLoss', this.profitLoss.toString());
  }

  getTradeHistory(limit = 100) {
    const tradeCount = this.tradeHistory.length;
    return this.tradeHistory.slice(Math.max(0, tradeCount - limit), tradeCount);
  }

  recordSuccessfulTrade(trade, profit) {
    this.successfulTrades++;
    this.totalTrades++;
    this.profitLoss += profit;
    this.addTradeToHistory(trade);
  }

  recordFailedTrade(trade) {
    this.failedTrades++;
    this.totalTrades++;
    this.addTradeToHistory(trade);
  }
}

// Jupiter API client
class JupiterApiClient {
  constructor() {
    this.apiUrl = 'https://quote-api.jup.ag/v6';
    this.quoteCircuitBreaker = new CircuitBreaker(60000, 5, 30000);
    this.swapCircuitBreaker = new CircuitBreaker(60000, 3, 60000);
    this.priceCache = new Map();
    this.priceCacheTTL = 60 * 1000; // 60 seconds
  }

  async getQuote(inputMint, outputMint, amount, slippageBps = 50) {
    try {
      const params = new URLSearchParams({
        inputMint,
        outputMint,
        amount: amount.toString(),
        slippageBps: slippageBps.toString(),
        feeBps: '4',
        onlyDirectRoutes: 'false',
        asLegacyTransaction: 'false',
      });

      return await this.quoteCircuitBreaker.execute(
        async () => {
          const MAX_RETRIES = 3;
          let lastError = null;
          
          for (let attempt = 0; attempt < MAX_RETRIES; attempt++) {
            try {
              const controller = new AbortController();
              const timeoutId = setTimeout(() => controller.abort(), 15000);
              
              const response = await fetch(`${this.apiUrl}/quote?${params}`, {
                signal: controller.signal
              });
              clearTimeout(timeoutId);
      
              if (!response.ok) {
                throw new Error(`Jupiter API error: ${response.status} ${response.statusText}`);
              }
              
              const quote = await response.json();
              if (!quote || !quote.outAmount) {
                throw new Error('Invalid quote response');
              }
              
              return quote;
            } catch (error) {
              lastError = error;
              
              if (error.name === 'AbortError') {
                console.warn('Jupiter quote API request timed out');
              } else {
                console.warn(`Jupiter quote error (attempt ${attempt+1}/${MAX_RETRIES}): ${error.message}`);
              }
              
              if (attempt < MAX_RETRIES - 1) {
                const backoffMs = Math.pow(2, attempt) * 1000;
                await new Promise(resolve => setTimeout(resolve, backoffMs));
              }
            }
          }
          
          throw lastError || new Error('Failed to get Jupiter quote after multiple attempts');
        },
        async () => {
          console.warn('Jupiter quote API circuit breaker open, using fallback method');
          return null;
        }
      );
    } catch (error) {
      console.error(`Error in getJupiterQuote: ${error.message}`);
      return null;
    }
  }

  async createSwapTransaction(route, userPublicKey, slippageBps) {
    try {
      return await this.swapCircuitBreaker.execute(
        async () => {
          const MAX_RETRIES = 2;
          let lastError = null;
          
          for (let attempt = 0; attempt < MAX_RETRIES; attempt++) {
            try {
              const controller = new AbortController();
              const timeoutId = setTimeout(() => controller.abort(), 30000);
              
              const response = await fetch(`${this.apiUrl}/swap`, {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                  route: route,
                  userPublicKey: userPublicKey.toString(),
                  slippageBps
                }),
                signal: controller.signal
              });
              clearTimeout(timeoutId);
      
              if (!response.ok) {
                throw new Error(`Jupiter swap API error: ${response.status}`);
              }
      
              const swapData = await response.json();
              if (!swapData || !swapData.swapTransaction) {
                throw new Error('No swap transaction received from Jupiter');
              }
              
              return swapData.swapTransaction;
            } catch (error) {
              lastError = error;
              
              if (error.name === 'AbortError') {
                console.warn('Jupiter swap API request timed out');
              } else {
                console.warn(`Error creating swap transaction (attempt ${attempt+1}/${MAX_RETRIES}): ${error.message}`);
              }
              
              if (attempt < MAX_RETRIES - 1) {
                const backoffMs = Math.pow(2, attempt) * 2000;
                await new Promise(resolve => setTimeout(resolve, backoffMs));
              }
            }
          }
          
          throw lastError || new Error('Failed to create swap transaction after multiple attempts');
        },
        async () => {
          console.error('Jupiter swap API circuit breaker open, cannot create transaction');
          return null;
        }
      );
    } catch (error) {
      console.error(`Error in createSwapTransaction: ${error.message}`);
      return null;
    }
  }

  async getTokenPrices(mints) {
    try {
      // Filter for tokens that need price updates
      const now = Date.now();
      const mintsToFetch = [];
      
      for (const mint of mints) {
        const cached = this.priceCache.get(mint);
        if (!cached || (now - cached.timestamp) >= this.priceCacheTTL) {
          mintsToFetch.push(mint);
        }
      }
      
      if (mintsToFetch.length === 0) {
        // Return cached prices
        return new Map(mints.map(mint => [
          mint, 
          this.priceCache.get(mint)?.data || { price: 0, priceChange24h: 0 }
        ]));
      }
      
      // Create comma-separated list of mints
      const mintsList = mintsToFetch.join(',');
      
      return await this.quoteCircuitBreaker.execute(
        async () => {
          const controller = new AbortController();
          const timeoutId = setTimeout(() => controller.abort(), 15000);
          
          try {
            const response = await fetch(`https://price.jup.ag/v4/price?ids=${mintsList}`, {
              signal: controller.signal
            });
            clearTimeout(timeoutId);
    
            if (!response.ok) throw new Error(`Price API error: ${response.status}`);
            const responseData = await response.json();
    
            // Process and cache results
            const results = new Map();
            for (const mint of mints) {
              const tokenData = responseData.data?.[mint] || {};
              
              // Cache the response
              if (mintsToFetch.includes(mint) && tokenData.price) {
                this.priceCache.set(mint, {
                  data: {
                    price: tokenData.price || 0,
                    priceChange24h: (tokenData.priceChange24h || 0) * 100,
                    volume24h: tokenData.volume24h || 0
                  },
                  timestamp: now
                });
              }
              
              // Use either new data or cached data
              results.set(mint, 
                this.priceCache.get(mint)?.data || 
                { price: 0, priceChange24h: 0, volume24h: 0 }
              );
            }
            
            return results;
          } catch (error) {
            clearTimeout(timeoutId);
            throw error;
          }
        },
        async () => {
          // Fallback: return cached data or zeros
          return new Map(mints.map(mint => [
            mint, 
            this.priceCache.get(mint)?.data || { price: 0, priceChange24h: 0 }
          ]));
        }
      );
    } catch (e) {
      console.error(`Error fetching price movements: ${e.message}`);
      // Return whatever we have cached
      return new Map(mints.map(mint => [
        mint, 
        this.priceCache.get(mint)?.data || { price: 0, priceChange24h: 0 }
      ]));
    }
  }
}

// Helius API client
class HeliusApiClient {
  constructor(apiKey) {
    this.apiKey = apiKey;
    this.baseUrl = 'https://api.helius.xyz/v0';
    this.mainnetRpc = `https://mainnet.helius-rpc.com/?api-key=${this.apiKey}`;
  }

  async getTransactionDetails(signature) {
    try {
      const url = `${this.baseUrl}/transactions?api-key=${this.apiKey}`;
      const response = await fetch(url, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          transactions: [signature]
        })
      });

      if (!response.ok) {
        throw new Error(`Helius API error: ${response.status} ${response.statusText}`);
      }

      const data = await response.json();
      if (!data || !Array.isArray(data) || data.length === 0) {
        throw new Error('Invalid response from Helius API');
      }
      
      return data[0];
    } catch (error) {
      console.error(`Error fetching transaction details: ${error.message}`);
      return null;
    }
  }

  getMainnetRpc() {
    return this.mainnetRpc;
  }
}

// Risk management
class RiskManager {
  constructor(bot, config) {
    this.bot = bot;
    this.storage = bot.storage;
    this.riskPercentage = config.riskPercentage || 1;
    this.minProfitThreshold = config.minProfitThreshold || 0.1;
    this.stopLossPercentage = config.stopLossPercentage || 2.5;
    this.dailyLossLimit = config.dailyLossLimit || 3;
    this.maxPriceImpact = config.maxPriceImpact || 2.0;
    this.dailyMoverThreshold = config.dailyMoverThreshold || 5;
  }

  hasHitDailyLossLimit() {
    if (this.bot.stats.dailyStartBalance <= 0) return false;
    const lossPercentage = (this.bot.stats.dailyPnL / this.bot.stats.dailyStartBalance) * 100;
    return lossPercentage <= -this.dailyLossLimit;
  }

  getTokenStopLossThreshold(mint) {
    const baseStopLoss = this.stopLossPercentage;
    const volatilityFactor = this.bot.tokenRegistry.getVolatilityFactor(mint) || 1.0;
    return baseStopLoss * volatilityFactor;
  }

  async checkStopLoss(mint, currentValueUsd) {
    try {
      const symbol = this.bot.tokenRegistry.mintToSymbol(mint);
      const stopLossKey = `stopLoss_${mint}`;

      const stopLossThreshold = this.getTokenStopLossThreshold(mint);
      const highWaterMarkStr = this.storage.getStoredValue(stopLossKey);
      let highWaterMarkUsd = highWaterMarkStr ? parseFloat(highWaterMarkStr) : 0;

      if (currentValueUsd > highWaterMarkUsd) {
        highWaterMarkUsd = currentValueUsd;
        this.storage.setStoredValue(stopLossKey, highWaterMarkUsd.toString());
        return { triggered: false };
      }

      if (highWaterMarkUsd > 0) {
        const dropPercentage = (1 - (currentValueUsd / highWaterMarkUsd)) * 100;
        if (dropPercentage >= stopLossThreshold) {
          console.log(`⚠️ STOP LOSS TRIGGERED for ${symbol}:`);
          console.log(`Peak value: $${highWaterMarkUsd.toFixed(2)}`);
          console.log(`Current value: $${currentValueUsd.toFixed(2)}`);
          console.log(`Drop: ${dropPercentage.toFixed(2)}% (threshold: ${stopLossThreshold.toFixed(2)}%)`);
          
          return { 
            triggered: true, 
            mint, 
            symbol,
            dropPercentage,
            highWaterMarkUsd,
            currentValueUsd,
            threshold: stopLossThreshold
          };
        }
      }

      return { triggered: false };
    } catch (error) {
      console.error(`Error in stop loss check for ${this.bot.tokenRegistry.mintToSymbol(mint)}: ${error.message}`);
      return { triggered: false };
    }
  }

  calculateAdaptiveSlippage(priceImpact, inputMint, outputMint) {
    const inputTokenSlippage = this.bot.tokenRegistry.getTokenSlippage(inputMint);
    const outputTokenSlippage = this.bot.tokenRegistry.getTokenSlippage(outputMint);
    
    // Use the higher of the two token slippages as base
    let slippage = Math.max(inputTokenSlippage, outputTokenSlippage);
    
    // Get token volatility factors
    const inputVolatility = this.bot.tokenRegistry.getVolatilityFactor(inputMint);
    const outputVolatility = this.bot.tokenRegistry.getVolatilityFactor(outputMint);
    
    // Use the higher volatility factor
    const volatilityFactor = Math.max(inputVolatility, outputVolatility);

    // Adjust slippage based on volatility
    slippage *= volatilityFactor;

    // Adjust based on price impact
    if (priceImpact > 1) {
      slippage += priceImpact * 0.5; // Add 0.5% for each 1% of price impact
    }

    // Additional adjustment for higher impacts
    if (priceImpact > 3) {
      slippage += priceImpact * 0.3; // Add another 0.3% per 1% for high impacts
    }

    // Cap maximum slippage
    const maxSlippage = volatilityFactor > 2 ? 12 : 8;
    
    return Math.min(slippage, maxSlippage);
  }

  findBestRoute(routes, inputMint, outputMint) {
    if (!routes || routes.length === 0) {
      return null;
    }

    // Get token-specific max price impact
    const tokenVolatilityFactorIn = this.bot.tokenRegistry.getVolatilityFactor(inputMint);
    const tokenVolatilityFactorOut = this.bot.tokenRegistry.getVolatilityFactor(outputMint);
    const volatilityFactor = Math.max(tokenVolatilityFactorIn, tokenVolatilityFactorOut);
    
    // Adjust price impact threshold based on token volatility
    const adjustedMaxPriceImpact = this.maxPriceImpact * volatilityFactor;

    // Remove routes with excessive price impact
    const filteredRoutes = routes.filter(route => 
      route.priceImpactPct < adjustedMaxPriceImpact
    );

    if (filteredRoutes.length === 0) {
      console.warn(`All routes exceed maximum price impact (${adjustedMaxPriceImpact.toFixed(2)}%), falling back to best available`);
      // Sort by best output in descending order
      const sortedRoutes = routes.sort((a, b) => 
        parseFloat(b.outAmount) - parseFloat(a.outAmount)
      );
      
      console.warn(`Selected route has high price impact: ${sortedRoutes[0].priceImpactPct.toFixed(2)}%`);
      return sortedRoutes[0];
    }

    // Sort by expected output in descending order (higher is better)
    const sortedRoutes = filteredRoutes.sort((a, b) => 
      parseFloat(b.outAmount) - parseFloat(a.outAmount)
    );
    
    return sortedRoutes[0];
  }

  setRiskPercentage(percentage) {
    if (percentage <= 0 || percentage > 100) {
      throw new Error('Risk percentage must be between 1 and 100');
    }
    this.riskPercentage = percentage;
  }

  setMinProfitThreshold(threshold) {
    if (threshold < 0) {
      throw new Error('Minimum profit threshold cannot be negative');
    }
    this.minProfitThreshold = threshold;
  }

  setDailyLossLimit(percentage) {
    if (percentage <= 0) {
      throw new Error('Daily loss limit must be greater than 0');
    }
    this.dailyLossLimit = percentage;
  }

  setStopLossPercentage(percentage) {
    if (percentage <= 0) {
      throw new Error('Stop loss percentage must be greater than 0');
    }
    this.stopLossPercentage = percentage;
  }

  setMaxPriceImpact(percentage) {
    if (percentage <= 0) {
      throw new Error('Maximum price impact must be greater than 0');
    }
    this.maxPriceImpact = percentage;
  }
}

// Notification system
class NotificationManager {
  constructor(storage) {
    this.storage = storage;
    this.handlers = [];
  }

  addHandler(handler) {
    if (typeof handler === 'function') {
      this.handlers.push(handler);
    }
  }

  notify(message, level = 'info') {
    this.handlers.forEach(handler => {
      try {
        if (typeof handler === 'function') {
          // Simple handlers get just the message
          handler(message, level);
        } else if (handler && typeof handler.send === 'function') {
          // Object-based handlers with send method
          handler.send(message, level);
        }
      } catch (e) {
        console.error('Notification handler error:', e);
      }
    });
  }

  async sendDiscordNotification(message, level = 'info') {
    try {
      // Find Discord webhook handlers
      const discordHandlers = this.handlers.filter(h => 
        h.isDiscord || (typeof h === 'object' && h.type === 'discord')
      );
      
      if (discordHandlers.length === 0) {
        return;
      }
      
      // Send to all Discord handlers
      for (const handler of discordHandlers) {
        try {
          if (typeof handler === 'function') {
            await handler(message, level);
          } else if (handler && typeof handler.send === 'function') {
            await handler.send(message, level);
          }
        } catch (e) {
          console.error(`Error sending Discord notification: ${e.message}`);
        }
      }
    } catch (error) {
      console.error(`Error building Discord notification: ${error.message}`);
    }
  }

  async sendDiscordTradeNotification(data) {
    try {
      const { strategy, tradeType, inputAmount, inputSymbol, outputAmount, outputSymbol, profit, profitPercent, txid, priceMovement } = data;
      
      let message = '';
      let messageLevel = 'info';
      
      if (strategy === 'ARBITRAGE') {
