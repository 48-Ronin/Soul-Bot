          }
        } catch (error) {
          console.error(`Discord webhook error: ${error.message}`);
        }
      };

      // Mark this handler as a Discord handler
      discordHandler.isDiscord = true;
      discordHandler.type = 'discord';

      // Add to notification handlers
      this.addHandler(discordHandler);
      console.log('Discord webhook added successfully');
      
      // Test the webhook
      discordHandler('🔄 **Discord notifications enabled**\nThis is a test message to confirm webhook functionality.', 'info');
    } catch (error) {
      console.error(`Error adding Discord webhook: ${error.message}`);
    }
  }
}

// Transaction helper
class TransactionHelper {
  constructor(bot) {
    this.bot = bot;
    this.connection = bot.rpcManager.connection;
    this.wallet = bot.wallet;
    this.maxRetries = 3;
    this.transactionTimeoutMs = 60000;
    this.cachedFeeEstimate = null;
  }

  async ensureTokenAccount(mint) {
    if (mint === this.bot.tokenRegistry.registry.SOL) {
      return true;
    }

    try {
      const mintPubkey = new PublicKey(mint);
      const associatedTokenAddress = getAssociatedTokenAddressSync(
        mintPubkey,
        this.wallet.publicKey,
        false,
        TOKEN_PROGRAM_ID
      );
      
      // Check if account exists
      const account = await this.connection.getAccountInfo(associatedTokenAddress);
      
      if (account) {
        return true;
      }
      
      // Account doesn't exist, create it
      console.log(`Creating token account for ${this.bot.tokenRegistry.mintToSymbol(mint)}`);
      
      const transaction = new Transaction().add(
        createAssociatedTokenAccountInstruction(
          this.wallet.publicKey,
          associatedTokenAddress,
          this.wallet.publicKey,
          mintPubkey,
          TOKEN_PROGRAM_ID
        )
      );
      
      const { blockhash } = await this.connection.getRecentBlockhash('finalized');
      transaction.recentBlockhash = blockhash;
      transaction.feePayer = this.wallet.publicKey;
      
      const signature = await this.sendAndConfirmTransaction(transaction);
      
      if (!signature) {
        throw new Error('Failed to create token account');
      }
      
      return true;
    } catch (error) {
      console.error(`Error creating token account for ${this.bot.tokenRegistry.mintToSymbol(mint)}: ${error.message}`);
      
      // Try with different RPC endpoint
      if (await this.bot.rpcManager.switchEndpoint()) {
        this.connection = this.bot.rpcManager.connection;
        return await this.ensureTokenAccount(mint);
      }
      
      return false;
    }
  }

  async estimateTransactionFee() {
    try {
      // Use cached estimate if available and not expired
      const now = Date.now();
      if (this.cachedFeeEstimate && now < this.cachedFeeEstimate.expiresAt) {
        return this.cachedFeeEstimate.fee;
      }

      // Get recent blockhash and fee calculator
      const { feeCalculator, blockhash } = await this.connection.getRecentBlockhash('finalized');

      // Base fee in lamports
      const baseFee = feeCalculator ? feeCalculator.lamportsPerSignature : 5000;

      // Get priority fee estimates
      let priorityFee = 0;
      try {
        const priorityFeeResponse = await this.connection.getRecentPrioritizationFees();
        if (priorityFeeResponse && priorityFeeResponse.length > 0) {
          // Calculate the median priority fee from recent fees
          const sortedFees = priorityFeeResponse
            .map(item => item.prioritizationFee)
            .sort((a, b) => a - b);
          
          const medianIndex = Math.floor(sortedFees.length / 2);
          priorityFee = sortedFees[medianIndex];
          
          // Add a safety margin
          priorityFee = Math.ceil(priorityFee * 1.1);
        }
      } catch (e) {
        // Default to a moderate priority fee
        priorityFee = 1000;
      }

      // Adjust based on network congestion
      let congestionMultiplier = 1.0;
      try {
        const performanceSamples = await this.connection.getRecentPerformanceSamples(10);
        if (performanceSamples && performanceSamples.length > 0) {
          // Calculate average TPS
          const averageTps = performanceSamples.reduce((sum, sample) => sum + sample.numTransactions / sample.samplePeriodSecs, 0) / performanceSamples.length;
          
          // Adjust multiplier based on TPS
          if (averageTps < 1000) {
            congestionMultiplier = 2.0; // High congestion
          } else if (averageTps < 2000) {
            congestionMultiplier = 1.5; // Medium congestion
          }
        }
      } catch (error) {
        console.warn(`Error checking network performance: ${error.message}`);
      }

      // Calculate final fee estimate
      const estimatedFee = Math.ceil((baseFee + priorityFee) * congestionMultiplier * 1.5); // 1.5 complexity multiplier for swaps

      // Cache this estimate
      const cacheMs = congestionMultiplier > 1.5 ? 5000 : 10000;
      this.cachedFeeEstimate = {
        fee: estimatedFee,
        timestamp: now,
        expiresAt: now + cacheMs,
        blockhash
      };

      return estimatedFee;
    } catch (error) {
      console.error(`Fee estimation error: ${error.message}`);
      return 15000; // 15,000 lamports as safe default
    }
  }

  async sendAndConfirmTransaction(transaction) {
    const maxRetries = this.maxRetries;
    let currentRetry = 0;

    while (currentRetry < maxRetries) {
      try {
        let signature;
        
        if (transaction instanceof VersionedTransaction) {
          signature = await this.connection.sendTransaction(transaction);
          const confirmedSig = await this.waitForConfirmation(signature, this.transactionTimeoutMs);
          if (confirmedSig) return confirmedSig;
          throw new Error('Transaction confirmation timed out');
        } else {
          signature = await sendAndConfirmTransaction(
            this.connection,
            transaction,
            [this.wallet],
            {
              skipPreflight: false,
              commitment: 'confirmed',
              maxRetries: 5,
              confirmTransactionInitialTimeout: this.transactionTimeoutMs
            }
          );
          return signature;
        }
      } catch (error) {
        currentRetry++;
        
        // Check if this is a retryable error
        const isRetryable = 
          error.message?.includes('timeout') || 
          error.message?.includes('block height exceeded') ||
          error.message?.includes('too many requests') ||
          error.message?.includes('rate limit') ||
          error.message?.includes('throttled') ||
          error.message?.includes('blockhash not found') ||
          error.message?.includes('503') ||
          error.message?.includes('500') ||
          error.message?.includes('429');
        
        if (isRetryable && currentRetry < maxRetries) {
          // Exponential backoff with random jitter
          const baseDelay = Math.pow(2, currentRetry) * 1000;
          const jitter = Math.random() * 1000;
          const delay = baseDelay + jitter;
          
          console.warn(`Transaction failed, retrying in ${(delay/1000).toFixed(1)}s (attempt ${currentRetry}/${maxRetries}): ${error.message}`);
          await new Promise(resolve => setTimeout(resolve, delay));
          
          if (error.message?.includes('blockhash') || 
              error.message?.includes('5') || 
              error.message?.includes('429')) {
            await this.bot.rpcManager.switchEndpoint();
            this.connection = this.bot.rpcManager.connection;
          }
        } else {
          console.error(`Error sending transaction: ${error.message}`);
          return null;
        }
      }
    }

    console.error(`Failed to send transaction after ${maxRetries} attempts`);
    return null;
  }

  async waitForConfirmation(signature, timeoutMs = 60000) {
    const startTime = Date.now();
    let checkCount = 0;
    
    while (Date.now() - startTime < timeoutMs) {
      try {
        checkCount++;
        const confirmation = await this.connection.getSignatureStatus(signature);
        
        if (confirmation && confirmation.value && 
            (confirmation.value.confirmationStatus === 'confirmed' || 
             confirmation.value.confirmationStatus === 'finalized')) {
          return signature;
        }
        
        // Adaptive backoff - start with quick checks and then slow down
        const waitTime = Math.min(2000 * Math.pow(1.5, Math.min(checkCount, 5) - 1), 10000);
        await new Promise(resolve => setTimeout(resolve, waitTime));
      } catch (error) {
        console.warn(`Error checking tx confirmation: ${error.message}`);
        await new Promise(resolve => setTimeout(resolve, 3000));
      }
    }

    console.error(`Transaction confirmation timed out after ${timeoutMs/1000}s`);
    return null; // Timed out
  }

  async processTransaction(rawTransaction, wallet) {
    try {
      // Deserialize transaction
      const messageBytes = Buffer.from(rawTransaction, 'base64');
      
      // Check if it's a versioned transaction (first byte is 0x80)
      if ((messageBytes[0] & 0x80) !== 0) {
        // Versioned transaction
        const versionedTx = VersionedTransaction.deserialize(messageBytes);
        versionedTx.sign([wallet]);
        return versionedTx;
      } else {
        // Legacy transaction
        const legacyTx = Transaction.from(messageBytes);
        legacyTx.partialSign(wallet);
        return legacyTx;
      }
    } catch (error) {
      console.error(`Error processing transaction: ${error.message}`);
      throw error;
    }
  }
}

// Base strategy class
class BaseStrategy {
  constructor(bot) {
    this.bot = bot;
    this.isRunning = false;
  }

  async getTokenBalance(mint) {
    const MAX_RETRIES = 3;
    for (let retries = 0; retries < MAX_RETRIES; retries++) {
      try {
        if (mint === this.bot.tokenRegistry.registry.SOL) {
          return (await this.bot.rpcManager.connection.getBalance(this.bot.wallet.publicKey)) / 1e9;
        }

        const tokenAccount = await getAssociatedTokenAddressSync(
          new PublicKey(mint),
          this.bot.wallet.publicKey,
          false,
          TOKEN_PROGRAM_ID
        );

        try {
          const info = await this.bot.rpcManager.connection.getTokenAccountBalance(tokenAccount);
          return parseFloat(info.value.amount) / (10 ** info.value.decimals);
        } catch (e) {
          if (e.message.includes('Account not found') || e.message.includes('could not find account')) {
            return 0; // Handle non-existent ATA
          }
          throw e; // Other errors should be retried
        }
      } catch (e) {
        if (retries + 1 === MAX_RETRIES) {
          console.error(`Failed to get balance for ${this.bot.tokenRegistry.mintToSymbol(mint)}: ${e.message}`);
          
          // If we've retried with the current endpoint, try switching RPC
          if (await this.bot.rpcManager.switchEndpoint()) {
            // One more try with new endpoint
            try {
              if (mint === this.bot.tokenRegistry.registry.SOL) {
                return (await this.bot.rpcManager.connection.getBalance(this.bot.wallet.publicKey)) / 1e9;
              }
              const tokenAccount = await getAssociatedTokenAddressSync(
                new PublicKey(mint),
                this.bot.wallet.publicKey,
                false,
                TOKEN_PROGRAM_ID
              );
              const info = await this.bot.rpcManager.connection.getTokenAccountBalance(tokenAccount);
              return parseFloat(info.value.amount) / (10 ** info.value.decimals);
            } catch {
              return 0; // Give up if even the fallback RPC fails
            }
          }
          
          return 0;
        }

        // Exponential backoff
        const backoffMs = Math.pow(2, retries) * 1000;
        await new Promise(resolve => setTimeout(resolve, backoffMs));
      }
    }
    return 0;
  }

  async getTokenDecimals(mint) {
    // Check cache in tokenRegistry
    if (this.bot.tokenRegistry.decimalCache.has(mint)) {
      return this.bot.tokenRegistry.decimalCache.get(mint);
    }

    // Special case for SOL
    if (mint === this.bot.tokenRegistry.registry.SOL) {
      this.bot.tokenRegistry.decimalCache.set(mint, 9);
      return 9;
    }

    try {
      // Get token metadata from Solana
      const info = await this.bot.rpcManager.connection.getParsedAccountInfo(new PublicKey(mint));
      
      if (info && info.value && info.value.data && 'parsed' in info.value.data) {
        const parsedData = info.value.data.parsed;
        if (parsedData && parsedData.info && parsedData.info.decimals) {
          const decimals = parsedData.info.decimals;
          this.bot.tokenRegistry.decimalCache.set(mint, decimals);
          return decimals;
        }
      }
      
      // Fallbacks for common tokens
      const commonDecimals = {
        [this.bot.tokenRegistry.registry.USDC]: 6,
        [this.bot.tokenRegistry.registry.USDT]: 6,
        [this.bot.tokenRegistry.registry.BONK]: 5,
        [this.bot.tokenRegistry.registry.MSOL]: 9,
        [this.bot.tokenRegistry.registry.SAMO]: 9,
        [this.bot.tokenRegistry.registry.JUP]: 6,
      };
      
      if (commonDecimals[mint]) {
        this.bot.tokenRegistry.decimalCache.set(mint, commonDecimals[mint]);
        return commonDecimals[mint];
      }
      
      // Default to 9 decimals
      console.warn(`Could not determine decimals for ${this.bot.tokenRegistry.mintToSymbol(mint)}, using default of 9`);
      this.bot.tokenRegistry.decimalCache.set(mint, 9);
      return 9;
    } catch (error) {
      console.error(`Error getting token decimals for ${this.bot.tokenRegistry.mintToSymbol(mint)}: ${error.message}`);
      
      if (error.message.includes('rate limit') || error.message.includes('429')) {
        // Try with a different RPC endpoint
        await this.bot.rpcManager.switchEndpoint();
        // Retry once with new endpoint
        try {
          const info = await this.bot.rpcManager.connection.getParsedAccountInfo(new PublicKey(mint));
          if (info && info.value && info.value.data && 'parsed' in info.value.data) {
            const decimals = info.value.data.parsed.info.decimals;
            this.bot.tokenRegistry.decimalCache.set(mint, decimals);
            return decimals;
          }
        } catch {
          // Fall through to default
        }
      }
      
      // Default to 9 decimals
      this.bot.tokenRegistry.decimalCache.set(mint, 9);
      return 9;
    }
  }

  async executeTrade(inputMint, outputMint, amount, quote, strategy, priceMovement = 0) {
    try {
      const inputSymbol = this.bot.tokenRegistry.mintToSymbol(inputMint);
      const outputSymbol = this.bot.tokenRegistry.mintToSymbol(outputMint);
      const tradeType = strategy === 'ARBITRAGE' ? 'SWAP' : (inputMint === this.bot.tokenRegistry.registry.USDC ? 'BUY' : 'SELL');

      // Validate minimum viable amount
      const prices = await this.bot.jupiterClient.getTokenPrices([inputMint]);
      const inputPrice = prices.get(inputMint)?.price || 0;
      const inputValueUsd = amount * inputPrice;
      const minViableUsd = 0.1; // $0.10 minimum value
      
      if (inputValueUsd < minViableUsd) {
        console.warn(`Trade value too small: $${inputValueUsd.toFixed(4)} < $${minViableUsd}`);
        return false;
      }

      // Get token decimals
      const inputDecimals = await this.getTokenDecimals(inputMint);
      const outputDecimals = await this.getTokenDecimals(outputMint);

      // Correctly format amounts with proper decimals
      const inputAmount = amount;
      const outputAmount = parseFloat(quote.outAmount) / Math.pow(10, outputDecimals);

      const tradeDetails = {
        timestamp: new Date().toISOString(),
        strategy,
        tradeType,
        input: {
          mint: inputMint,
          symbol: inputSymbol,
          amount: inputAmount
        },
        output: {
          mint: outputMint,
          symbol: outputSymbol,
          amount: outputAmount
        },
        priceMovement,
      };

      this.bot.stats.totalTrades++;

      // In simulation mode, just log the trade
      if (this.bot.simulationMode) {
        this.bot.notify(`[SIMULATION] [${strategy}] ${tradeType}: ${inputAmount.toFixed(6)} ${inputSymbol} → ${outputAmount.toFixed(6)} ${outputSymbol}`);
        this.bot.stats.successfulTrades++;

        // Calculate profit/loss
        const outputPrice = (await this.bot.jupiterClient.getTokenPrices([outputMint])).get(outputMint)?.price || 0;
        const profit = (outputAmount * outputPrice) - (inputAmount * inputPrice);
        this.bot.stats.profitLoss += profit;
        this.bot.stats.currentBalanceUsd += profit;

        // Add to trade history
        tradeDetails.status = 'simulated';
        tradeDetails.profit = profit;
        this.bot.stats.addTradeToHistory(tradeDetails);
        
        // Send Discord notification
        if (Math.abs(profit) > 0.01) {
          await this.bot.notificationManager.sendDiscordTradeNotification({
            strategy,
            tradeType,
            inputAmount: inputAmount,
            inputSymbol,
            outputAmount,
            outputSymbol,
            profit,
            profitPercent: (profit / inputValueUsd) * 100
          });
        }
        return true;
      }

      // Create transaction helper
      const txHelper = new TransactionHelper(this.bot);

      // Check if token accounts exist, create if needed
      const inputAccountExists = await txHelper.ensureTokenAccount(inputMint);
      const outputAccountExists = await txHelper.ensureTokenAccount(outputMint);

      if (!inputAccountExists || !outputAccountExists) {
        console.error(`Failed to ensure token accounts exist`);
        this.bot.stats.failedTrades++;
        tradeDetails.status = 'failed';
        tradeDetails.error = 'Token account creation failed';
        this.bot.stats.addTradeToHistory(tradeDetails);
        return false;
      }

      // Calculate adaptive slippage based on token properties
      const priceImpact = quote.priceImpactPct || 0;
      const adaptiveSlippage = this.bot.riskManager.calculateAdaptiveSlippage(priceImpact, inputMint, outputMint);
      const slippageBps = Math.floor(adaptiveSlippage * 100);
      
      console.log(`Using adaptive slippage of ${adaptiveSlippage.toFixed(2)}% (${slippageBps} bps) for ${inputSymbol}-${outputSymbol}`);

      // Create swap transaction
      const txBase64 = await this.bot.jupiterClient.createSwapTransaction(
        quote, this.bot.wallet.publicKey, slippageBps
      );
      
      if (!txBase64) {
        console.error(`Failed to create swap transaction`);
        this.bot.stats.failedTrades++;
        tradeDetails.status = 'failed';
        tradeDetails.error = 'Failed to create transaction';
        this.bot.stats.addTradeToHistory(tradeDetails);
        return false;
      }

      // Process the transaction
      const transaction = await txHelper.processTransaction(txBase64, this.bot.wallet);

      // Calculate estimated fee before sending
      const estimatedFeeInLamports = await txHelper.estimateTransactionFee();
      const solPrice = (await this.bot.jupiterClient.getTokenPrices([this.bot.tokenRegistry.registry.SOL])).get(this.bot.tokenRegistry.registry.SOL)?.price || 0;
      const estimatedFeeUsd = (estimatedFeeInLamports / 1e9) * solPrice;
      
      console.log(`Estimated transaction fee: ${estimatedFeeInLamports} lamports ($${estimatedFeeUsd.toFixed(4)})`);

      // Pre-trade notification to Discord
      await this.bot.notificationManager.sendDiscordNotification(
        `🔄 **EXECUTING TRADE**\n${strategy} ${tradeType}: ${inputAmount.toFixed(6)} ${inputSymbol} → ${outputAmount.toFixed(6)} ${outputSymbol}`,
        'info'
      );

      // Send and confirm transaction
      const txid = await txHelper.sendAndConfirmTransaction(transaction);
      if (!txid) {
        console.error(`Transaction failed to confirm`);
        this.bot.stats.failedTrades++;
        tradeDetails.status = 'failed';
        tradeDetails.error = 'Transaction failed to confirm';
        this.bot.stats.addTradeToHistory(tradeDetails);
        return false;
      }

      // Get enhanced transaction details from Helius
      const enhancedStatus = await this.bot.heliusClient.getTransactionDetails(txid);

      // Calculate profit/loss
      const outputPrice = (await this.bot.jupiterClient.getTokenPrices([outputMint])).get(outputMint)?.price || 0;
      const profit = (outputAmount * outputPrice) - (inputAmount * inputPrice);
      const profitWithFees = profit - estimatedFeeUsd;

      // Add to trade history with enhanced data
      tradeDetails.status = 'success';
      tradeDetails.txid = txid;
      tradeDetails.profit = profitWithFees;
      tradeDetails.enhancedData = {
        slot: enhancedStatus?.slot,
        confirmedAt: new Date().toISOString(),
        fee: enhancedStatus?.fee || estimatedFeeInLamports,
        feeUsd: estimatedFeeUsd
      };

      this.bot.stats.addTradeToHistory(tradeDetails);

      // Store the full transaction details separately
      if (enhancedStatus) {
        this.bot.storage.storeTransactionDetails(txid, enhancedStatus);
      }

      // Update stats
      this.bot.stats.successfulTrades++;
      this.bot.stats.profitLoss += profitWithFees;

      // Notify about the trade
      this.bot.notify(`[${strategy}] ${tradeType} executed: ${inputAmount.toFixed(6)} ${inputSymbol} → ${outputAmount.toFixed(6)} ${outputSymbol} (${profitWithFees >= 0 ? '+' : ''}$${profitWithFees.toFixed(4)})`);
      
      // Send detailed Discord notification
      await this.bot.notificationManager.sendDiscordTradeNotification({
        strategy,
        tradeType,
        inputAmount,
        inputSymbol,
        outputAmount,
        outputSymbol,
        profit: profitWithFees,
        profitPercent: (profitWithFees / inputValueUsd) * 100,
        txid,
        priceMovement
      });

      return true;
    } catch (error) {
      console.error(`Trade execution failed: ${error.message}`);
      this.bot.stats.failedTrades++;

      // Add failed trade to history
      const tradeDetails = {
        timestamp: new Date().toISOString(),
        strategy,
        tradeType: strategy === 'ARBITRAGE' ? 'SWAP' : (inputMint === this.bot.tokenRegistry.registry.USDC ? 'BUY' : 'SELL'),
        input: {
          mint: inputMint,
          symbol: this.bot.tokenRegistry.mintToSymbol(inputMint),
          amount
        },
        output: {
          mint: outputMint,
          symbol: this.bot.tokenRegistry.mintToSymbol(outputMint),
          amount: 0
        },
        status: 'failed',
        error: error.message,
        priceMovement,
      };

      this.bot.stats.addTradeToHistory(tradeDetails);
      
      // Send Discord failure notification
      await this.bot.notificationManager.sendDiscordNotification(
        `❌ **TRADE FAILED**\n${strategy} ${tradeDetails.tradeType}: ${amount.toFixed(6)} ${this.bot.tokenRegistry.mintToSymbol(inputMint)} → ${this.bot.tokenRegistry.mintToSymbol(outputMint)}\nError: ${error.message}`,
        'error'
      );
      
      return false;
    }
  }

  async executeStopLossExit(mint) {
    try {
      const symbol = this.bot.tokenRegistry.mintToSymbol(mint);
      console.log(`Executing stop loss exit for ${symbol}`);

      // Get token balance
      const balance = await this.getTokenBalance(mint);
      const minViableAmount = this.bot.tokenRegistry.getMinViableAmount(mint);
      
      if (balance <= minViableAmount) {
        console.warn(`No significant balance for ${symbol}, skipping stop loss exit`);
        return false;
      }

      // Choose appropriate stable coin as destination
      const stableMint = this.bot.tokenRegistry.registry.USDC;

      // Get exit quote - sell 98% of the balance (leave a bit for dust)
      const exitAmount = balance * 0.98;

      // Log the exit attempt
      console.log(`Stop loss exit: selling ${exitAmount.toFixed(6)} ${symbol} for USDC`);

      // Get quote for the exit trade
      const quote = await this.bot.jupiterClient.getQuote(mint, stableMint, exitAmount);
      if (!quote) {
        console.error(`Failed to get quote for stop loss exit of ${symbol}`);
        return false;
      }

      // Ignore profit threshold for stop loss - execute at market price
      const result = await this.executeTrade(
        mint,
        stableMint,
        exitAmount,
        quote,
        'STOP_LOSS'
      );

      if (result) {
        // Reset stop loss high-water mark after successful exit
        this.bot.storage.setStoredValue(`stopLoss_${mint}`, "0");
        
        // Send urgent notification for stop loss
        await this.bot.notificationManager.sendDiscordNotification(
          `🛑 **STOP LOSS EXECUTED FOR ${symbol}**\nSold ${exitAmount.toFixed(6)} ${symbol} for USDC`,
          'alert'
        );
        
        this.bot.notify(`✅ Stop loss exit completed for ${symbol}`);
        return true;
      } else {
        console.error(`Stop loss exit failed for ${symbol}`);
        return false;
      }
    } catch (error) {
      console.error(`Error executing stop loss exit for ${this.bot.tokenRegistry.mintToSymbol(mint)}: ${error.message}`);
      return false;
    }
  }
}

// Arbitrage strategy
class ArbitrageStrategy extends BaseStrategy {
  constructor(bot, config) {
    super(bot);
    this.allocation = (config.arbitrageAllocation || 40) / 100;
  }

  async execute() {
    if (this.isRunning) {
      console.log('Arbitrage strategy already running, skipping');
      return;
    }

    this.isRunning = true;

    try {
      console.log('Checking arbitrage opportunities...');
      
      // Skip if daily loss limit hit
      if (this.bot.riskManager.hasHitDailyLossLimit()) {
        console.warn('Daily loss limit reached, skipping arbitrage');
        return;
      }
      
      // Calculate available capital
      const portfolioValue = await this.bot.calculatePortfolioValue();
      const arbitrageCapital = portfolioValue * this.allocation;
      const tradeRiskAmount = arbitrageCapital * (this.bot.riskManager.riskPercentage / 100);
      
      console.log(`Arbitrage capital: $${arbitrageCapital.toFixed(2)}, Trade risk: $${tradeRiskAmount.toFixed(2)}`);
      
      // Check SOL balance for fees
      const solBalance = await this.getTokenBalance(this.bot.tokenRegistry.registry.SOL);
      const minimumSolRequired = 0.01; // 0.01 SOL for transaction fees
      
      if (solBalance < minimumSolRequired) {
        console.warn(`Insufficient SOL for transaction fees: ${solBalance.toFixed(6)} SOL, needed: ${minimumSolRequired} SOL`);
        await this.bot.notificationManager.sendDiscordNotification(
          `⚠️ **LOW SOL BALANCE**\nCurrent: ${solBalance.toFixed(6)} SOL\nRequired: ${minimumSolRequired} SOL\nPlease add SOL for transaction fees.`,
          'warn');
        return;
      }
      
      // Check for arbitrage across all trading pairs
      for (const pair of this.bot.tradingPairs) {
        try {
          const [fromMint, toMint] = this.bot.tokenRegistry.parseTradingPair(pair);
          
          // Skip pairs with recent failed attempts
          const pairKey = `${fromMint}-${toMint}`;
          const lastFailTime = parseInt(this.bot.storage.getStoredValue(`lastFail_${pairKey}`) || '0');
          const backoffPeriod = parseInt(this.bot.storage.getStoredValue(`backoff_${pairKey}`) || '60000');
          
          if (Date.now() - lastFailTime < backoffPeriod) {
            console.log(`Skipping recently failed pair ${pair} (in backoff period)`);
            continue;
          }
          
          // Check token balances
          const fromBalance = await this.getTokenBalance(fromMint);
          if (fromBalance <= 0) {
            console.log(`No balance for ${this.bot.tokenRegistry.mintToSymbol(fromMint)}, skipping pair ${pair}`);
            continue;
          }
          
          // Check if token has hit stop loss
          const prices = await this.bot.jupiterClient.getTokenPrices([fromMint]);
          const fromPrice = prices.get(fromMint)?.price || 0;
          const fromValueUsd = fromBalance * fromPrice;
          
          const stopLossCheck = await this.bot.riskManager.checkStopLoss(fromMint, fromValueUsd);
          if (stopLossCheck.triggered) {
            console.warn(`Stop loss triggered for ${this.bot.tokenRegistry.mintToSymbol(fromMint)}, executing exit trade`);
            await this.executeStopLossExit(fromMint);
            continue;
          }
          
          // Calculate trade size - adjust based on token-specific min amounts
          const minViableAmount = this.bot.tokenRegistry.getMinViableAmount(fromMint);
          const tradeSize = Math.max(
            Math.min(tradeRiskAmount / fromPrice, fromBalance * 0.98),
            minViableAmount
          );
          
          if (tradeSize * fromPrice < 0.1) { // Ensure at least $0.10 worth
            console.log(`Trade size too small for ${pair}, skipping`);
            continue;
          }
          
          console.log(`Checking arbitrage for ${pair} with size ${tradeSize.toFixed(6)} ${this.bot.tokenRegistry.mintToSymbol(fromMint)}`);
          
          // Get quote
          const quote = await this.bot.jupiterClient.getQuote(fromMint, toMint, tradeSize);
          if (!quote) {
            // Record failure with exponential backoff
            const currentBackoff = parseInt(this.bot.storage.getStoredValue(`backoff_${pairKey}`) || '60000');
            const newBackoff = Math.min(currentBackoff * 2, 3600000); // Max 1 hour
            this.bot.storage.setStoredValue(`lastFail_${pairKey}`, Date.now().toString());
            this.bot.storage.setStoredValue(`backoff_${pairKey}`, newBackoff.toString());
            
            console.warn(`Failed to get quote for ${pair}, backoff increased to ${newBackoff/1000}s`);
            continue;
          }
          
          // Reset backoff on successful quote
          this.bot.storage.setStoredValue(`backoff_${pairKey}`, '60000');
          
          // Calculate profit
          const outAmount = parseFloat(quote.outAmount) / Math.pow(10, await this.getTokenDecimals(toMint));
          const toPrices = await this.bot.jupiterClient.getTokenPrices([toMint]);
          const toPrice = toPrices.get(toMint)?.price || 0;
          
          const inputValue = tradeSize * fromPrice;
          const outputValue = outAmount * toPrice;
          const profitPercentage = ((outputValue - inputValue) / inputValue) * 100;
          
          // Estimate transaction fee
          const txHelper = new TransactionHelper(this.bot);
          const estimatedFeeInLamports = await txHelper.estimateTransactionFee();
          const solPrices = await this.bot.jupiterClient.getTokenPrices([this.bot.tokenRegistry.registry.SOL]);
          const solPrice = solPrices.get(this.bot.tokenRegistry.registry.SOL)?.price || 0;
          const transactionFeeUsd = (estimatedFeeInLamports / 1e9) * solPrice;
          
          // Calculate net profit after fees
          const netProfitUsd = outputValue - inputValue - transactionFeeUsd;
          const netProfitPercentage = (netProfitUsd / inputValue) * 100;
          
          console.log(`${pair} arbitrage: ${profitPercentage.toFixed(2)}% profit (${netProfitPercentage.toFixed(2)}% after fees)`);
          
          // Execute if profitable
          if (netProfitPercentage > this.bot.riskManager.minProfitThreshold) {
            console.log(`Executing arbitrage for ${pair} with ${netProfitPercentage.toFixed(2)}% profit`);
            await this.executeTrade(fromMint, toMint, tradeSize, quote, 'ARBITRAGE');
            
            // Wait a bit after successful trade
            await new Promise(resolve => setTimeout(resolve, 5000));
          }
        } catch (e) {
          console.error(`Error checking arbitrage for ${pair}: ${e.message}`);
        }
      }
    } catch (error) {
      console.error(`Error in arbitrage strategy: ${error.message}`);
    } finally {
      this.isRunning = false;
    }
  }
}

// Daily Movers strategy
class DailyMoversStrategy extends BaseStrategy {
  constructor(bot, config) {
    super(bot);
    this.allocation = (config.dailyMoversAllocation || 60) / 100;
    this.threshold = config.dailyMoverThreshold || 5;
  }

  async execute() {
    if (this.isRunning) {
      console.log('Daily movers strategy already running, skipping');
      return;
    }

    this.isRunning = true;

    try {
      console.log('Scanning for daily movers...');
      
      // Skip if daily loss limit hit
      if (this.bot.riskManager.hasHitDailyLossLimit()) {
        console.warn('Daily loss limit reached, skipping daily movers');
        return;
      }
      
      // Calculate available capital
      const portfolioValue = await this.bot.calculatePortfolioValue();
      const dailyMoverCapital = portfolioValue * this.allocation;
      const tradeRiskAmount = dailyMoverCapital * (this.bot.riskManager.riskPercentage / 100);
      
      console.log(`Daily movers capital: $${dailyMoverCapital.toFixed(2)}, Trade risk: $${tradeRiskAmount.toFixed(2)}`);
      
      // Check SOL balance for fees
      const solBalance = await this.getTokenBalance(this.bot.tokenRegistry.registry.SOL);
      const minimumSolRequired = 0.01; // 0.01 SOL for transaction fees
      
      if (solBalance < minimumSolRequired) {
        console.warn(`Insufficient SOL for transaction fees: ${solBalance.toFixed(6)} SOL, needed: ${minimumSolRequired} SOL`);
        return;
      }
      
      // Get unique tokens to check
      const uniqueTokens = new Set();

      // Add all tokens from trading pairs
      this.bot.tradingPairs.forEach(pair => {
        const [fromMint, toMint] = this.bot.tokenRegistry.parseTradingPair(pair);
        uniqueTokens.add(fromMint);
        uniqueTokens.add(toMint);
      });
      
      // Get token price movements
      const tokenPrices = await this.bot.jupiterClient.getTokenPrices(Array.from(uniqueTokens));
      
      // Check market volatility and adjust threshold
      let marketVolatilitySum = 0;
      let volatileTokenCount = 0;
      
      // Calculate average market volatility
      for (const [mint, data] of tokenPrices.entries()) {
        if (!this.bot.tokenRegistry.isStablecoin(mint) && data.price > 0) {
          marketVolatilitySum += Math.abs(data.priceChange24h);
          volatileTokenCount++;
        }
      }
      
      const avgMarketVolatility = volatileTokenCount > 0 ? marketVolatilitySum / volatileTokenCount : 0;
      this.bot.storage.setStoredValue('marketVolatility', avgMarketVolatility.toString());
      
      if (avgMarketVolatility > 10) {
        console.warn(`High market volatility detected: ${avgMarketVolatility.toFixed(2)}%`);
        if (avgMarketVolatility > 15) {
          await this.bot.notificationManager.sendDiscordNotification(
            `⚠️ **HIGH MARKET VOLATILITY ALERT**\nAverage 24h price change: ${avgMarketVolatility.toFixed(2)}%\nTrading with extra caution`,
            'warn'
          );
        }
      }
      
      // Adjust threshold based on market volatility
      let adjustedThreshold = this.threshold;
      if (avgMarketVolatility > 12) {
        adjustedThreshold = this.threshold * 1.5;
        console.log(`Increased daily mover threshold to ${adjustedThreshold.toFixed(1)}% due to high market volatility`);
      }
      
      // Filter for significant movers
      const significantMovers = Array.from(tokenPrices.entries())
        .filter(([mint, data]) => {
          // Skip stablecoins
          if (this.bot.tokenRegistry.isStablecoin(mint)) return false;
          
          // Skip tokens with insufficient price data
          if (!data.price || data.price === 0) return false;
          
          // Check for significant movement and volume
          const significantMove = Math.abs(data.priceChange24h) >= adjustedThreshold;
          const sufficientVolume = data.volume24h > 50000; // $50k minimum volume
          
          return significantMove && sufficientVolume;
        })
        .sort((a, b) => Math.abs(b[1].priceChange24h) - Math.abs(a[1].priceChange24h));
      
      if (significantMovers.length === 0) {
        console.log('No significant daily movers found');
        return;
      }
      
      console.log(`Found ${significantMovers.length} significant daily movers`);
      
      // Send Discord notification with found movers
      if (significantMovers.length > 0) {
        let moversMessage = `📊 **DAILY MOVERS DETECTED**\n`;
        significantMovers.slice(0, 5).forEach(([mint, data], index) => {
          const symbol = this.bot.tokenRegistry.mintToSymbol(mint);
          const change = data.priceChange24h.toFixed(2);
          const direction = data.priceChange24h > 0 ? '📈' : '📉';
          moversMessage += `${index+1}. ${direction} **${symbol}**: ${change}% ($${(data.volume24h/1000).toFixed(0)}k vol)\n`;
        });
        
        if (significantMovers.length > 5) {
          moversMessage += `...and ${significantMovers.length - 5} more`;
        }
        
        await this.bot.notificationManager.sendDiscordNotification(moversMessage, 'info');
      }
      
      // Process each significant mover
      for (const [mint, data] of significantMovers) {
        const symbol = this.bot.tokenRegistry.mintToSymbol(mint);
        console.log(`${symbol}: ${data.priceChange24h.toFixed(2)}% price change, $${data.volume24h.toFixed(0)} volume`);
        
        // Determine trade direction:
        // - Negative price change: BUY (price dropped, expect recovery)
        // - Positive price change: SELL (price jumped, take profit)
        const direction = data.priceChange24h <= -adjustedThreshold ? 'BUY' : 'SELL';
        
        await this.tradeDailyMover(
          direction === 'BUY' ? this.bot.tokenRegistry.registry.USDC : mint,
          direction === 'BUY' ? mint : this.bot.tokenRegistry.registry.USDC,
          data.priceChange24h,
          direction,
          tradeRiskAmount
        );
        
        // Wait a bit between trades
        await new Promise(resolve => setTimeout(resolve, 5000));
      }
    } catch (error) {
      console.error(`Error in daily movers strategy: ${error.message}`);
    } finally {
      this.isRunning = false;
    }
  }

  async tradeDailyMover(fromMint, toMint, priceChange, direction, maxTradeSize) {
    try {
      const fromSymbol = this.bot.tokenRegistry.mintToSymbol(fromMint);
      const toSymbol = this.bot.tokenRegistry.mintToSymbol(toMint);
      
      console.log(`Evaluating ${direction} opportunity for ${fromSymbol} → ${toSymbol} (${priceChange.toFixed(2)}% move)`);
      
      // Check balance
      const fromBalance = await this.getTokenBalance(fromMint);
      if (fromBalance <= 0) {
        console.log(`No balance for ${fromSymbol}, skipping trade`);
        return false;
      }
      
      // Check if token has hit stop loss
      const prices = await this.bot.jupiterClient.getTokenPrices([fromMint]);
      const fromPrice = prices.get(fromMint)?.price || 0;
      const fromValueUsd = fromBalance * fromPrice;
      
      const stopLossCheck = await this.bot.riskManager.checkStopLoss(fromMint, fromValueUsd);
      if (stopLossCheck.triggered) {
        console.warn(`Stop loss triggered for ${fromSymbol}, executing exit trade`);
        await this.executeStopLossExit(fromMint);
        return false;
      }
      
      // Calculate safe trade size
      const minViableAmount = this.bot.tokenRegistry.getMinViableAmount(fromMint);
      const maxSafeAmount = fromBalance * 0.98; // Leave 2% to account for price fluctuations
      
      // Determine optimal trade size
      let tradeSize;
      if (direction === 'BUY') {
        // For buys, use a percentage of the max trade size to diversify risk
        const buyPercentage = Math.min(30 + Math.abs(priceChange), 70) / 100; // 30-70% based on price drop
        tradeSize = Math.min(maxTradeSize * buyPercentage / fromPrice, maxSafeAmount);
      } else {
        // For sells, use a higher percentage of available balance to lock in profits
        const sellPercentage = Math.min(50 + Math.abs(priceChange) / 2, 90) / 100; // 50-90% based on price jump
        tradeSize = Math.min(maxSafeAmount * sellPercentage, maxTradeSize / fromPrice);
      }
      
      // Ensure minimum viable amount
      tradeSize = Math.max(tradeSize, minViableAmount);
      
      if (tradeSize * fromPrice < 0.1) { // Ensure at least $0.10 value
        console.log(`Trade size too small for ${fromSymbol}, skipping`);
        return false;
      }
      
      // Get quote
      const quote = await this.bot.jupiterClient.getQuote(fromMint, toMint, tradeSize);
      if (!quote) {
        console.warn(`Failed to get quote for ${fromSymbol} → ${toSymbol}`);
        return false;
      }

      // Calculate output
      const outAmount = parseFloat(quote.outAmount) / Math.pow(10, await this.getTokenDecimals(toMint));
      const toPrices = await this.bot.jupiterClient.getTokenPrices([toMint]);
      const toPrice = toPrices.get(toMint)?.price || 0;
      
      // Determine if trade is favorable
      let shouldTrade = false;
      
      if (direction === 'BUY') {
        // For buys, check execution price vs expected
        const executionPriceChange = ((tradeSize * fromPrice / outAmount) - toPrice) / toPrice * 100;
        
        // Trade is favorable if execution price is within 3% of market price
        shouldTrade = Math.abs(executionPriceChange) < 3.0;
        
        // Additional check for severe price drops (>15%) to avoid catching falling knives
        if (priceChange < -15 && !this.bot.storage.getStoredValue(`confirmed_drop_${toMint}`)) {
          // Only buy after confirming the drop in a second scan
          this.bot.storage.setStoredValue(`confirmed_drop_${toMint}`, 'true');
          console.warn(`Large price drop for ${toSymbol} (${priceChange.toFixed(2)}%), waiting for confirmation`);
          shouldTrade = false;
        }
      } else {
        // For sells, always execute to lock in profits, unless execution price is terrible
        const executionPriceChange = (toPrice - (outAmount / tradeSize)) / toPrice * 100;
        shouldTrade = executionPriceChange < 5.0; // Allow up to 5% slippage for sells
      }
      
      if (shouldTrade) {
        console.log(`Executing ${direction} for ${fromSymbol} → ${toSymbol} (${priceChange.toFixed(2)}% move)`);
        return await this.executeTrade(fromMint, toMint, tradeSize, quote, 'DAILY_MOVER', priceChange);
      } else {
        console.log(`Skipping ${direction} for ${fromSymbol} → ${toSymbol} - unfavorable execution`);
        return false;
      }
    } catch (error) {
      console.error(`Error in daily mover trade: ${error.message}`);
      return false;
    }
  }
}

// Main Bot Class - Entry point and coordinator
class SolanaBot {
  constructor(config) {
    this.config = config;
    this.storage = new StorageManager(config.dataDir);
    this.tokenRegistry = new TokenRegistry(config.tokenRegistry);
    this.rpcManager = new RpcManager(config.rpcEndpoint || ['https://mainnet.helius-rpc.com/?api-key=8d7f2c65-f029-45c5-9aa8-de2dfb41078f']);
    this.notificationManager = new NotificationManager(this.storage);
    
    // Initialize wallet
    this.wallet = WalletManager.initializeWallet(config);
    
    // State tracking
    this.isRunning = false;
    this.simulationMode = config.simulationMode !== false;
    this.isCycleRunning = false;
    this.runIntervalId = null;
    this.stats = new TradingStats(this.storage);
    
    // Initialize API clients
    this.heliusClient = new HeliusApiClient(config.heliusApiKey || '8d7f2c65-f029-45c5-9aa8-de2dfb41078f');
    this.jupiterClient = new JupiterApiClient();
    
    // Initialize strategies
    this.strategies = {
      arbitrage: new ArbitrageStrategy(this, config),
      dailyMovers: new DailyMoversStrategy(this, config)
    };
    
    // Risk parameters
    this.riskManager = new RiskManager(this, config);

    // Initialize trading parameters
    this.tradingPairs = config.pairs || ['USDC-SOL', 'USDC-BONK', 'SOL-BONK', 'USDC-SAMO', 'SOL-SAMO', 'USDC-JUP', 'SOL-JUP'];
    
    this.log(`Bot initialized with wallet: ${this.wallet.publicKey.toString()}`);
    this.log(`Mode: ${this.simulationMode ? 'SIMULATION' : 'LIVE TRADING'}`);
  }

  log(message, level = 'info') {
    const timestamp = new Date().toISOString();
    const formattedMessage = `[${timestamp}] [${level.toUpperCase()}] ${message}`;
    console.log(formattedMessage);
    this.storage.queueLogWrite(formattedMessage);
  }

  notify(message, level = 'info') {
    this.log(message, level);
    this.notificationManager.notify(message, level);
  }

  async start() {
    if (this.isRunning) {
      this.log('Bot is already running', 'warn');
      return;
    }

    try {
      this.isRunning = true;
      this.log('Starting Solana trading bot...');
      
      // Initialize connection
      await this.rpcManager.initializeConnectionPool();
      
      // Load historical data
      await this.stats.loadHistoricalData();
      
      // Calculate starting balance
      this.stats.startingBalanceUsd = await this.calculatePortfolioValue();
      this.log(`Initial portfolio value: $${this.stats.startingBalanceUsd.toFixed(2)}`);
      
      // Store start time
      this.storage.setStoredValue('startTime', Date.now().toString());
      
      // Send initial status
      await this.notificationManager.sendStatusMessage(this);
      
      // Run first cycle immediately
      await this.runTradingCycle();
      
      // Set up intervals with jittered timing
      const baseInterval = 5 * 60 * 1000; // 5 minutes base
      const setupInterval = () => {
        const jitter = Math.random() * 60 * 1000; // Up to 1 minute jitter
        const interval = baseInterval + jitter;
        
        this.runIntervalId = setTimeout(async () => {
          await this.runTradingCycle();
          // Re-setup with new jitter each time
          if (this.isRunning) {
            setupInterval();
          }
        }, interval);
        
        this.log(`Next trading cycle scheduled in ${(interval/60000).toFixed(1)} minutes`);
      };
      
      setupInterval();
      
      // Set up daily summary (at midnight)
      this.setupDailySummary();
      
      const modeText = this.simulationMode ? 'SIMULATION' : 'LIVE TRADING';
      this.notify(`Bot started in ${modeText} mode`);
      
      // Send startup notification
      await this.notificationManager.sendDiscordNotification(
        `🚀 **BOT STARTED**\nMode: ${modeText}\nWallet: ${this.wallet.publicKey.toString()}\nBalance: $${this.stats.startingBalanceUsd.toFixed(2)}`,
        'info'
      );
      
      return true;
    } catch (error) {
      this.isRunning = false;
      this.log(`Error starting bot: ${error.message}`, 'error');
      
      // Clean up interval if there was an error
      if (this.runIntervalId) {
        clearTimeout(this.runIntervalId);
        this.runIntervalId = null;
      }
      
      // Send alert for startup failure
      try {
        await this.notificationManager.sendDiscordNotification(
          `❌ **BOT STARTUP FAILED**\nError: ${error.message}`,
          'error'
        );
      } catch (e) {
        // Ignore notification errors on startup failure
      }
      
      throw error;
    }
  }

  setupDailySummary() {
    // Check every hour if it's time for daily summary
    const checkDailySummary = async () => {
      const now = new Date();
      
      // Send summary at midnight (00:00-00:05)
      if (now.getHours() === 0 && now.getMinutes() < 5) {
        await this.sendDailySummary();
      }
      
      // Reschedule if bot is still running
      if (this.isRunning) {
        setTimeout(checkDailySummary, 60 * 60 * 1000); // Check every hour
      }
    };
    
    // Start the check cycle
    setTimeout(checkDailySummary, 60 * 60 * 1000);
  }

  async sendDailySummary() {
    try {
      // Calculate daily stats
      const balance = await this.calculatePortfolioValue();
      const dailyPnLPercent = this.stats.dailyStartBalance > 0 ? 
        (this.stats.dailyPnL / this.stats.dailyStartBalance * 100) : 0;
      
      // Get today's trades
      const today = new Date().toISOString().split('T')[0];
      const todayTrades = this.stats.tradeHistory.filter(
        trade => trade.timestamp.startsWith(today) && 
                (trade.status === 'success' || trade.status === 'simulated')
      );
      
      // Calculate success rate
      const todayTotal = todayTrades.length;
      const successRate = todayTotal > 0 ? 
        (todayTrades.length / todayTotal) * 100 : 0;
      
      // Build the message
      let message = `📊 **DAILY TRADING SUMMARY**\n\n`;
      message += `+ **Date:** ${new Date().toLocaleDateString()}\n`;
      message += `+ **Total Trades:** ${todayTotal}\n`;
      message += `+ **Success Rate:** ${successRate.toFixed(1)}%\n`;
      message += `+ **Daily P&L:** ${this.stats.dailyPnL > 0 ? '+' : ''}$${this.stats.dailyPnL.toFixed(4)} (${dailyPnLPercent.toFixed(2)}%)\n\n`;
      message += `+ **Current Balance:** $${balance.toFixed(2)}\n`;
      
      await this.notificationManager.sendDiscordNotification(message, 'info');
    } catch (error) {
      this.log(`Error building Discord summary: ${error.message}`, 'error');
    }
  }

  async stop() {
    if (!this.isRunning) {
      this.log('Bot is not running', 'warn');
      return;
    }

    this.log('Stopping bot...');

    // Clear interval
    if (this.runIntervalId) {
      clearTimeout(this.runIntervalId);
      this.runIntervalId = null;
    }

    this.isRunning = false;

    // Store current state
    try {
      const balance = await this.calculatePortfolioValue();
      this.storage.setStoredValue('lastKnownBalance', balance.toString());
      this.storage.setStoredValue('profitLoss', this.stats.profitLoss.toString());
      
      // Calculate uptime
      const uptime = (Date.now() - parseInt(this.storage.getStoredValue('startTime') || Date.now().toString())) / 1000;
      const hours = Math.floor(uptime / 3600);
      const minutes = Math.floor((uptime % 3600) / 60);
      
      // Send status update to Discord
      await this.notificationManager.sendDiscordNotification(
        `🛑 **BOT STOPPED**\n` +
        `+ Final Balance: $${balance.toFixed(2)}\n` +
        `+ Uptime: ${hours}h ${minutes}m\n` +
        `+ Trades: ${this.stats.totalTrades} (${this.stats.successfulTrades} successful)\n` +
        `+ P&L: ${this.stats.profitLoss >= 0 ? '+' : ''}$${this.stats.profitLoss.toFixed(2)}`,
        'info'
      );
    } catch (e) {
      this.log(`Error sending stop notification: ${e.message}`, 'error');
    }

    this.notify('Bot stopped');
    return true;
  }

  async runTradingCycle() {
    // Skip if already running
    if (this.isCycleRunning) {
      this.log('Trading cycle already in progress, skipping');
      return;
    }

    this.isCycleRunning = true;

    try {
      this.log('--- Starting Trading Cycle ---');
      
      // Check RPC health
      const rpcHealthy = await this.rpcManager.checkHealth();
      if (!rpcHealthy) {
        this.log('RPC endpoint unhealthy, trying alternative', 'warn');
        await this.rpcManager.switchEndpoint();
      }
      
      // Track daily balance
      await this.trackDailyBalance();
      
      // Check daily loss limit
      if (this.riskManager.hasHitDailyLossLimit()) {
        this.log('Daily loss limit reached, skipping trading cycle', 'warn');
        return;
      }
      
      // Check SOL balance for transaction fees
      const solBalance = await this.strategies.arbitrage.getTokenBalance(this.tokenRegistry.registry.SOL);
      const minimumSolRequired = 0.01; // 0.01 SOL for transaction fees
      
      if (solBalance < minimumSolRequired) {
        this.notify(`⚠️ Insufficient SOL for transaction fees: ${solBalance.toFixed(6)} SOL. Need at least ${minimumSolRequired} SOL`, 'alert');
        return;
      }
      
      // Run strategies
      await this.strategies.arbitrage.execute();
      await this.strategies.dailyMovers.execute();
      
    } catch (error) {
      this.log(`Error in trading cycle: ${error.message}`, 'error');
      
      // Send Discord alert for critical errors
      if (error.message.includes('connection') || 
          error.message.includes('timeout') || 
          error.message.includes('network')) {
        await this.notificationManager.sendDiscordNotification(
          `⚠️ **TRADING CYCLE ERROR**\n${error.message}`,
          'error'
        );
      }
    } finally {
      this.isCycleRunning = false;
      this.log('--- Trading Cycle Completed ---');
    }
  }

  async trackDailyBalance() {
    try {
      // Calculate current portfolio value
      const totalBalance = await this.calculatePortfolioValue();

      // Set as daily starting balance if not set yet today
      const today = new Date().toDateString();
      const lastBalanceDay = this.storage.getStoredValue('lastBalanceDay');
      
      if (lastBalanceDay !== today) {
        this.stats.dailyStartBalance = totalBalance;
        this.stats.dailyPnL = 0;
        this.storage.setStoredValue('lastBalanceDay', today);
        this.storage.setStoredValue('dailyStartBalance', this.stats.dailyStartBalance.toString());
        this.log(`New day detected. Setting starting balance: $${this.stats.dailyStartBalance.toFixed(2)}`);
        
        // Store historical balance
        const balanceRecord = {
          date: today,
          balance: totalBalance,
          change: 0
        };
        this.stats.dailyBalances.push(balanceRecord);
        if (this.stats.dailyBalances.length > 30) {
          this.stats.dailyBalances = this.stats.dailyBalances.slice(-30); // Keep only last 30 days
        }
        this.storage.setStoredValue('dailyBalances', JSON.stringify(this.stats.dailyBalances));
        
        // Send notification for new day
        await this.notificationManager.sendDiscordNotification(
          `📅 **NEW TRADING DAY**\nStarting balance: $${this.stats.dailyStartBalance.toFixed(2)}`,
          'info'
        );
      } else if (this.stats.dailyStartBalance === 0) {
        // If we're restarting the bot during the same day, load saved value
        const savedBalance = this.storage.getStoredValue('dailyStartBalance');
        if (savedBalance) {
          this.stats.dailyStartBalance = parseFloat(savedBalance);
        } else {
          this.stats.dailyStartBalance = totalBalance;
          this.storage.setStoredValue('dailyStartBalance', this.stats.dailyStartBalance.toString());
        }
        this.log(`Loaded daily starting balance: $${this.stats.dailyStartBalance.toFixed(2)}`);
      }
      
      // Calculate current daily P&L
      this.stats.dailyPnL = totalBalance - this.stats.dailyStartBalance;
      const dailyPnLPercent = (this.stats.dailyPnL / this.stats.dailyStartBalance * 100);
      this.log(`Current daily P&L: $${this.stats.dailyPnL.toFixed(2)} (${dailyPnLPercent.toFixed(2)}%)`);
      
      // Store last known balance
      this.storage.setStoredValue('lastKnownBalance', totalBalance.toString());
      
      // Check daily loss limit
      if (this.riskManager.hasHitDailyLossLimit()) {
        this.notify(`⚠️ DAILY LOSS LIMIT REACHED: ${dailyPnLPercent.toFixed(2)}% loss exceeds ${this.riskManager.dailyLossLimit}% limit`, 'alert');
        
        // Send Discord alert for loss limit
        await this.notificationManager.sendDiscordNotification(
          `🚨 **DAILY LOSS LIMIT REACHED**\nTrading halted - Daily loss: ${dailyPnLPercent.toFixed(2)}% exceeds ${this.riskManager.dailyLossLimit}% limit\nCurrent balance: $${totalBalance.toFixed(2)}`,
          'error'
        );
      }
      
      return totalBalance;
    } catch (error) {
      this.log(`Error tracking daily balance: ${error.message}`, 'error');
      
      // Try to recover from stored data
      const lastKnownBalanceStr = this.storage.getStoredValue('lastKnownBalance');
      let lastKnownBalance = 0;
      
      if (lastKnownBalanceStr) {
        lastKnownBalance = parseFloat(lastKnownBalanceStr);
        this.log(`Using last known balance: $${lastKnownBalance}`, 'warn');
      }
      
      // If daily start balance is not set, try to load from storage
      if (this.stats.dailyStartBalance === 0) {
        const savedStartBalance = this.storage.getStoredValue('dailyStartBalance');
        if (savedStartBalance) {
          this.stats.dailyStartBalance = parseFloat(savedStartBalance);
          this.log(`Recovered daily starting balance: $${this.stats.dailyStartBalance}`, 'warn');
        } else if (lastKnownBalance > 0) {
          // Use last known balance as starting balance if we have nothing else
          this.stats.dailyStartBalance = lastKnownBalance;
          this.log(`Using last known balance as daily starting balance: $${this.stats.dailyStartBalance}`, 'warn');
        } else {
          // Absolute last resort - use a safe default
          this.stats.dailyStartBalance = 1000;
          this.log(`Using safe default for daily starting balance: $${this.stats.dailyStartBalance}`, 'warn');
        }
      }
      
      return lastKnownBalance > 0 ? lastKnownBalance : this.stats.dailyStartBalance;
    }
  }

  async calculatePortfolioValue() {
    const MAX_RETRIES = 3;
    for (let retries = 0; retries < MAX_RETRIES; retries++) {
      try {
        const uniqueTokens = new Set();

        // Add all tokens from trading pairs
        this.tradingPairs.forEach(pair => {
          const [fromMint, toMint] = this.tokenRegistry.parseTradingPair(pair);
          uniqueTokens.add(fromMint);
          uniqueTokens.add(toMint);
        });

        // Add major tokens like USDC, SOL
        uniqueTokens.add(this.tokenRegistry.registry.USDC);
        uniqueTokens.add(this.tokenRegistry.registry.SOL);

        // Get all token prices in one request
        const tokenArray = Array.from(uniqueTokens);
        const prices = await this.jupiterClient.getTokenPrices(tokenArray);
        
        let totalValue = 0;
        for (const mint of uniqueTokens) {
          const balance = await this.strategies.arbitrage.getTokenBalance(mint);
          if (balance > 0) {
            const price = prices.get(mint)?.price || 0;
            const value = balance * price;
            totalValue += value;
            this.log(`${this.tokenRegistry.mintToSymbol(mint)}: ${balance.toFixed(6)} @ $${price.toFixed(6)} = $${value.toFixed(2)}`, 'debug');
          }
        }

        this.stats.currentBalanceUsd = totalValue;
        return totalValue;
      } catch (e) {
        if (retries + 1 === MAX_RETRIES) {
          this.log(`Portfolio value calculation failed: ${e.message}`, 'error');
          return this.stats.currentBalanceUsd || 0;
        }
        const backoffMs = Math.pow(2, retries) * 1000;
        await new Promise(resolve => setTimeout(resolve, backoffMs));
      }
    }
    return this.stats.currentBalanceUsd || 0;
  }

  addDiscordWebhook(webhookUrl) {
    this.notificationManager.addDiscordWebhook(webhookUrl, this);
    this.log('Discord webhook added');
  }

  getStatus() {
    return {
      isRunning: this.isRunning,
      simulationMode: this.simulationMode,
      currentBalanceUsd: this.stats.currentBalanceUsd,
      startingBalanceUsd: this.stats.startingBalanceUsd,
      dailyStartBalance: this.stats.dailyStartBalance,
      dailyPnL: this.stats.dailyPnL,
      dailyPnLPercent: this.stats.dailyStartBalance > 0 ? 
        (this.stats.dailyPnL / this.stats.dailyStartBalance * 100) : 0,
      totalTrades: this.stats.totalTrades,
      successfulTrades: this.stats.successfulTrades,
      failedTrades: this.stats.failedTrades,
      successRate: this.stats.totalTrades > 0 ? 
        (this.stats.successfulTrades / this.stats.totalTrades * 100) : 0,
      profitLoss: this.stats.profitLoss,
      riskParameters: {
        riskPercentage: this.riskManager.riskPercentage,
        minProfitThreshold: this.riskManager.minProfitThreshold,
        stopLossPercentage: this.riskManager.stopLossPercentage,
        dailyLossLimit: this.riskManager.dailyLossLimit,
        maxPriceImpact: this.riskManager.maxPriceImpact,
        dailyMoverThreshold: this.strategies.dailyMovers.threshold,
      },
      strategyAllocation: {
        dailyMovers: this.strategies.dailyMovers.allocation * 100,
        arbitrage: this.strategies.arbitrage.allocation * 100,
      },
      tradingPairs: this.tradingPairs,
      walletAddress: this.wallet.publicKey.toString(),
      connectionHealth: {
        poolSize: this.rpcManager.connectionPool.length,
        activeEndpoint: this.rpcManager.getCurrentEndpoint()
      }
    };
  }

  // Helper methods to modify configuration
  setRiskPercentage(percentage) {
    this.riskManager.setRiskPercentage(percentage);
    this.log(`Risk percentage set to ${percentage}%`);
  }

  setMinProfitThreshold(threshold) {
    this.riskManager.setMinProfitThreshold(threshold);
    this.log(`Minimum profit threshold set to ${threshold}%`);
  }

  setDailyLossLimit(percentage) {
    this.riskManager.setDailyLossLimit(percentage);
    this.log(`Daily loss limit set to ${percentage}%`);
  }

  setStopLossPercentage(percentage) {
    this.riskManager.setStopLossPercentage(percentage);
    this.log(`Stop loss percentage set to ${percentage}%`);
  }

  setMaxPriceImpact(percentage) {
    this.riskManager.setMaxPriceImpact(percentage);
    this.log(`Maximum price impact set to ${percentage}%`);
  }

  setStrategyAllocation(dailyMoversAllocation, arbitrageAllocation) {
    const total = dailyMoversAllocation + arbitrageAllocation;
    if (total <= 0) {
      throw new Error('Total allocation must be greater than 0');
    }

    this.strategies.dailyMovers.allocation = dailyMoversAllocation / total;
    this.strategies.arbitrage.allocation = arbitrageAllocation / total;

    this.log(`Strategy allocation set to ${this.strategies.dailyMovers.allocation * 100}% Daily Movers, ${this.strategies.arbitrage.allocation * 100}% Arbitrage`);
  }

  addTradingPair(pair) {
    if (!pair.includes('-')) {
      throw new Error('Invalid trading pair format. Use format like "USDC-SOL"');
    }

    const [fromSymbol, toSymbol] = pair.split('-');
    const fromMint = this.tokenRegistry.symbolToMint(fromSymbol);
    const toMint = this.tokenRegistry.symbolToMint(toSymbol);

    if (!fromMint || !toMint) {
      throw new Error('Unknown token symbol. Add to token registry first.');
    }

    if (!this.tradingPairs.includes(pair)) {
      this.tradingPairs.push(pair);
      this.log(`Added trading pair: ${pair}`);
    } else {
      this.log(`Trading pair ${pair} already exists`);
    }
  }

  removeTradingPair(pair) {
    const index = this.tradingPairs.indexOf(pair);
    if (index !== -1) {
      this.tradingPairs.splice(index, 1);
      this.log(`Removed trading pair: ${pair}`);
      return true;
    }
    this.log(`Trading pair not found: ${pair}`);
    return false;
  }

  addToken(symbol, mint) {
    this.tokenRegistry.addToken(symbol, mint);
    this.log(`Added token ${symbol} with mint ${mint}`);
  }
}

module.exports = SolanaBot;
