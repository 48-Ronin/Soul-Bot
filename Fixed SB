        message += `+ Pair: **${inputSymbol}-${outputSymbol}**\n`;
        message += `+ Amount: ${inputAmount.toFixed(6)} ${inputSymbol} → ${outputAmount.toFixed(6)} ${outputSymbol}\n`;
        message += `+ Profit: **${profit >= 0 ? '+' : ''}$${profit.toFixed(4)}** (${profitPercent?.toFixed(2) || '?'}%)`;
      } else if (strategy === 'DAILY_MOVER') {
        const emoji = tradeType === 'BUY' ? '📉➡️📈' : '📈➡️💵';
        message = `${emoji} **DAILY MOVER ${tradeType}**\n`;
        message += `+ Pair: **${inputSymbol}-${outputSymbol}**\n`;
        message += `+ Amount: ${inputAmount.toFixed(6)} ${inputSymbol} → ${outputAmount.toFixed(6)} ${outputSymbol}\n`;
        
        if (priceMovement) {
          message += `+ Price Change: **${priceMovement.toFixed(2)}%**\n`;
        }
        
        if (profit !== undefined) {
          message += `+ P&L: **${profit >= 0 ? '+' : ''}$${profit.toFixed(4)}**`;
        }
      } else if (strategy === 'STOP_LOSS') {
        message = `🛑 **STOP LOSS EXECUTED**\n`;
        message += `+ Pair: **${inputSymbol}-${outputSymbol}**\n`;
        message += `+ Amount: ${inputAmount.toFixed(6)} ${inputSymbol}\n`;
        
        if (profit !== undefined) {
          message += `+ P&L: **${profit >= 0 ? '+' : ''}$${profit.toFixed(4)}**`;
        }
        
        messageLevel = 'alert';
      }
      
      if (txid) {
        const explorerUrl = `https://solscan.io/tx/${txid}`;
        message += `\n+ [View Transaction](${explorerUrl})`;
      }
      
      // Send the message
      await this.sendDiscordNotification(message, messageLevel);
    } catch (error) {
      console.error(`Error sending Discord trade notification: ${error.message}`);
    }
  }
  
  async sendStatusMessage(bot) {
    try {
      const balance = await bot.calculatePortfolioValue();
      const walletAddress = bot.wallet.publicKey.toString();
      const explorerUrl = `https://solscan.io/account/${walletAddress}`;
      
      const message = `🤖 **RONIN BOT STATUS**\n\n` +
                      `+ **Mode:** ${bot.simulationMode ? 'Simulation' : 'Live Trading'}\n` +
                      `+ **Balance:** $${balance.toFixed(2)}\n` +
                      `+ **Wallet:** [${walletAddress.slice(0, 6)}...${walletAddress.slice(-6)}](${explorerUrl})\n` +
                      `+ **Total Trades:** ${bot.stats.totalTrades}\n` +
                      `+ **Success Rate:** ${bot.stats.totalTrades > 0 ? (bot.stats.successfulTrades / bot.stats.totalTrades * 100).toFixed(1) : 0}%\n` +
                      `+ **P&L:** ${bot.stats.profitLoss > 0 ? '+' : ''}$${bot.stats.profitLoss.toFixed(2)}\n\n`;
      
      await this.sendDiscordNotification(message, 'info');
    } catch (error) {
      console.error(`Error building Discord status: ${error.message}`);
    }
  }

  addDiscordWebhook(webhookUrl, bot) {
    try {
      // Create a notification handler that sends to Discord
      const discordHandler = async (message, level = 'info') => {
        try {
          // Determine color based on level
          let color;
          switch (level) {
            case 'error':
            case 'alert':
              color = 0xFF0000; // Red
              break;
            case 'warn':
              color = 0xFFAA00; // Orange
              break;
            case 'success':
              color = 0x00FF00; // Green
              break;
            default:
              color = 0x0099FF; // Blue
          }
          
          // Prepare embed
          const embed = {
            color: color,
            description: message,
            timestamp: new Date().toISOString()
          };
          
          // Add footer with bot info
